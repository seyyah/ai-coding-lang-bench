+def cmd_diff(commit1_hash, commit2_hash):                                     
+    """Compares two commits."""                                               
+    files1 = get_commit_files(commit1_hash)                                   
+    files2 = get_commit_files(commit2_hash)                                   
+                                                                              
+    if files1 is None or files2 is None:                                      
+        print("Invalid commit")                                               
+        sys.exit(1)                                                           
