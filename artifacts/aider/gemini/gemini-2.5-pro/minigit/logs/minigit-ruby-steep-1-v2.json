+# 'diff' command implementation                                               
+def diff_command(hash1, hash2)                                                
+  commit1_data = parse_commit_full(hash1)                                     
+  commit2_data = parse_commit_full(hash2)                                     
+                                                                              
+  unless commit1_data && commit2_data                                         
+    puts "Invalid commit"                                                     
+    exit 1                                                                    
+  end                                                                         
+                                                                              
+  files1 = commit1_data[:files]                                               
+  files2 = commit2_data[:files]                                               
+                                                                              
+  all_files = (files1.keys + files2.keys).uniq.sort                           
+                                                                              
+  all_files.each do |file|                                                    
+    in1 = files1.key?(file)                                                   
+    in2 = files2.key?(file)                                                   
+                                                                              
+    if in1 && !in2                                                            
+      puts "Removed: #{file}"                                                 
+    elsif !in1 && in2                                                         
+      puts "Added: #{file}"                                                   
+    elsif in1 && in2 && files1[file] != files2[file]                          
+      puts "Modified: #{file}"                                                
+      puts "Added: #{file}"                                                   
+    elsif in1 && in2 && files1[file] != files2[file]                          
+      puts "Modified: #{file}"                                                
+    end                                                                       
+  end                                                                         
+end                                                                           
+                                                                              
+# 'checkout' command implementation                                           
+def checkout_command(commit_hash)                                             
+  commit_data = parse_commit_full(commit_hash)                                
+  unless commit_data                                                          
+    puts "Invalid commit"                                                     
+    exit 1                                                                    
+  end                                                                         
+                                                                              
+  commit_data[:files].each do |filename, blob_hash|                           
+    blob_path = File.join(OBJECTS_DIR, blob_hash)                             
+    content = File.binread(blob_path)                                         
+    File.binwrite(filename, content)                                          
+  end                                                                         
+                                                                              
+  File.write(HEAD_FILE, "#{commit_hash}\n")                                   
+  File.truncate(INDEX_FILE, 0)                                                
+                                                                              
+  puts "Checked out #{commit_hash}"                                           
+end                                                                           
+                                                                              
+# 'reset' command implementation                                              
+def reset_command(commit_hash)                                                
+  commit_file_path = File.join(COMMITS_DIR, commit_hash)                      
+  unless commit_hash && File.exist?(commit_file_path)                         
+    puts "Invalid commit"                                                     
+    exit 1                                                                    
+  end                                                                         
+                                                                              
+  File.write(HEAD_FILE, "#{commit_hash}\n")                                   
+  File.truncate(INDEX_FILE, 0)                                                
+                                                                              
+  puts "Reset to #{commit_hash}"                                              
+end                                                                           
+                                                                              
+# 'rm' command implementation                                                 
+def rm_command(file_path)                                                     
+  unless file_path                                                            
+    exit 1                                                                    
+  end                                                                         
+                                                                              
+  index_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:   
true) : []                                                                     
+  unless index_files.include?(file_path)                                      
+    puts "File not in index"                                                  
+    exit 1                                                                    
+  File.open(INDEX_FILE, 'w') do |f|                                           
+    new_index_files.each { |file| f.puts(file) }                              
+  end                                                                         
+end                                                                           
+                                                                              
+# 'show' command implementation                                               
+def show_command(commit_hash)                                                 
+                                                                              
+# 'show' command implementation                                               
+def show_command(commit_hash)                                                 
+  commit_data = parse_commit_full(commit_hash)                                
+  unless commit_data                                                          
+    puts "Invalid commit"                                                     
+    exit 1                                                                    
+  end                                                                         
+                                                                              
+  puts "commit #{commit_hash}"                                                
+  when 'checkout'                                                             
+    checkout_command(ARGV[1])                                                 
+  when 'reset'                                                                
+    reset_command(ARGV[1])                                                    
+  when 'rm'                                                                   
+    rm_command(ARGV[1])                                                       
+  when 'show'                                                                 
+    show_command(ARGV[1])                                                     
   else                                                                        
     exit 1                                                                    
   end                                                                         
 end                                                                           
                                                                               

