minigit.c                                                                      

                                                                               
#include <stdio.h>                                                             
                                                                               
#include <stdlib.h>                                                            
                                                                               
#include <string.h>                                                            
                                                                               
#include <sys/stat.h>                                                          
                                                                               
#include <sys/types.h>                                                         
                                                                               
#include <unistd.h>                                                            
                                                                               
#include <time.h>                                                              
                                                                               
#include <stdint.h>                                                            
                                                                               
                                                                               
                                                                               
// --- Hashing ---                                                             
                                                                               
char* minihash(const void* data, size_t len) {                                 
                                                                               
    const uint8_t* bytes = (const uint8_t*)data;                               
                                                                               
    uint64_t h = 1469598103934665603ULL;                                       
                                                                               
    const uint64_t prime = 1099511628211ULL;                                   
                                                                               
                                                                               
                                                                               
    for (size_t i = 0; i < len; ++i) {                                         
                                                                               
        h ^= bytes[i];                                                         
                                                                               
        h *= prime;                                                            
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    char* hex_str = malloc(17);                                                
                                                                               
    if (!hex_str) {                                                            
                                                                               
        perror("malloc");                                                      
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
    sprintf(hex_str, "%016lx", h);                                             
                                                                               
    return hex_str;                                                            
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// --- File helpers ---                                                        
                                                                               
char* read_file_content(const char *path, size_t *size) {                      
                                                                               
    FILE *f = fopen(path, "rb");                                               
                                                                               
    if (!f) return NULL;                                                       
                                                                               
                                                                               
                                                                               
    fseek(f, 0, SEEK_END);                                                     
                                                                               
    long fsize = ftell(f);                                                     
                                                                               
    fseek(f, 0, SEEK_SET);                                                     
                                                                               
                                                                               
                                                                               
    char *content = malloc(fsize + 1);                                         
                                                                               
    if (!content) {                                                            
                                                                               
        fclose(f);                                                             
                                                                               
        perror("malloc");                                                      
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if (fread(content, 1, fsize, f) != (size_t)fsize) {                        
                                                                               
        if (!feof(f)) { // only error out if it's not EOF                      
                                                                               
             perror("fread");                                                  
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    fclose(f);                                                                 
                                                                               
    content[fsize] = 0;                                                        
                                                                               
    if (size) *size = fsize;                                                   
                                                                               
    return content;                                                            
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void write_file_content(const char *path, const void *content, size_t size) {  
                                                                               
    FILE *f = fopen(path, "wb");                                               
                                                                               
    if (!f) {                                                                  
                                                                               
        perror("fopen");                                                       
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
    if (fwrite(content, 1, size, f) != size) {                                 
                                                                               
        perror("fwrite");                                                      
                                                                               
        fclose(f);                                                             
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
    fclose(f);                                                                 
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// --- Commands ---                                                            
                                                                               
void do_init() {                                                               
                                                                               
    struct stat st = {0};                                                      
                                                                               
    if (stat(".minigit", &st) == 0 && S_ISDIR(st.st_mode)) {                   
                                                                               
        printf("Repository already initialized\n");                            
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    mkdir(".minigit", 0755);                                                   
                                                                               
    mkdir(".minigit/objects", 0755);                                           
                                                                               
    mkdir(".minigit/commits", 0755);                                           
                                                                               
    FILE* index = fopen(".minigit/index", "w");                                
                                                                               
    if (index) fclose(index);                                                  
                                                                               
    FILE* head = fopen(".minigit/HEAD", "w");                                  
                                                                               
    if (head) fclose(head);                                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void do_add(const char *filename) {                                            
                                                                               
    struct stat st;                                                            
                                                                               
    if (stat(filename, &st) != 0) {                                            
                                                                               
        printf("File not found\n");                                            
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    size_t content_size;                                                       
                                                                               
    char *content = read_file_content(filename, &content_size);                
                                                                               
    if (!content) {                                                            
                                                                               
        perror("read_file_content");                                           
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    char *hash = minihash(content, content_size);                              
                                                                               
    char obj_path[256];                                                        
                                                                               
    snprintf(obj_path, sizeof(obj_path), ".minigit/objects/%s", hash);         
                                                                               
    write_file_content(obj_path, content, content_size);                       
                                                                               
    free(content);                                                             
                                                                               
    free(hash);                                                                
                                                                               
                                                                               
                                                                               
    size_t index_size;                                                         
                                                                               
    char *index_content_ro = read_file_content(".minigit/index", &index_size); 
                                                                               
    int found = 0;                                                             
                                                                               
    if (index_content_ro && index_size > 0) {                                  
                                                                               
        char *index_content = strdup(index_content_ro);                        
                                                                               
        char *line = strtok(index_content, "\n");                              
                                                                               
        while (line) {                                                         
                                                                               
            if (strcmp(line, filename) == 0) {                                 
                                                                               
                found = 1;                                                     
                                                                               
                break;                                                         
                                                                               
            }                                                                  
                                                                               
            line = strtok(NULL, "\n");                                         
                                                                               
        }                                                                      
                                                                               
        free(index_content);                                                   
                                                                               
        free(index_content_ro);                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if (!found) {                                                              
                                                                               
        FILE *index_file = fopen(".minigit/index", "a");                       
                                                                               
        if (!index_file) {                                                     
                                                                               
            perror("fopen .minigit/index");                                    
                                                                               
            exit(1);                                                           
                                                                               
        }                                                                      
                                                                               
        fprintf(index_file, "%s\n", filename);                                 
                                                                               
        fclose(index_file);                                                    
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
int compare_strings(const void *a, const void *b) {                            
                                                                               
    return strcmp(*(const char **)a, *(const char **)b);                       
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void do_commit(const char *message) {                                          
                                                                               
    struct stat st;                                                            
                                                                               
    if (stat(".minigit/index", &st) != 0 || st.st_size == 0) {                 
                                                                               
        printf("Nothing to commit\n");                                         
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    char *parent_to_use;                                                       
                                                                               
    size_t head_size;                                                          
                                                                               
    char *head_content = read_file_content(".minigit/HEAD", &head_size);       
                                                                               
    if (head_content == NULL || head_size == 0) {                              
                                                                               
        parent_to_use = strdup("NONE");                                        
                                                                               
    } else {                                                                   
                                                                               
        head_content[strcspn(head_content, "\r\n")] = 0;                       
                                                                               
        parent_to_use = strdup(head_content);                                  
                                                                               
    }                                                                          
                                                                               
    free(head_content);                                                        
                                                                               
                                                                               
                                                                               
    FILE *index_file = fopen(".minigit/index", "r");                           
                                                                               
    char **filenames = NULL;                                                   
                                                                               
    size_t num_files = 0;                                                      
                                                                               
    char line[256];                                                            
                                                                               
    while (fgets(line, sizeof(line), index_file)) {                            
                                                                               
        line[strcspn(line, "\n")] = 0;                                         
                                                                               
        if (strlen(line) == 0) continue;                                       
                                                                               
        num_files++;                                                           
                                                                               
        filenames = realloc(filenames, num_files * sizeof(char *));            
                                                                               
        filenames[num_files - 1] = strdup(line);                               
                                                                               
    }                                                                          
                                                                               
    fclose(index_file);                                                        
                                                                               
                                                                               
                                                                               
    qsort(filenames, num_files, sizeof(char *), compare_strings);              
                                                                               
                                                                               
                                                                               
    size_t capacity = 4096;                                                    
                                                                               
    char *commit_content = malloc(capacity);                                   
                                                                               
    size_t length = 0;                                                         
                                                                               
                                                                               
                                                                               
    length += snprintf(commit_content + length, capacity - length, "parent:    
%s\n", parent_to_use);                                                         
                                                                               
    length += snprintf(commit_content + length, capacity - length, "timestamp: 
%ld\n", time(NULL));                                                           
                                                                               
    length += snprintf(commit_content + length, capacity - length, "message:   
%s\n", message);                                                               
                                                                               
    length += snprintf(commit_content + length, capacity - length, "files:\n");
                                                                               
                                                                               
                                                                               
    for (size_t i = 0; i < num_files; ++i) {                                   
                                                                               
        size_t file_content_size;                                              
                                                                               
        char *file_content = read_file_content(filenames[i],                   
&file_content_size);                                                           
                                                                               
        if(!file_content) { perror(filenames[i]); exit(1); }                   
                                                                               
        char *blob_hash = minihash(file_content, file_content_size);           
                                                                               
                                                                               
                                                                               
        size_t line_len = strlen(filenames[i]) + 1 + strlen(blob_hash) + 2;    
                                                                               
        if (length + line_len >= capacity) {                                   
                                                                               
             capacity *= 2;                                                    
                                                                               
             commit_content = realloc(commit_content, capacity);               
                                                                               
        }                                                                      
                                                                               
        length += snprintf(commit_content + length, capacity - length, "%s     
%s\n", filenames[i], blob_hash);                                               
                                                                               
                                                                               
                                                                               
        free(file_content);                                                    
                                                                               
        free(blob_hash);                                                       
                                                                               
        free(filenames[i]);                                                    
                                                                               
    }                                                                          
                                                                               
    free(filenames);                                                           
                                                                               
                                                                               
                                                                               
    char* commit_hash = minihash(commit_content, length);                      
                                                                               
                                                                               
                                                                               
    char commit_path[256];                                                     
                                                                               
    snprintf(commit_path, sizeof(commit_path), ".minigit/commits/%s",          
commit_hash);                                                                  
                                                                               
    write_file_content(commit_path, commit_content, length);                   
                                                                               
                                                                               
                                                                               
    write_file_content(".minigit/HEAD", commit_hash, strlen(commit_hash));     
                                                                               
                                                                               
                                                                               
    fclose(fopen(".minigit/index", "w"));                                      
                                                                               
                                                                               
                                                                               
    printf("Committed %s\n", commit_hash);                                     
                                                                               
                                                                               
                                                                               
    free(parent_to_use);                                                       
                                                                               
    free(commit_content);                                                      
                                                                               
    free(commit_hash);                                                         
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void do_log() {                                                                
                                                                               
    size_t head_size;                                                          
                                                                               
    char *current_hash = read_file_content(".minigit/HEAD", &head_size);       
                                                                               
    if (!current_hash || head_size == 0) {                                     
                                                                               
        printf("No commits\n");                                                
                                                                               
        free(current_hash);                                                    
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    current_hash[strcspn(current_hash, "\r\n")] = 0;                           
                                                                               
                                                                               
                                                                               
    while (strcmp(current_hash, "NONE") != 0 && strlen(current_hash) > 0) {    
                                                                               
        char commit_path[256];                                                 
                                                                               
        snprintf(commit_path, sizeof(commit_path), ".minigit/commits/%s",      
current_hash);                                                                 
                                                                               
                                                                               
                                                                               
        size_t commit_content_size;                                            
                                                                               
        char* commit_content_ro = read_file_content(commit_path,               
&commit_content_size);                                                         
                                                                               
        if (!commit_content_ro) break;                                         
                                                                               
                                                                               
                                                                               
        char* commit_content = strdup(commit_content_ro);                      
                                                                               
        free(commit_content_ro);                                               
                                                                               
                                                                               
                                                                               
        char *parent = NULL;                                                   
                                                                               
        char *timestamp = NULL;                                                
                                                                               
        char *message = NULL;                                                  
                                                                               
                                                                               
                                                                               
        char *saveptr;                                                         
                                                                               
        char *line = strtok_r(commit_content, "\n", &saveptr);                 
                                                                               
        while (line) {                                                         
                                                                               
            if (strncmp(line, "parent: ", 8) == 0) {                           
                                                                               
                parent = strdup(line + 8);                                     
                                                                               
            } else if (strncmp(line, "timestamp: ", 11) == 0) {                
                                                                               
                timestamp = strdup(line + 11);                                 
                                                                               
            } else if (strncmp(line, "message: ", 9) == 0) {                   
                                                                               
                message = strdup(line + 9);                                    
                                                                               
            }                                                                  
                                                                               
            line = strtok_r(NULL, "\n", &saveptr);                             
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        printf("commit %s\n", current_hash);                                   
                                                                               
        if (timestamp) printf("Date: %s\n", timestamp);                        
                                                                               
        if (message) printf("Message: %s\n", message);                         
                                                                               
        printf("\n");                                                          
                                                                               
                                                                               
                                                                               
        free(commit_content);                                                  
                                                                               
        free(timestamp);                                                       
                                                                               
        free(message);                                                         
                                                                               
                                                                               
                                                                               
        free(current_hash);                                                    
                                                                               
        current_hash = parent;                                                 
                                                                               
        if (!current_hash) break;                                              
                                                                               
    }                                                                          
                                                                               
    free(current_hash);                                                        
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
int main(int argc, char *argv[]) {                                             
                                                                               
    if (argc < 2) {                                                            
                                                                               
        return 1;                                                              
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if (strcmp(argv[1], "init") == 0) {                                        
                                                                               
        if (argc != 2) return 1;                                               
                                                                               
        do_init();                                                             
                                                                               
    } else if (strcmp(argv[1], "add") == 0) {                                  
                                                                               
        if (argc != 3) return 1;                                               
                                                                               
        do_add(argv[2]);                                                       
                                                                               
    } else if (strcmp(argv[1], "commit") == 0) {                               
                                                                               
        if (argc != 4 || strcmp(argv[2], "-m") != 0) return 1;                 
                                                                               
        do_commit(argv[3]);                                                    
                                                                               
    } else if (strcmp(argv[1], "log") == 0) {                                  
                                                                               
        if (argc != 2) return 1;                                               
                                                                               
        do_log();                                                              
                                                                               
    } else {                                                                   
                                                                               
        return 1;                                                              
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    return 0;                                                                  
                                                                               
}                                                                              
                                                                               

