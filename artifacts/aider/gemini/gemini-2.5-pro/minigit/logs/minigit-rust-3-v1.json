build.sh                                                                       

                                                                               
#!/usr/bin/env bash                                                            
                                                                               
set -e                                                                         
                                                                               
cargo build --release                                                          
                                                                               
cp target/release/minigit .                                                    
                                                                               

Cargo.toml                                                                     

                                                                               
[package]                                                                      
                                                                               
name = "minigit"                                                               
                                                                               
version = "0.1.0"                                                              
                                                                               
edition = "2021"                                                               
                                                                               
                                                                               
                                                                               
# See more keys and their definitions at                                       
https://doc.rust-lang.org/cargo/reference/manifest.html                        
                                                                               
                                                                               
                                                                               
[dependencies]                                                                 
                                                                               

src/main.rs                                                                    

                                                                               
use std::env;                                                                  
                                                                               
use std::fs;                                                                   
                                                                               
use std::io::{self, Write};                                                    
                                                                               
use std::path::Path;                                                           
                                                                               
use std::time::{SystemTime, UNIX_EPOCH};                                       
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR: &str = ".minigit";                                          
                                                                               
const OBJECTS_DIR: &str = ".minigit/objects";                                  
                                                                               
const COMMITS_DIR: &str = ".minigit/commits";                                  
                                                                               
const INDEX_FILE: &str = ".minigit/index";                                     
                                                                               
const HEAD_FILE: &str = ".minigit/HEAD";                                       
                                                                               
                                                                               
                                                                               
fn minihash(data: &[u8]) -> String {                                           
                                                                               
    let mut h: u64 = 1469598103934665603;                                      
                                                                               
    let prime: u64 = 1099511628211;                                            
                                                                               
                                                                               
                                                                               
    for &byte in data {                                                        
                                                                               
        h ^= byte as u64;                                                      
                                                                               
        h = h.wrapping_mul(prime);                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    format!("{:016x}", h)                                                      
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_init() -> io::Result<()> {                                           
                                                                               
    if Path::new(MINIGIT_DIR).exists() {                                       
                                                                               
        println!("Repository already initialized");                            
                                                                               
        return Ok(());                                                         
                                                                               
    }                                                                          
                                                                               
    fs::create_dir(MINIGIT_DIR)?;                                              
                                                                               
    fs::create_dir(OBJECTS_DIR)?;                                              
                                                                               
    fs::create_dir(COMMITS_DIR)?;                                              
                                                                               
    fs::File::create(INDEX_FILE)?;                                             
                                                                               
    fs::File::create(HEAD_FILE)?;                                              
                                                                               
    Ok(())                                                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_add(file_path_str: &str) -> io::Result<()> {                         
                                                                               
    let file_path = Path::new(file_path_str);                                  
                                                                               
    if !file_path.exists() {                                                   
                                                                               
        eprintln!("File not found");                                           
                                                                               
        std::process::exit(1);                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let content = fs::read(file_path)?;                                        
                                                                               
    let hash = minihash(&content);                                             
                                                                               
                                                                               
                                                                               
    let object_path = Path::new(OBJECTS_DIR).join(&hash);                      
                                                                               
    fs::write(object_path, content)?;                                          
                                                                               
                                                                               
                                                                               
    let index_content = fs::read_to_string(INDEX_FILE)?;                       
                                                                               
    let file_name = file_path.to_str().unwrap();                               
                                                                               
                                                                               
                                                                               
    if !index_content.lines().any(|line| line == file_name) {                  
                                                                               
        let mut file = fs::OpenOptions::new().append(true).open(INDEX_FILE)?;  
                                                                               
        writeln!(file, "{}", file_name)?;                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    Ok(())                                                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_commit(message: &str) -> io::Result<()> {                            
                                                                               
    let index_content = fs::read_to_string(INDEX_FILE)?;                       
                                                                               
    if index_content.trim().is_empty() {                                       
                                                                               
        println!("Nothing to commit");                                         
                                                                               
        std::process::exit(1);                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let parent_hash = fs::read_to_string(HEAD_FILE)?.trim().to_string();       
                                                                               
    let parent_str = if parent_hash.is_empty() { "NONE" } else { &parent_hash  
};                                                                             
                                                                               
                                                                               
                                                                               
    let timestamp = SystemTime::now()                                          
                                                                               
        .duration_since(UNIX_EPOCH)                                            
                                                                               
        .expect("Time went backwards")                                         
                                                                               
        .as_secs();                                                            
                                                                               
                                                                               
                                                                               
    let mut files_to_commit: Vec<(String, String)> = Vec::new();               
                                                                               
    for filename in index_content.lines() {                                    
                                                                               
        let content = fs::read(filename)?;                                     
                                                                               
        let blob_hash = minihash(&content);                                    
                                                                               
        files_to_commit.push((filename.to_string(), blob_hash));               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    files_to_commit.sort_by(|a, b| a.0.cmp(&b.0));                             
                                                                               
                                                                               
                                                                               
    let mut commit_content_builder = String::new();                            
                                                                               
    commit_content_builder.push_str(&format!("parent: {}\n", parent_str));     
                                                                               
    commit_content_builder.push_str(&format!("timestamp: {}\n", timestamp));   
                                                                               
    commit_content_builder.push_str(&format!("message: {}\n", message));       
                                                                               
    commit_content_builder.push_str("files:\n");                               
                                                                               
    for (filename, blob_hash) in files_to_commit {                             
                                                                               
        commit_content_builder.push_str(&format!("{} {}\n", filename,          
blob_hash));                                                                   
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let commit_content = commit_content_builder;                               
                                                                               
    let commit_hash = minihash(commit_content.as_bytes());                     
                                                                               
                                                                               
                                                                               
    let commit_path = Path::new(COMMITS_DIR).join(&commit_hash);               
                                                                               
    fs::write(commit_path, commit_content)?;                                   
                                                                               
                                                                               
                                                                               
    fs::write(HEAD_FILE, &commit_hash)?;                                       
                                                                               
    fs::write(INDEX_FILE, "")?;                                                
                                                                               
                                                                               
                                                                               
    println!("Committed {}", commit_hash);                                     
                                                                               
                                                                               
                                                                               
    Ok(())                                                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_log() -> io::Result<()> {                                            
                                                                               
    let mut current_hash = fs::read_to_string(HEAD_FILE)?.trim().to_string();  
                                                                               
                                                                               
                                                                               
    if current_hash.is_empty() {                                               
                                                                               
        println!("No commits");                                                
                                                                               
        return Ok(());                                                         
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while !current_hash.is_empty() && current_hash != "NONE" {                 
                                                                               
        let commit_path = Path::new(COMMITS_DIR).join(&current_hash);          
                                                                               
        if !commit_path.exists() {                                             
                                                                               
            break;                                                             
                                                                               
        }                                                                      
                                                                               
        let commit_content = fs::read_to_string(commit_path)?;                 
                                                                               
                                                                               
                                                                               
        let mut parent_hash_from_commit = String::new();                       
                                                                               
        let mut timestamp = String::new();                                     
                                                                               
        let mut message = String::new();                                       
                                                                               
                                                                               
                                                                               
        for line in commit_content.lines() {                                   
                                                                               
            if let Some(p) = line.strip_prefix("parent: ") {                   
                                                                               
                parent_hash_from_commit = p.to_string();                       
                                                                               
            } else if let Some(t) = line.strip_prefix("timestamp: ") {         
                                                                               
                timestamp = t.to_string();                                     
                                                                               
            } else if let Some(m) = line.strip_prefix("message: ") {           
                                                                               
                message = m.to_string();                                       
                                                                               
            }                                                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        println!("commit {}", current_hash);                                   
                                                                               
        println!("Date: {}", timestamp);                                       
                                                                               
        println!("Message: {}", message);                                      
                                                                               
                                                                               
                                                                               
        current_hash = parent_hash_from_commit;                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    Ok(())                                                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn main() {                                                                    
                                                                               
    let args: Vec<String> = env::args().collect();                             
                                                                               
    if args.len() < 2 {                                                        
                                                                               
        eprintln!("Usage: minigit <command> [<args>]");                        
                                                                               
        std::process::exit(1);                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let command = &args[1];                                                    
                                                                               
    let result = match command.as_str() {                                      
                                                                               
        "init" => handle_init(),                                               
                                                                               
        "add" => {                                                             
                                                                               
            if args.len() != 3 {                                               
                                                                               
                eprintln!("Usage: minigit add <file>");                        
                                                                               
                std::process::exit(1);                                         
                                                                               
            }                                                                  
                                                                               
            handle_add(&args[2])                                               
                                                                               
        },                                                                     
                                                                               
        "commit" => {                                                          
                                                                               
            if args.len() != 4 || args[2] != "-m" {                            
                                                                               
                eprintln!("Usage: minigit commit -m \"<message>\"");           
                                                                               
                std::process::exit(1);                                         
                                                                               
            }                                                                  
                                                                               
            handle_commit(&args[3])                                            
                                                                               
        },                                                                     
                                                                               
        "log" => handle_log(),                                                 
                                                                               
        _ => {                                                                 
                                                                               
            eprintln!("Unknown command: {}", command);                         
                                                                               
            std::process::exit(1);                                             
                                                                               
        }                                                                      
                                                                               
    };                                                                         
                                                                               
                                                                               
                                                                               
    if let Err(e) = result {                                                   
                                                                               
        eprintln!("Error running command: {}", e);                             
                                                                               
        std::process::exit(1);                                                 
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               

