#!/usr/bin/env python3                                                         
                                                                               
                                                                               
                                                                               
import sys                                                                     
                                                                               
import os                                                                      
                                                                               
import time                                                                    
                                                                               
                                                                               
                                                                               
MINIGIT_DIR = ".minigit"                                                       
                                                                               
OBJECTS_DIR = os.path.join(MINIGIT_DIR, "objects")                             
                                                                               
COMMITS_DIR = os.path.join(MINIGIT_DIR, "commits")                             
                                                                               
INDEX_FILE = os.path.join(MINIGIT_DIR, "index")                                
                                                                               
HEAD_FILE = os.path.join(MINIGIT_DIR, "HEAD")                                  
                                                                               
                                                                               
                                                                               
def mini_hash(data: bytes) -> str:                                             
                                                                               
    h = 1469598103934665603                                                    
                                                                               
    for byte in data:                                                          
                                                                               
        h ^= byte                                                              
                                                                               
        h = (h * 1099511628211) & 0xFFFFFFFFFFFFFFFF                           
                                                                               
    return f"{h:016x}"                                                         
                                                                               
                                                                               
                                                                               
def init_command():                                                            
                                                                               
    if os.path.exists(MINIGIT_DIR):                                            
                                                                               
        print("Repository already initialized")                                
                                                                               
        return                                                                 
                                                                               
                                                                               
                                                                               
    os.makedirs(OBJECTS_DIR)                                                   
                                                                               
    os.makedirs(COMMITS_DIR)                                                   
                                                                               
    with open(INDEX_FILE, "w") as f:                                           
                                                                               
        pass                                                                   
                                                                               
    with open(HEAD_FILE, "w") as f:                                            
                                                                               
        pass                                                                   
                                                                               
                                                                               
                                                                               
def add_command(filename):                                                     
                                                                               
    if not os.path.exists(filename):                                           
                                                                               
        print("File not found")                                                
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
    with open(filename, "rb") as f:                                            
                                                                               
        content = f.read()                                                     
                                                                               
                                                                               
                                                                               
    file_hash = mini_hash(content)                                             
                                                                               
                                                                               
                                                                               
    object_path = os.path.join(OBJECTS_DIR, file_hash)                         
                                                                               
    with open(object_path, "wb") as f:                                         
                                                                               
        f.write(content)                                                       
                                                                               
                                                                               
                                                                               
    staged_files = []                                                          
                                                                               
    if os.path.exists(INDEX_FILE):                                             
                                                                               
        with open(INDEX_FILE, "r") as f:                                       
                                                                               
            staged_files = [line.strip() for line in f.readlines()]            
                                                                               
                                                                               
                                                                               
    if filename not in staged_files:                                           
                                                                               
        with open(INDEX_FILE, "a") as f:                                       
                                                                               
            f.write(f"{filename}\n")                                           
                                                                               
                                                                               
                                                                               
def commit_command(message):                                                   
                                                                               
    if not os.path.exists(INDEX_FILE) or os.path.getsize(INDEX_FILE) == 0:     
                                                                               
        print("Nothing to commit")                                             
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
    with open(INDEX_FILE, "r") as f:                                           
                                                                               
        staged_files = [line.strip() for line in f.readlines() if line.strip()]
                                                                               
                                                                               
                                                                               
    if not staged_files:                                                       
                                                                               
        print("Nothing to commit")                                             
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
    staged_files.sort()                                                        
                                                                               
                                                                               
                                                                               
    parent_hash = "NONE"                                                       
                                                                               
    if os.path.exists(HEAD_FILE) and os.path.getsize(HEAD_FILE) > 0:           
                                                                               
        with open(HEAD_FILE, "r") as f:                                        
                                                                               
            parent_hash = f.read().strip()                                     
                                                                               
                                                                               
                                                                               
    timestamp = int(time.time())                                               
                                                                               
                                                                               
                                                                               
    commit_content_lines = []                                                  
                                                                               
    commit_content_lines.append(f"parent: {parent_hash}")                      
                                                                               
    commit_content_lines.append(f"timestamp: {timestamp}")                     
                                                                               
    commit_content_lines.append(f"message: {message}")                         
                                                                               
    commit_content_lines.append("files:")                                      
                                                                               
                                                                               
                                                                               
    for filename in staged_files:                                              
                                                                               
        with open(filename, "rb") as f:                                        
                                                                               
            content = f.read()                                                 
                                                                               
        blob_hash = mini_hash(content)                                         
                                                                               
        commit_content_lines.append(f"{filename} {blob_hash}")                 
                                                                               
                                                                               
                                                                               
    commit_content = "\n".join(commit_content_lines) + "\n"                    
                                                                               
                                                                               
                                                                               
    commit_hash = mini_hash(commit_content.encode('utf-8'))                    
                                                                               
                                                                               
                                                                               
    commit_path = os.path.join(COMMITS_DIR, commit_hash)                       
                                                                               
    with open(commit_path, "w") as f:                                          
                                                                               
        f.write(commit_content)                                                
                                                                               
                                                                               
                                                                               
    with open(HEAD_FILE, "w") as f:                                            
                                                                               
        f.write(commit_hash)                                                   
                                                                               
                                                                               
                                                                               
    with open(INDEX_FILE, "w") as f:                                           
                                                                               
        pass                                                                   
                                                                               
                                                                               
                                                                               
    print(f"Committed {commit_hash}")                                          
                                                                               
                                                                               
                                                                               
def log_command():                                                             
                                                                               
    if not os.path.exists(HEAD_FILE) or os.path.getsize(HEAD_FILE) == 0:       
                                                                               
        print("No commits")                                                    
                                                                               
        return                                                                 
                                                                               
                                                                               
                                                                               
    with open(HEAD_FILE, "r") as f:                                            
                                                                               
        current_hash = f.read().strip()                                        
                                                                               
                                                                               
                                                                               
    output_parts = []                                                          
                                                                               
    while current_hash and current_hash != "NONE":                             
                                                                               
        commit_path = os.path.join(COMMITS_DIR, current_hash)                  
                                                                               
        if not os.path.exists(commit_path):                                    
                                                                               
            break                                                              
                                                                               
                                                                               
                                                                               
        with open(commit_path, "r") as f:                                      
                                                                               
            lines = f.readlines()                                              
                                                                               
                                                                               
                                                                               
        parent_hash = "NONE"                                                   
                                                                               
        timestamp = ""                                                         
                                                                               
        message = ""                                                           
                                                                               
                                                                               
                                                                               
        for line in lines:                                                     
                                                                               
            if line.startswith("parent: "):                                    
                                                                               
                parent_hash = line.strip().split(": ", 1)[1]                   
                                                                               
            elif line.startswith("timestamp: "):                               
                                                                               
                timestamp = line.strip().split(": ", 1)[1]                     
                                                                               
            elif line.startswith("message: "):                                 
                                                                               
                message = line.strip().split(": ", 1)[1]                       
                                                                               
                                                                               
                                                                               
        commit_output = [                                                      
                                                                               
            f"commit {current_hash}",                                          
                                                                               
            f"Date: {timestamp}",                                              
                                                                               
            f"Message: {message}"                                              
                                                                               
        ]                                                                      
                                                                               
        output_parts.append("\n".join(commit_output))                          
                                                                               
                                                                               
                                                                               
        current_hash = parent_hash                                             
                                                                               
                                                                               
                                                                               
    print("\n".join(output_parts))                                             
                                                                               
                                                                               
                                                                               
def main():                                                                    
                                                                               
    if len(sys.argv) < 2:                                                      
                                                                               
        print("Usage: minigit <command> [<args>]", file=sys.stderr)            
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
    command = sys.argv[1]                                                      
                                                                               
                                                                               
                                                                               
    if command == "init":                                                      
                                                                               
        init_command()                                                         
                                                                               
    elif command == "add":                                                     
                                                                               
        if len(sys.argv) < 3:                                                  
                                                                               
            print("Usage: minigit add <file>", file=sys.stderr)                
                                                                               
            sys.exit(1)                                                        
                                                                               
        add_command(sys.argv[2])                                               
                                                                               
    elif command == "commit":                                                  
                                                                               
        if len(sys.argv) < 4 or sys.argv[2] != "-m":                           
                                                                               
            print("Usage: minigit commit -m \"<message>\"", file=sys.stderr)   
                                                                               
            sys.exit(1)                                                        
                                                                               
        commit_command(sys.argv[3])                                            
                                                                               
    elif command == "log":                                                     
                                                                               
        log_command()                                                          
                                                                               
    else:                                                                      
                                                                               
        print(f"Unknown command: {command}", file=sys.stderr)                  
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
if __name__ == "__main__":                                                     
                                                                               
    main()                                                                     
                                                                               

