minigit                                                                        

                                                                               
#!/usr/bin/env node                                                            
                                                                               
require('./minigit.js');                                                       
                                                                               

minigit.ts                                                                     

                                                                               
import * as fs from 'fs';                                                      
                                                                               
import * as path from 'path';                                                  
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR = '.minigit';                                                
                                                                               
const OBJECTS_DIR = path.join(MINIGIT_DIR, 'objects');                         
                                                                               
const COMMITS_DIR = path.join(MINIGIT_DIR, 'commits');                         
                                                                               
const INDEX_FILE = path.join(MINIGIT_DIR, 'index');                            
                                                                               
const HEAD_FILE = path.join(MINIGIT_DIR, 'HEAD');                              
                                                                               
                                                                               
                                                                               
function miniHash(data: Buffer): string {                                      
                                                                               
    let h: bigint = 1469598103934665603n;                                      
                                                                               
    const prime: bigint = 1099511628211n;                                      
                                                                               
    const mod: bigint = 2n ** 64n;                                             
                                                                               
                                                                               
                                                                               
    for (const byte of data) {                                                 
                                                                               
        h = h ^ BigInt(byte);                                                  
                                                                               
        h = (h * prime) % mod;                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    return h.toString(16).padStart(16, '0');                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function init() {                                                              
                                                                               
    if (fs.existsSync(MINIGIT_DIR)) {                                          
                                                                               
        console.log("Repository already initialized");                         
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    fs.mkdirSync(MINIGIT_DIR);                                                 
                                                                               
    fs.mkdirSync(OBJECTS_DIR);                                                 
                                                                               
    fs.mkdirSync(COMMITS_DIR);                                                 
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
    fs.writeFileSync(HEAD_FILE, '');                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function add(file: string) {                                                   
                                                                               
    if (!fs.existsSync(file)) {                                                
                                                                               
        console.log("File not found");                                         
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
    const content = fs.readFileSync(file);                                     
                                                                               
    const hash = miniHash(content);                                            
                                                                               
    const objectPath = path.join(OBJECTS_DIR, hash);                           
                                                                               
    fs.writeFileSync(objectPath, content);                                     
                                                                               
                                                                               
                                                                               
    let indexContent = fs.existsSync(INDEX_FILE) ? fs.readFileSync(INDEX_FILE, 
'utf-8') : '';                                                                 
                                                                               
    const indexFiles = indexContent.split('\n').filter(f => f.length > 0);     
                                                                               
    if (!indexFiles.includes(file)) {                                          
                                                                               
        indexFiles.push(file);                                                 
                                                                               
        fs.writeFileSync(INDEX_FILE, indexFiles.join('\n') + '\n');            
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function commit(message: string) {                                             
                                                                               
    const indexContent = fs.readFileSync(INDEX_FILE, 'utf-8');                 
                                                                               
    const stagedFiles = indexContent.split('\n').filter(f => f.length > 0);    
                                                                               
                                                                               
                                                                               
    if (stagedFiles.length === 0) {                                            
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let parent = fs.readFileSync(HEAD_FILE, 'utf-8').trim();                   
                                                                               
    if (parent.length === 0) {                                                 
                                                                               
        parent = 'NONE';                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const timestamp = Math.floor(Date.now() / 1000);                           
                                                                               
                                                                               
                                                                               
    stagedFiles.sort();                                                        
                                                                               
                                                                               
                                                                               
    const fileEntries = stagedFiles.map(file => {                              
                                                                               
        const content = fs.readFileSync(file);                                 
                                                                               
        const hash = miniHash(content);                                        
                                                                               
        return `${file} ${hash}`;                                              
                                                                               
    });                                                                        
                                                                               
                                                                               
                                                                               
    const commitContent = `parent: ${parent}\ntimestamp: ${timestamp}\nmessage:
${message}\nfiles:\n${fileEntries.join('\n')}`;                                
                                                                               
                                                                               
                                                                               
    const commitHash = miniHash(Buffer.from(commitContent, 'utf-8'));          
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(path.join(COMMITS_DIR, commitHash), commitContent);       
                                                                               
    fs.writeFileSync(HEAD_FILE, commitHash);                                   
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
                                                                               
                                                                               
    console.log(`Committed ${commitHash}`);                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function log() {                                                               
                                                                               
    let currentHash = fs.readFileSync(HEAD_FILE, 'utf-8').trim();              
                                                                               
                                                                               
                                                                               
    if (currentHash.length === 0) {                                            
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while (currentHash !== 'NONE') {                                           
                                                                               
        const commitPath = path.join(COMMITS_DIR, currentHash);                
                                                                               
        if (!fs.existsSync(commitPath)) {                                      
                                                                               
            break;                                                             
                                                                               
        }                                                                      
                                                                               
        const commitContent = fs.readFileSync(commitPath, 'utf-8');            
                                                                               
        const lines = commitContent.split('\n');                               
                                                                               
                                                                               
                                                                               
        const parentLine = lines.find(l => l.startsWith('parent:'));           
                                                                               
        const timestampLine = lines.find(l => l.startsWith('timestamp:'));     
                                                                               
        const messageLine = lines.find(l => l.startsWith('message:'));         
                                                                               
                                                                               
                                                                               
        const timestamp = timestampLine ? timestampLine.split(': ')[1] : '';   
                                                                               
        const message = messageLine ? messageLine.split(': ')[1] : '';         
                                                                               
                                                                               
                                                                               
        console.log(`commit ${currentHash}`);                                  
                                                                               
        console.log(`Date: ${timestamp}`);                                     
                                                                               
        console.log(`Message: ${message}`);                                    
                                                                               
                                                                               
                                                                               
        const parent = parentLine ? parentLine.split(': ')[1] : 'NONE';        
                                                                               
        currentHash = parent;                                                  
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function main() {                                                              
                                                                               
    const args = process.argv.slice(2);                                        
                                                                               
    const command = args[0];                                                   
                                                                               
                                                                               
                                                                               
    switch (command) {                                                         
                                                                               
        case 'init':                                                           
                                                                               
            init();                                                            
                                                                               
            break;                                                             
                                                                               
        case 'add':                                                            
                                                                               
            if (args.length < 2) {                                             
                                                                               
                console.log("File not specified");                             
                                                                               
                process.exit(1);                                               
                                                                               
            }                                                                  
                                                                               
            add(args[1]);                                                      
                                                                               
            break;                                                             
                                                                               
        case 'commit':                                                         
                                                                               
            if (args.length < 3 || args[1] !== '-m') {                         
                                                                               
                 console.log("Invalid commit command format. Use: minigit      
commit -m \"<message>\"");                                                     
                                                                               
                 process.exit(1);                                              
                                                                               
            }                                                                  
                                                                               
            const message = args[2];                                           
                                                                               
            commit(message);                                                   
                                                                               
            break;                                                             
                                                                               
        case 'log':                                                            
                                                                               
            log();                                                             
                                                                               
            break;                                                             
                                                                               
        default:                                                               
                                                                               
            console.log(`Unknown command: ${command}`);                        
                                                                               
            process.exit(1);                                                   
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
main();                                                                        
                                                                               

