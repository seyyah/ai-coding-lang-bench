package main                                                                   
                                                                               
                                                                               
                                                                               
import (                                                                       
                                                                               
    "fmt"                                                                      
                                                                               
    "log"                                                                      
                                                                               
    "os"                                                                       
                                                                               
    "path/filepath"                                                            
                                                                               
    "sort"                                                                     
                                                                               
    "strings"                                                                  
                                                                               
    "time"                                                                     
                                                                               
)                                                                              
                                                                               
                                                                               
                                                                               
const (                                                                        
                                                                               
    minigitDir = ".minigit"                                                    
                                                                               
    objectsDir = ".minigit/objects"                                            
                                                                               
    commitsDir = ".minigit/commits"                                            
                                                                               
    indexFile  = ".minigit/index"                                              
                                                                               
    headFile   = ".minigit/HEAD"                                               
                                                                               
)                                                                              
                                                                               
                                                                               
                                                                               
// miniHash implements the custom MiniHash algorithm.                          
                                                                               
func miniHash(data []byte) string {                                            
                                                                               
    var h uint64 = 1469598103934665603                                         
                                                                               
    for _, b := range data {                                                   
                                                                               
        h ^= uint64(b)                                                         
                                                                               
        h *= 1099511628211                                                     
                                                                               
    }                                                                          
                                                                               
    return fmt.Sprintf("%016x", h)                                             
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
func handleInit() {                                                            
                                                                               
    if _, err := os.Stat(minigitDir); !os.IsNotExist(err) {                    
                                                                               
        fmt.Println("Repository already initialized")                          
                                                                               
        return                                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    dirs := []string{minigitDir, objectsDir, commitsDir}                       
                                                                               
    for _, dir := range dirs {                                                 
                                                                               
        if err := os.MkdirAll(dir, 0755); err != nil {                         
                                                                               
            log.Fatalf("Failed to create directory %s: %v", dir, err)          
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    files := []string{indexFile, headFile}                                     
                                                                               
    for _, file := range files {                                               
                                                                               
        f, err := os.Create(file)                                              
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to create file %s: %v", file, err)              
                                                                               
        }                                                                      
                                                                               
        f.Close()                                                              
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
func handleAdd(filename string) {                                              
                                                                               
    if _, err := os.Stat(filename); os.IsNotExist(err) {                       
                                                                               
        fmt.Println("File not found")                                          
                                                                               
        os.Exit(1)                                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    content, err := os.ReadFile(filename)                                      
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read file %s: %v", filename, err)                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    hash := miniHash(content)                                                  
                                                                               
    objectPath := filepath.Join(objectsDir, hash)                              
                                                                               
    if err := os.WriteFile(objectPath, content, 0644); err != nil {            
                                                                               
        log.Fatalf("Failed to write object file: %v", err)                     
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    indexContent, err := os.ReadFile(indexFile)                                
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read index file: %v", err)                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    files := strings.Split(string(indexContent), "\n")                         
                                                                               
    found := false                                                             
                                                                               
    for _, f := range files {                                                  
                                                                               
        if f == filename {                                                     
                                                                               
            found = true                                                       
                                                                               
            break                                                              
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if !found {                                                                
                                                                               
        f, err := os.OpenFile(indexFile, os.O_APPEND|os.O_WRONLY, 0644)        
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to open index for writing: %v", err)            
                                                                               
        }                                                                      
                                                                               
        defer f.Close()                                                        
                                                                               
                                                                               
                                                                               
        trimmedContent := strings.TrimSpace(string(indexContent))              
                                                                               
        if trimmedContent != "" {                                              
                                                                               
            if _, err := fmt.Fprint(f, "\n"); err != nil {                     
                                                                               
                log.Fatalf("Failed to write to index: %v", err)                
                                                                               
            }                                                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        if _, err := fmt.Fprint(f, filename); err != nil {                     
                                                                               
            log.Fatalf("Failed to write to index: %v", err)                    
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
func handleCommit(message string) {                                            
                                                                               
    indexContent, err := os.ReadFile(indexFile)                                
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read index: %v", err)                            
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    trimmedIndex := strings.TrimSpace(string(indexContent))                    
                                                                               
    if trimmedIndex == "" {                                                    
                                                                               
        fmt.Println("Nothing to commit")                                       
                                                                               
        os.Exit(1)                                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    stagedFiles := strings.Split(trimmedIndex, "\n")                           
                                                                               
                                                                               
                                                                               
    parentHashBytes, err := os.ReadFile(headFile)                              
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read HEAD: %v", err)                             
                                                                               
    }                                                                          
                                                                               
    parentHash := strings.TrimSpace(string(parentHashBytes))                   
                                                                               
    if parentHash == "" {                                                      
                                                                               
        parentHash = "NONE"                                                    
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    timestamp := time.Now().Unix()                                             
                                                                               
                                                                               
                                                                               
    var commitContent strings.Builder                                          
                                                                               
    commitContent.WriteString(fmt.Sprintf("parent: %s\n", parentHash))         
                                                                               
    commitContent.WriteString(fmt.Sprintf("timestamp: %d\n", timestamp))       
                                                                               
    commitContent.WriteString(fmt.Sprintf("message: %s\n", message))           
                                                                               
    commitContent.WriteString("files:\n")                                      
                                                                               
                                                                               
                                                                               
    type fileInfo struct {                                                     
                                                                               
        name string                                                            
                                                                               
        hash string                                                            
                                                                               
    }                                                                          
                                                                               
    var filesWithHashes []fileInfo                                             
                                                                               
                                                                               
                                                                               
    for _, filename := range stagedFiles {                                     
                                                                               
        content, err := os.ReadFile(filename)                                  
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to read staged file %s: %v", filename, err)     
                                                                               
        }                                                                      
                                                                               
        blobHash := miniHash(content)                                          
                                                                               
        filesWithHashes = append(filesWithHashes, fileInfo{name: filename,     
hash: blobHash})                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    sort.Slice(filesWithHashes, func(i, j int) bool {                          
                                                                               
        return filesWithHashes[i].name < filesWithHashes[j].name               
                                                                               
    })                                                                         
                                                                               
                                                                               
                                                                               
    for i, fi := range filesWithHashes {                                       
                                                                               
        commitContent.WriteString(fmt.Sprintf("%s %s", fi.name, fi.hash))      
                                                                               
        if i < len(filesWithHashes)-1 {                                        
                                                                               
            commitContent.WriteString("\n")                                    
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    finalCommitContent := commitContent.String()                               
                                                                               
    commitHash := miniHash([]byte(finalCommitContent))                         
                                                                               
                                                                               
                                                                               
    commitPath := filepath.Join(commitsDir, commitHash)                        
                                                                               
    if err := os.WriteFile(commitPath, []byte(finalCommitContent), 0644); err  
!= nil {                                                                       
                                                                               
        log.Fatalf("Failed to write commit object: %v", err)                   
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if err := os.WriteFile(headFile, []byte(commitHash), 0644); err != nil {   
                                                                               
        log.Fatalf("Failed to update HEAD: %v", err)                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if err := os.Truncate(indexFile, 0); err != nil {                          
                                                                               
        log.Fatalf("Failed to clear index: %v", err)                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    fmt.Printf("Committed %s\n", commitHash)                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
func handleLog() {                                                             
                                                                               
    currentHashBytes, err := os.ReadFile(headFile)                             
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read HEAD: %v", err)                             
                                                                               
    }                                                                          
                                                                               
    currentHash := strings.TrimSpace(string(currentHashBytes))                 
                                                                               
                                                                               
                                                                               
    if currentHash == "" {                                                     
                                                                               
        fmt.Println("No commits")                                              
                                                                               
        return                                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    for currentHash != "NONE" && currentHash != "" {                           
                                                                               
        commitPath := filepath.Join(commitsDir, currentHash)                   
                                                                               
        commitContentBytes, err := os.ReadFile(commitPath)                     
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to read commit %s: %v", currentHash, err)       
                                                                               
        }                                                                      
                                                                               
        commitContent := string(commitContentBytes)                            
                                                                               
                                                                               
                                                                               
        lines := strings.Split(commitContent, "\n")                            
                                                                               
        var parent, timestamp, message string                                  
                                                                               
                                                                               
                                                                               
        for _, line := range lines {                                           
                                                                               
            if strings.HasPrefix(line, "parent: ") {                           
                                                                               
                parent = strings.TrimPrefix(line, "parent: ")                  
                                                                               
            } else if strings.HasPrefix(line, "timestamp: ") {                 
                                                                               
                timestamp = strings.TrimPrefix(line, "timestamp: ")            
                                                                               
            } else if strings.HasPrefix(line, "message: ") {                   
                                                                               
                message = strings.TrimPrefix(line, "message: ")                
                                                                               
            }                                                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        fmt.Printf("commit %s\n", currentHash)                                 
                                                                               
        fmt.Printf("Date: %s\n", timestamp)                                    
                                                                               
        fmt.Printf("Message: %s\n", message)                                   
                                                                               
                                                                               
                                                                               
        currentHash = parent                                                   
                                                                               
        if currentHash != "NONE" && currentHash != "" {                        
                                                                               
            fmt.Println()                                                      
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
func main() {                                                                  
                                                                               
    if len(os.Args) < 2 {                                                      
                                                                               
        log.Fatalf("Usage: minigit <command> [<args>]")                        
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    command := os.Args[1]                                                      
                                                                               
                                                                               
                                                                               
    switch command {                                                           
                                                                               
    case "init":                                                               
                                                                               
        handleInit()                                                           
                                                                               
    case "add":                                                                
                                                                               
        if len(os.Args) < 3 {                                                  
                                                                               
            log.Fatalf("Usage: minigit add <file>")                            
                                                                               
        }                                                                      
                                                                               
        handleAdd(os.Args[2])                                                  
                                                                               
    case "commit":                                                             
                                                                               
        if len(os.Args) < 4 || os.Args[2] != "-m" {                            
                                                                               
            log.Fatalf("Usage: minigit commit -m \"<message>\"")               
                                                                               
        }                                                                      
                                                                               
        handleCommit(os.Args[3])                                               
                                                                               
    case "log":                                                                
                                                                               
        handleLog()                                                            
                                                                               
    default:                                                                   
                                                                               
        log.Fatalf("Unknown command: %s", command)                             
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               

