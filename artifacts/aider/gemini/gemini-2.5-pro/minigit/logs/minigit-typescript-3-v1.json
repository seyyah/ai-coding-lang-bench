#!/usr/bin/env bash                                                            
                                                                               
# This script assumes 'tsc' (TypeScript Compiler) is available in the path or  
via npx.                                                                       
                                                                               
# It also assumes Node.js is installed.                                        
                                                                               
                                                                               
                                                                               
# Compile the TypeScript source file to JavaScript using a specific tsc version
                                                                               
# This avoids needing a tsconfig.json file                                     
                                                                               
npx -p typescript@5.3.3 tsc minigit.ts --target es2020 --module commonjs >     
/dev/null 2>&1                                                                 
                                                                               
                                                                               
                                                                               
# Create the executable 'minigit'                                              
                                                                               
# 1. Add a shebang line for node                                               
                                                                               
# 2. Append the compiled JavaScript code                                       
                                                                               
echo '#!/usr/bin/env node' > minigit                                           
                                                                               
cat minigit.js >> minigit                                                      
                                                                               
                                                                               
                                                                               
# Make the 'minigit' file executable                                           
                                                                               
chmod +x minigit                                                               
                                                                               

minigit.ts                                                                     

                                                                               
import * as fs from 'fs';                                                      
                                                                               
import * as path from 'path';                                                  
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR = '.minigit';                                                
                                                                               
const OBJECTS_DIR = path.join(MINIGIT_DIR, 'objects');                         
                                                                               
const COMMITS_DIR = path.join(MINIGIT_DIR, 'commits');                         
                                                                               
const INDEX_FILE = path.join(MINIGIT_DIR, 'index');                            
                                                                               
const HEAD_FILE = path.join(MINIGIT_DIR, 'HEAD');                              
                                                                               
                                                                               
                                                                               
function miniHash(data: Buffer): string {                                      
                                                                               
    let h = 1469598103934665603n;                                              
                                                                               
    const prime = 1099511628211n;                                              
                                                                               
    const mask = 0xFFFFFFFFFFFFFFFFn;                                          
                                                                               
                                                                               
                                                                               
    for (const byte of data) {                                                 
                                                                               
        h = h ^ BigInt(byte);                                                  
                                                                               
        h = (h * prime) & mask;                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    return h.toString(16).padStart(16, '0');                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function init() {                                                              
                                                                               
    if (fs.existsSync(MINIGIT_DIR)) {                                          
                                                                               
        console.log("Repository already initialized");                         
                                                                               
        process.exit(0);                                                       
                                                                               
    }                                                                          
                                                                               
    fs.mkdirSync(MINIGIT_DIR);                                                 
                                                                               
    fs.mkdirSync(OBJECTS_DIR);                                                 
                                                                               
    fs.mkdirSync(COMMITS_DIR);                                                 
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
    fs.writeFileSync(HEAD_FILE, '');                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function add(filePath: string) {                                               
                                                                               
    if (!fs.existsSync(filePath)) {                                            
                                                                               
        console.log("File not found");                                         
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const content = fs.readFileSync(filePath);                                 
                                                                               
    const hash = miniHash(content);                                            
                                                                               
                                                                               
                                                                               
    if (!fs.existsSync(OBJECTS_DIR)) {                                         
                                                                               
        fs.mkdirSync(OBJECTS_DIR, { recursive: true });                        
                                                                               
    }                                                                          
                                                                               
    fs.writeFileSync(path.join(OBJECTS_DIR, hash), content);                   
                                                                               
                                                                               
                                                                               
    let indexContent = fs.existsSync(INDEX_FILE) ? fs.readFileSync(INDEX_FILE, 
'utf-8') : '';                                                                 
                                                                               
    const indexFiles = indexContent.split('\n').filter(line => line.length >   
0);                                                                            
                                                                               
                                                                               
                                                                               
    if (!indexFiles.includes(filePath)) {                                      
                                                                               
        indexFiles.push(filePath);                                             
                                                                               
        fs.writeFileSync(INDEX_FILE, indexFiles.join('\n') + '\n');            
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function commit(message: string) {                                             
                                                                               
    if (!fs.existsSync(INDEX_FILE) || fs.readFileSync(INDEX_FILE,              
'utf-8').trim() === '') {                                                      
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const indexContent = fs.readFileSync(INDEX_FILE, 'utf-8');                 
                                                                               
    const stagedFiles = indexContent.split('\n').filter(line => line.length >  
0).sort();                                                                     
                                                                               
                                                                               
                                                                               
    const parent = fs.readFileSync(HEAD_FILE, 'utf-8').trim() || 'NONE';       
                                                                               
    const timestamp = Math.floor(Date.now() / 1000);                           
                                                                               
                                                                               
                                                                               
    let commitContent = `parent: ${parent}\n`;                                 
                                                                               
    commitContent += `timestamp: ${timestamp}\n`;                              
                                                                               
    commitContent += `message: ${message}\n`;                                  
                                                                               
    commitContent += `files:\n`;                                               
                                                                               
                                                                               
                                                                               
    const fileEntries: string[] = [];                                          
                                                                               
    for (const file of stagedFiles) {                                          
                                                                               
        const content = fs.readFileSync(file);                                 
                                                                               
        const hash = miniHash(content);                                        
                                                                               
        fileEntries.push(`${file} ${hash}`);                                   
                                                                               
    }                                                                          
                                                                               
    commitContent += fileEntries.join('\n');                                   
                                                                               
                                                                               
                                                                               
    const commitHash = miniHash(Buffer.from(commitContent, 'utf-8'));          
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(path.join(COMMITS_DIR, commitHash), commitContent);       
                                                                               
    fs.writeFileSync(HEAD_FILE, commitHash);                                   
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
                                                                               
                                                                               
    console.log(`Committed ${commitHash}`);                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function log() {                                                               
                                                                               
    if (!fs.existsSync(HEAD_FILE)) {                                           
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let currentCommitHash = fs.readFileSync(HEAD_FILE, 'utf-8').trim();        
                                                                               
                                                                               
                                                                               
    if (!currentCommitHash) {                                                  
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while (currentCommitHash && currentCommitHash !== 'NONE') {                
                                                                               
        const commitPath = path.join(COMMITS_DIR, currentCommitHash);          
                                                                               
        if (!fs.existsSync(commitPath)) {                                      
                                                                               
            break;                                                             
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        const commitContent = fs.readFileSync(commitPath, 'utf-8');            
                                                                               
        const lines = commitContent.split('\n');                               
                                                                               
                                                                               
                                                                               
        const parentLine = lines.find(l => l.startsWith('parent: '));          
                                                                               
        const timestampLine = lines.find(l => l.startsWith('timestamp: '));    
                                                                               
        const messageLine = lines.find(l => l.startsWith('message: '));        
                                                                               
                                                                               
                                                                               
        const timestamp = timestampLine ? timestampLine.substring('timestamp:  
'.length) : '';                                                                
                                                                               
        const message = messageLine ? messageLine.substring('message: '.length)
: '';                                                                          
                                                                               
                                                                               
                                                                               
        console.log(`commit ${currentCommitHash}`);                            
                                                                               
        console.log(`Date: ${timestamp}`);                                     
                                                                               
        console.log(`Message: ${message}`);                                    
                                                                               
                                                                               
                                                                               
        currentCommitHash = parentLine ? parentLine.substring('parent:         
'.length).trim() : 'NONE';                                                     
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
const args = process.argv.slice(2);                                            
                                                                               
const command = args[0];                                                       
                                                                               
                                                                               
                                                                               
switch (command) {                                                             
                                                                               
    case 'init':                                                               
                                                                               
        init();                                                                
                                                                               
        break;                                                                 
                                                                               
    case 'add':                                                                
                                                                               
        if (args.length < 2) {                                                 
                                                                               
            console.error("Usage: minigit add <file>");                        
                                                                               
            process.exit(1);                                                   
                                                                               
        }                                                                      
                                                                               
        add(args[1]);                                                          
                                                                               
        break;                                                                 
                                                                               
    case 'commit':                                                             
                                                                               
        if (args[1] !== '-m' || args.length < 3) {                             
                                                                               
            console.error('Usage: minigit commit -m "<message>"');             
                                                                               
            process.exit(1);                                                   
                                                                               
        }                                                                      
                                                                               
        commit(args[2]);                                                       
                                                                               
        break;                                                                 
                                                                               
    case 'log':                                                                
                                                                               
        log();                                                                 
                                                                               
        break;                                                                 
                                                                               
    default:                                                                   
                                                                               
        console.error(`Unknown command: ${command}`);                          
                                                                               
        process.exit(1);                                                       
                                                                               
}                                                                              
                                                                               

