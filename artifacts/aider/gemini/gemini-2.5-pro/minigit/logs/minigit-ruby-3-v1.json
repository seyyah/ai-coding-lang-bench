#!/usr/bin/env ruby                                                            
                                                                               
                                                                               
                                                                               
require 'fileutils'                                                            
                                                                               
                                                                               
                                                                               
class MiniGit                                                                  
                                                                               
  MINIGIT_DIR = '.minigit'                                                     
                                                                               
  OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects')                              
                                                                               
  COMMITS_DIR = File.join(MINIGIT_DIR, 'commits')                              
                                                                               
  INDEX_FILE = File.join(MINIGIT_DIR, 'index')                                 
                                                                               
  HEAD_FILE = File.join(MINIGIT_DIR, 'HEAD')                                   
                                                                               
                                                                               
                                                                               
  def self.run(args)                                                           
                                                                               
    command = args[0]                                                          
                                                                               
    case command                                                               
                                                                               
    when 'init'                                                                
                                                                               
      init                                                                     
                                                                               
    when 'add'                                                                 
                                                                               
      add(args[1])                                                             
                                                                               
    when 'commit'                                                              
                                                                               
      if args[1] == '-m' && args.length >= 3                                   
                                                                               
        commit(args[2])                                                        
                                                                               
      else                                                                     
                                                                               
        exit 1                                                                 
                                                                               
      end                                                                      
                                                                               
    when 'log'                                                                 
                                                                               
      log                                                                      
                                                                               
    else                                                                       
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  private                                                                      
                                                                               
                                                                               
                                                                               
  def self.mini_hash(data)                                                     
                                                                               
    h = 1469598103934665603                                                    
                                                                               
    data.each_byte do |b|                                                      
                                                                               
      h ^= b                                                                   
                                                                               
      h = (h * 1099511628211) & 0xFFFFFFFFFFFFFFFF                             
                                                                               
    end                                                                        
                                                                               
    format('%016x', h)                                                         
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def self.init                                                                
                                                                               
    if Dir.exist?(MINIGIT_DIR)                                                 
                                                                               
      puts "Repository already initialized"                                    
                                                                               
      exit 0                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    Dir.mkdir(MINIGIT_DIR)                                                     
                                                                               
    Dir.mkdir(OBJECTS_DIR)                                                     
                                                                               
    Dir.mkdir(COMMITS_DIR)                                                     
                                                                               
    FileUtils.touch(INDEX_FILE)                                                
                                                                               
    FileUtils.touch(HEAD_FILE)                                                 
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def self.add(filename)                                                       
                                                                               
    unless filename && File.exist?(filename)                                   
                                                                               
      puts "File not found"                                                    
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    content = File.binread(filename)                                           
                                                                               
    hash = mini_hash(content)                                                  
                                                                               
                                                                               
                                                                               
    File.write(File.join(OBJECTS_DIR, hash), content)                          
                                                                               
                                                                               
                                                                               
    indexed_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:
true) : []                                                                     
                                                                               
    unless indexed_files.include?(filename)                                    
                                                                               
      File.open(INDEX_FILE, 'a') { |f| f.puts filename }                       
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def self.commit(message)                                                     
                                                                               
    unless File.exist?(INDEX_FILE) && !File.read(INDEX_FILE).strip.empty?      
                                                                               
      puts "Nothing to commit"                                                 
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    staged_files = File.readlines(INDEX_FILE, chomp: true).sort                
                                                                               
                                                                               
                                                                               
    file_lines = staged_files.map do |filename|                                
                                                                               
      content = File.binread(filename)                                         
                                                                               
      blob_hash = mini_hash(content)                                           
                                                                               
      "#{filename} #{blob_hash}"                                               
                                                                               
    end.join("\n")                                                             
                                                                               
                                                                               
                                                                               
    parent = File.read(HEAD_FILE).strip                                        
                                                                               
    parent = 'NONE' if parent.empty?                                           
                                                                               
                                                                               
                                                                               
    timestamp = Time.now.to_i                                                  
                                                                               
                                                                               
                                                                               
    commit_content = "parent: #{parent}\ntimestamp: #{timestamp}\nmessage:     
#{message}\nfiles:\n#{file_lines}"                                             
                                                                               
                                                                               
                                                                               
    commit_hash = mini_hash(commit_content)                                    
                                                                               
                                                                               
                                                                               
    File.write(File.join(COMMITS_DIR, commit_hash), commit_content)            
                                                                               
    File.write(HEAD_FILE, commit_hash)                                         
                                                                               
    File.write(INDEX_FILE, '')                                                 
                                                                               
                                                                               
                                                                               
    puts "Committed #{commit_hash}"                                            
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def self.log                                                                 
                                                                               
    current_hash = File.read(HEAD_FILE).strip                                  
                                                                               
    if current_hash.empty?                                                     
                                                                               
      puts "No commits"                                                        
                                                                               
      return                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    while !current_hash.empty? && current_hash != 'NONE'                       
                                                                               
      commit_path = File.join(COMMITS_DIR, current_hash)                       
                                                                               
      break unless File.exist?(commit_path)                                    
                                                                               
                                                                               
                                                                               
      commit_content = File.read(commit_path)                                  
                                                                               
      lines = commit_content.lines                                             
                                                                               
                                                                               
                                                                               
      parent_line = lines.find { |l| l.start_with?('parent:') }                
                                                                               
      timestamp_line = lines.find { |l| l.start_with?('timestamp:') }          
                                                                               
      message_line = lines.find { |l| l.start_with?('message:') }              
                                                                               
                                                                               
                                                                               
      parent = parent_line.split(': ', 2)[1].strip                             
                                                                               
      timestamp = timestamp_line.split(': ', 2)[1].strip                       
                                                                               
      message = message_line.split(': ', 2)[1].strip                           
                                                                               
                                                                               
                                                                               
      puts "commit #{current_hash}"                                            
                                                                               
      puts "Date: #{timestamp}"                                                
                                                                               
      puts "Message: #{message}"                                               
                                                                               
                                                                               
                                                                               
      current_hash = parent                                                    
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
if __FILE__ == $0                                                              
                                                                               
  MiniGit.run(ARGV)                                                            
                                                                               
end                                                                            
                                                                               

