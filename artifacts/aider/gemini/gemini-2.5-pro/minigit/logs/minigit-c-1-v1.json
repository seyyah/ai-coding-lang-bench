minigit.c                                                                      

                                                                               
#include <stdio.h>                                                             
                                                                               
#include <stdlib.h>                                                            
                                                                               
#include <string.h>                                                            
                                                                               
#include <sys/stat.h>                                                          
                                                                               
#include <sys/types.h>                                                         
                                                                               
#include <unistd.h>                                                            
                                                                               
#include <time.h>                                                              
                                                                               
#include <stdint.h>                                                            
                                                                               
                                                                               
                                                                               
#define MINIGIT_DIR ".minigit"                                                 
                                                                               
#define OBJECTS_DIR ".minigit/objects"                                         
                                                                               
#define COMMITS_DIR ".minigit/commits"                                         
                                                                               
#define INDEX_FILE ".minigit/index"                                            
                                                                               
#define HEAD_FILE ".minigit/HEAD"                                              
                                                                               
                                                                               
                                                                               
uint64_t minihash(const unsigned char *data, size_t len) {                     
                                                                               
    uint64_t h = 1469598103934665603ULL;                                       
                                                                               
    const uint64_t prime = 1099511628211ULL;                                   
                                                                               
    for (size_t i = 0; i < len; ++i) {                                         
                                                                               
        h ^= data[i];                                                          
                                                                               
        h *= prime;                                                            
                                                                               
    }                                                                          
                                                                               
    return h;                                                                  
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void hash_to_string(uint64_t hash, char *out_str) {                            
                                                                               
    sprintf(out_str, "%016lx", hash);                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void create_dir(const char *path) {                                            
                                                                               
    mkdir(path, 0755);                                                         
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void write_file(const char *path, const void *content, size_t len) {           
                                                                               
    FILE *f = fopen(path, "wb");                                               
                                                                               
    if (!f) {                                                                  
                                                                               
        perror("fopen write");                                                 
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
    if (len > 0) {                                                             
                                                                               
        if (fwrite(content, 1, len, f) != len) {                               
                                                                               
            perror("fwrite");                                                  
                                                                               
            fclose(f);                                                         
                                                                               
            exit(1);                                                           
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
    fclose(f);                                                                 
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
char* read_file_content(const char *path, size_t *len) {                       
                                                                               
    FILE *f = fopen(path, "rb");                                               
                                                                               
    if (!f) return NULL;                                                       
                                                                               
    fseek(f, 0, SEEK_END);                                                     
                                                                               
    long file_size = ftell(f);                                                 
                                                                               
    if (file_size < 0) {                                                       
                                                                               
        fclose(f);                                                             
                                                                               
        return NULL;                                                           
                                                                               
    }                                                                          
                                                                               
    *len = file_size;                                                          
                                                                               
    fseek(f, 0, SEEK_SET);                                                     
                                                                               
    char *buf = malloc(*len + 1);                                              
                                                                               
    if (!buf) {                                                                
                                                                               
        fclose(f);                                                             
                                                                               
        return NULL;                                                           
                                                                               
    }                                                                          
                                                                               
    if (*len > 0 && fread(buf, 1, *len, f) != *len) {                          
                                                                               
        free(buf);                                                             
                                                                               
        fclose(f);                                                             
                                                                               
        return NULL;                                                           
                                                                               
    }                                                                          
                                                                               
    buf[*len] = '\0';                                                          
                                                                               
    fclose(f);                                                                 
                                                                               
    return buf;                                                                
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
int path_exists(const char *path) {                                            
                                                                               
    struct stat st;                                                            
                                                                               
    return stat(path, &st) == 0;                                               
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void handle_init() {                                                           
                                                                               
    if (path_exists(MINIGIT_DIR)) {                                            
                                                                               
        printf("Repository already initialized\n");                            
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    create_dir(MINIGIT_DIR);                                                   
                                                                               
    create_dir(OBJECTS_DIR);                                                   
                                                                               
    create_dir(COMMITS_DIR);                                                   
                                                                               
    write_file(INDEX_FILE, "", 0);                                             
                                                                               
    write_file(HEAD_FILE, "", 0);                                              
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void handle_add(const char *filename) {                                        
                                                                               
    if (!path_exists(filename)) {                                              
                                                                               
        printf("File not found\n");                                            
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    size_t content_len;                                                        
                                                                               
    char *content = read_file_content(filename, &content_len);                 
                                                                               
    if (!content) exit(1);                                                     
                                                                               
                                                                               
                                                                               
    uint64_t hash_val = minihash((unsigned char*)content, content_len);        
                                                                               
    char hash_str[17];                                                         
                                                                               
    hash_to_string(hash_val, hash_str);                                        
                                                                               
                                                                               
                                                                               
    char obj_path[512];                                                        
                                                                               
    snprintf(obj_path, sizeof(obj_path), "%s/%s", OBJECTS_DIR, hash_str);      
                                                                               
    write_file(obj_path, content, content_len);                                
                                                                               
    free(content);                                                             
                                                                               
                                                                               
                                                                               
    size_t index_len;                                                          
                                                                               
    char *index_content = read_file_content(INDEX_FILE, &index_len);           
                                                                               
    int found = 0;                                                             
                                                                               
    if (index_content && index_len > 0) {                                      
                                                                               
        char *index_copy = strdup(index_content);                              
                                                                               
        char *line = strtok(index_copy, "\n");                                 
                                                                               
        while (line != NULL) {                                                 
                                                                               
            if (strcmp(line, filename) == 0) {                                 
                                                                               
                found = 1;                                                     
                                                                               
                break;                                                         
                                                                               
            }                                                                  
                                                                               
            line = strtok(NULL, "\n");                                         
                                                                               
        }                                                                      
                                                                               
        free(index_copy);                                                      
                                                                               
    }                                                                          
                                                                               
    free(index_content);                                                       
                                                                               
                                                                               
                                                                               
    if (!found) {                                                              
                                                                               
        FILE *index_file = fopen(INDEX_FILE, "a");                             
                                                                               
        if (!index_file) {                                                     
                                                                               
            perror("fopen index for append");                                  
                                                                               
            exit(1);                                                           
                                                                               
        }                                                                      
                                                                               
        fprintf(index_file, "%s\n", filename);                                 
                                                                               
        fclose(index_file);                                                    
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
int compare_strings(const void *a, const void *b) {                            
                                                                               
    return strcmp(*(const char **)a, *(const char **)b);                       
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void handle_commit(const char *message) {                                      
                                                                               
    size_t index_len;                                                          
                                                                               
    char *index_content = read_file_content(INDEX_FILE, &index_len);           
                                                                               
    if (!index_content || index_len == 0) {                                    
                                                                               
        printf("Nothing to commit\n");                                         
                                                                               
        if(index_content) free(index_content);                                 
                                                                               
        exit(1);                                                               
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    char parent_hash[40];                                                      
                                                                               
    size_t head_len;                                                           
                                                                               
    char *head_content = read_file_content(HEAD_FILE, &head_len);              
                                                                               
    if (!head_content || head_len == 0) {                                      
                                                                               
        strcpy(parent_hash, "NONE");                                           
                                                                               
    } else {                                                                   
                                                                               
        head_content[strcspn(head_content, "\r\n")] = 0;                       
                                                                               
        strcpy(parent_hash, head_content);                                     
                                                                               
    }                                                                          
                                                                               
    if (head_content) free(head_content);                                      
                                                                               
                                                                               
                                                                               
    long timestamp = time(NULL);                                               
                                                                               
                                                                               
                                                                               
    char *filenames[1024];                                                     
                                                                               
    int file_count = 0;                                                        
                                                                               
    char *line = strtok(index_content, "\n");                                  
                                                                               
    while (line != NULL && file_count < 1024) {                                
                                                                               
        filenames[file_count++] = strdup(line);                                
                                                                               
        line = strtok(NULL, "\n");                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    qsort(filenames, file_count, sizeof(char *), compare_strings);             
                                                                               
                                                                               
                                                                               
    char files_list_str[16384] = "";                                           
                                                                               
    for (int i = 0; i < file_count; i++) {                                     
                                                                               
        size_t file_len;                                                       
                                                                               
        char *file_content = read_file_content(filenames[i], &file_len);       
                                                                               
        if (!file_content) exit(1);                                            
                                                                               
                                                                               
                                                                               
        uint64_t blob_hash_val = minihash((unsigned char*)file_content,        
file_len);                                                                     
                                                                               
        char blob_hash_str[17];                                                
                                                                               
        hash_to_string(blob_hash_val, blob_hash_str);                          
                                                                               
                                                                               
                                                                               
        char line_buf[512];                                                    
                                                                               
        snprintf(line_buf, sizeof(line_buf), "%s %s%s", filenames[i],          
blob_hash_str, (i < file_count - 1) ? "\n" : "");                              
                                                                               
        strcat(files_list_str, line_buf);                                      
                                                                               
                                                                               
                                                                               
        free(file_content);                                                    
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    char commit_content[32768];                                                
                                                                               
    snprintf(commit_content, sizeof(commit_content),                           
                                                                               
        "parent: %s\n"                                                         
                                                                               
        "timestamp: %ld\n"                                                     
                                                                               
        "message: %s\n"                                                        
                                                                               
        "files:\n"                                                             
                                                                               
        "%s",                                                                  
                                                                               
        parent_hash, timestamp, message, files_list_str);                      
                                                                               
                                                                               
                                                                               
    size_t commit_len = strlen(commit_content);                                
                                                                               
    uint64_t commit_hash_val = minihash((unsigned char*)commit_content,        
commit_len);                                                                   
                                                                               
    char commit_hash_str[17];                                                  
                                                                               
    hash_to_string(commit_hash_val, commit_hash_str);                          
                                                                               
                                                                               
                                                                               
    char commit_path[512];                                                     
                                                                               
    snprintf(commit_path, sizeof(commit_path), "%s/%s", COMMITS_DIR,           
commit_hash_str);                                                              
                                                                               
    write_file(commit_path, commit_content, commit_len);                       
                                                                               
                                                                               
                                                                               
    write_file(HEAD_FILE, commit_hash_str, strlen(commit_hash_str));           
                                                                               
    write_file(INDEX_FILE, "", 0);                                             
                                                                               
                                                                               
                                                                               
    printf("Committed %s\n", commit_hash_str);                                 
                                                                               
                                                                               
                                                                               
    for (int i = 0; i < file_count; i++) {                                     
                                                                               
        free(filenames[i]);                                                    
                                                                               
    }                                                                          
                                                                               
    free(index_content);                                                       
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
void handle_log() {                                                            
                                                                               
    size_t head_len;                                                           
                                                                               
    char *current_hash_base = read_file_content(HEAD_FILE, &head_len);         
                                                                               
    if (!current_hash_base || head_len == 0) {                                 
                                                                               
        printf("No commits\n");                                                
                                                                               
        if(current_hash_base) free(current_hash_base);                         
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    current_hash_base[strcspn(current_hash_base, "\r\n")] = 0;                 
                                                                               
    char *current_hash = strdup(current_hash_base);                            
                                                                               
    free(current_hash_base);                                                   
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
    while (strlen(current_hash) > 0 && strcmp(current_hash, "NONE") != 0) {    
                                                                               
        char commit_path[512];                                                 
                                                                               
        snprintf(commit_path, sizeof(commit_path), "%s/%s", COMMITS_DIR,       
current_hash);                                                                 
                                                                               
                                                                               
                                                                               
        size_t commit_len;                                                     
                                                                               
        char *commit_content = read_file_content(commit_path, &commit_len);    
                                                                               
        if (!commit_content) break;                                            
                                                                               
                                                                               
                                                                               
        char timestamp[256] = "", message[1024] = "", parent[256] = "";        
                                                                               
                                                                               
                                                                               
        char* commit_copy = strdup(commit_content);                            
                                                                               
        char *line = strtok(commit_copy, "\n");                                
                                                                               
        while(line) {                                                          
                                                                               
            if (strncmp(line, "parent: ", 8) == 0) {                           
                                                                               
                strcpy(parent, line + 8);                                      
                                                                               
            } else if (strncmp(line, "timestamp: ", 11) == 0) {                
                                                                               
                strcpy(timestamp, line + 11);                                  
                                                                               
            } else if (strncmp(line, "message: ", 9) == 0) {                   
                                                                               
                strcpy(message, line + 9);                                     
                                                                               
            } else if (strcmp(line, "files:") == 0) {                          
                                                                               
                break;                                                         
                                                                               
            }                                                                  
                                                                               
            line = strtok(NULL, "\n");                                         
                                                                               
        }                                                                      
                                                                               
        free(commit_copy);                                                     
                                                                               
                                                                               
                                                                               
        printf("commit %s\n", current_hash);                                   
                                                                               
        printf("Date: %s\n", timestamp);                                       
                                                                               
        printf("Message: %s\n", message);                                      
                                                                               
                                                                               
                                                                               
        free(commit_content);                                                  
                                                                               
                                                                               
                                                                               
        char *prev_hash = current_hash;                                        
                                                                               
        current_hash = strdup(parent);                                         
                                                                               
        free(prev_hash);                                                       
                                                                               
    }                                                                          
                                                                               
    free(current_hash);                                                        
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
int main(int argc, char *argv[]) {                                             
                                                                               
    if (argc < 2) {                                                            
                                                                               
        fprintf(stderr, "Usage: minigit <command> [<args>]\n");                
                                                                               
        return 1;                                                              
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const char *command = argv[1];                                             
                                                                               
                                                                               
                                                                               
    if (strcmp(command, "init") == 0) {                                        
                                                                               
        handle_init();                                                         
                                                                               
    } else if (strcmp(command, "add") == 0) {                                  
                                                                               
        if (argc != 3) {                                                       
                                                                               
            fprintf(stderr, "Usage: minigit add <file>\n");                    
                                                                               
            return 1;                                                          
                                                                               
        }                                                                      
                                                                               
        handle_add(argv[2]);                                                   
                                                                               
    } else if (strcmp(command, "commit") == 0) {                               
                                                                               
        if (argc != 4 || strcmp(argv[2], "-m") != 0) {                         
                                                                               
            fprintf(stderr, "Usage: minigit commit -m \"<message>\"\n");       
                                                                               
            return 1;                                                          
                                                                               
        }                                                                      
                                                                               
        handle_commit(argv[3]);                                                
                                                                               
    } else if (strcmp(command, "log") == 0) {                                  
                                                                               
        handle_log();                                                          
                                                                               
    } else {                                                                   
                                                                               
        fprintf(stderr, "Unknown command: %s\n", command);                     
                                                                               
        return 1;                                                              
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    return 0;                                                                  
                                                                               
}                                                                              
                                                                               

