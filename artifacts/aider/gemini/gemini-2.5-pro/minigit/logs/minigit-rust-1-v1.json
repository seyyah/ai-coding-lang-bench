kod src/main.rs dosyasında yer alacaktır.                                      

İşte istenen değişiklikler:                                                    

 1 Cargo.toml: Projenin bağımlılıkları olmadan basit bir tanımını içeren yeni  
   bir dosya oluşturulacak.                                                    
 2 Makefile: cargo kullanarak projeyi derlemek ve çalıştırılabilir dosyayı test
   betiğinin beklediği yere kopyalamak için yeni bir dosya oluşturulacak.      
 3 src/main.rs: init, add, commit ve log komutlarının tüm mantığını içeren yeni
   bir dosya oluşturulacak.                                                    

Aşağıda bu dosyaların içerikleri bulunmaktadır.                                

Cargo.toml                                                                     

                                                                               
[package]                                                                      
                                                                               
name = "minigit"                                                               
                                                                               
version = "0.1.0"                                                              
                                                                               
edition = "2021"                                                               
                                                                               
                                                                               
                                                                               
[dependencies]                                                                 
                                                                               

Makefile                                                                       

                                                                               
.PHONY: all clean                                                              
                                                                               
                                                                               
                                                                               
all: minigit                                                                   
                                                                               
                                                                               
                                                                               
minigit:                                                                       
                                                                               
    @cargo build --release --quiet                                             
                                                                               
    @cp target/release/minigit .                                               
                                                                               
                                                                               
                                                                               
clean:                                                                         
                                                                               
    @cargo clean --quiet                                                       
                                                                               
    @rm -f minigit                                                             
                                                                               

src/main.rs                                                                    

                                                                               
use std::collections::HashSet;                                                 
                                                                               
use std::env;                                                                  
                                                                               
use std::fs;                                                                   
                                                                               
use std::io::Write;                                                            
                                                                               
use std::path::Path;                                                           
                                                                               
use std::process;                                                              
                                                                               
use std::time::{SystemTime, UNIX_EPOCH};                                       
                                                                               
                                                                               
                                                                               
fn minihash(data: &[u8]) -> String {                                           
                                                                               
    let mut h: u64 = 1469598103934665603;                                      
                                                                               
    let prime: u64 = 1099511628211;                                            
                                                                               
                                                                               
                                                                               
    for &b in data {                                                           
                                                                               
        h ^= b as u64;                                                         
                                                                               
        h = h.wrapping_mul(prime);                                             
                                                                               
    }                                                                          
                                                                               
    format!("{:016x}", h)                                                      
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_init() {                                                             
                                                                               
    if Path::new(".minigit").exists() {                                        
                                                                               
        println!("Repository already initialized");                            
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    fs::create_dir(".minigit").unwrap();                                       
                                                                               
    fs::create_dir(".minigit/objects").unwrap();                               
                                                                               
    fs::create_dir(".minigit/commits").unwrap();                               
                                                                               
    fs::File::create(".minigit/index").unwrap();                               
                                                                               
    fs::File::create(".minigit/HEAD").unwrap();                                
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_add(filename: &str) {                                                
                                                                               
    let file_path = Path::new(filename);                                       
                                                                               
    if !file_path.exists() {                                                   
                                                                               
        println!("File not found");                                            
                                                                               
        process::exit(1);                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let content = fs::read(file_path).unwrap();                                
                                                                               
    let hash = minihash(&content);                                             
                                                                               
                                                                               
                                                                               
    let object_path = Path::new(".minigit/objects").join(&hash);               
                                                                               
    fs::write(object_path, content).unwrap();                                  
                                                                               
                                                                               
                                                                               
    let index_path = ".minigit/index";                                         
                                                                               
    let index_content = fs::read_to_string(index_path).unwrap();               
                                                                               
    let mut files: HashSet<String> =                                           
index_content.lines().map(String::from).collect();                             
                                                                               
                                                                               
                                                                               
    if files.insert(filename.to_string()) {                                    
                                                                               
        let mut sorted_files: Vec<String> = files.into_iter().collect();       
                                                                               
        sorted_files.sort();                                                   
                                                                               
        let mut new_index_content = sorted_files.join("\n");                   
                                                                               
        if !new_index_content.is_empty() {                                     
                                                                               
            new_index_content.push('\n');                                      
                                                                               
        }                                                                      
                                                                               
        fs::write(index_path, new_index_content).unwrap();                     
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_commit(message: &str) {                                              
                                                                               
    let index_path = ".minigit/index";                                         
                                                                               
    let index_content = fs::read_to_string(index_path).unwrap();               
                                                                               
    if index_content.trim().is_empty() {                                       
                                                                               
        println!("Nothing to commit");                                         
                                                                               
        process::exit(1);                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let head_content = fs::read_to_string(".minigit/HEAD").unwrap();           
                                                                               
    let parent_hash = if head_content.trim().is_empty() {                      
                                                                               
        "NONE".to_string()                                                     
                                                                               
    } else {                                                                   
                                                                               
        head_content.trim().to_string()                                        
                                                                               
    };                                                                         
                                                                               
                                                                               
                                                                               
    let timestamp = SystemTime::now()                                          
                                                                               
        .duration_since(UNIX_EPOCH)                                            
                                                                               
        .unwrap()                                                              
                                                                               
        .as_secs();                                                            
                                                                               
                                                                               
                                                                               
    let mut staged_files: Vec<String> =                                        
index_content.lines().map(String::from).collect();                             
                                                                               
    staged_files.sort();                                                       
                                                                               
                                                                               
                                                                               
    let mut file_entries = Vec::new();                                         
                                                                               
    for filename in &staged_files {                                            
                                                                               
        let content = fs::read(filename).unwrap();                             
                                                                               
        let hash = minihash(&content);                                         
                                                                               
        file_entries.push(format!("{} {}", filename, hash));                   
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let commit_data = format!(                                                 
                                                                               
        "parent: {}\ntimestamp: {}\nmessage: {}\nfiles:\n{}",                  
                                                                               
        parent_hash,                                                           
                                                                               
        timestamp,                                                             
                                                                               
        message,                                                               
                                                                               
        file_entries.join("\n")                                                
                                                                               
    );                                                                         
                                                                               
                                                                               
                                                                               
    let commit_hash = minihash(commit_data.as_bytes());                        
                                                                               
                                                                               
                                                                               
    fs::write(                                                                 
                                                                               
        Path::new(".minigit/commits").join(&commit_hash),                      
                                                                               
        commit_data,                                                           
                                                                               
    )                                                                          
                                                                               
    .unwrap();                                                                 
                                                                               
    fs::write(".minigit/HEAD", &commit_hash).unwrap();                         
                                                                               
    fs::write(index_path, "").unwrap();                                        
                                                                               
                                                                               
                                                                               
    println!("Committed {}", commit_hash);                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn handle_log() {                                                              
                                                                               
    let head_content = fs::read_to_string(".minigit/HEAD").unwrap();           
                                                                               
    let mut current_hash = head_content.trim().to_string();                    
                                                                               
                                                                               
                                                                               
    if current_hash.is_empty() {                                               
                                                                               
        println!("No commits");                                                
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while !current_hash.is_empty() && current_hash != "NONE" {                 
                                                                               
        let commit_path = Path::new(".minigit/commits").join(&current_hash);   
                                                                               
        if !commit_path.exists() {                                             
                                                                               
            break;                                                             
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        let commit_content = fs::read_to_string(commit_path).unwrap();         
                                                                               
        let mut parent = "NONE".to_string();                                   
                                                                               
        let mut timestamp = "";                                                
                                                                               
        let mut message = "";                                                  
                                                                               
                                                                               
                                                                               
        for line in commit_content.lines() {                                   
                                                                               
            if let Some(val) = line.strip_prefix("parent: ") {                 
                                                                               
                parent = val.to_string();                                      
                                                                               
            } else if let Some(val) = line.strip_prefix("timestamp: ") {       
                                                                               
                timestamp = val;                                               
                                                                               
            } else if let Some(val) = line.strip_prefix("message: ") {         
                                                                               
                message = val;                                                 
                                                                               
            }                                                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        println!("commit {}", current_hash);                                   
                                                                               
        println!("Date: {}", timestamp);                                       
                                                                               
        println!("Message: {}", message);                                      
                                                                               
                                                                               
                                                                               
        current_hash = parent;                                                 
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn main() {                                                                    
                                                                               
    let args: Vec<String> = env::args().collect();                             
                                                                               
    if args.len() < 2 {                                                        
                                                                               
        // No command, exit silently                                           
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let command = &args[1];                                                    
                                                                               
                                                                               
                                                                               
    match command.as_str() {                                                   
                                                                               
        "init" => handle_init(),                                               
                                                                               
        "add" => {                                                             
                                                                               
            if args.len() < 3 {                                                
                                                                               
                // Should not happen based on spec                             
                                                                               
                process::exit(1);                                              
                                                                               
            }                                                                  
                                                                               
            handle_add(&args[2]);                                              
                                                                               
        }                                                                      
                                                                               
        "commit" => {                                                          
                                                                               
            if args.len() < 4 || args[2] != "-m" {                             
                                                                               
                // Should not happen based on spec                             
                                                                               
                process::exit(1);                                              
                                                                               
            }                                                                  
                                                                               
            handle_commit(&args[3]);                                           
                                                                               
        }                                                                      
                                                                               
        "log" => handle_log(),                                                 
                                                                               
        _ => {                                                                 
                                                                               
            // Unknown command, exit silently                                  
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               

