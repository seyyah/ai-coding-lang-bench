+function cmd_checkout(commit_hash)                                            
+    local commit_path = ".minigit/commits/" .. commit_hash                    
+    if not fs.exists(commit_path) then                                        
+        print("Invalid commit")                                               
+        os.exit(1)                                                            
+    end                                                                       
+                                                                              
+    local commit_content = fs.read(commit_path)                               
+    local in_files_section = false                                            
+    local files_to_checkout = {}                                              
+                                                                              
+    for line in commit_content:gmatch("[^\r\n]+") do                          
+        if in_files_section then                                              
+            local filename, blob_hash = line:match("^(.-) (%S+)$")            
+            if filename and blob_hash then                                    
+                 table.insert(files_to_checkout, {filename = filename, hash = 
blob_hash})                                                                    
+            end                                                               
+        elseif line == "files:" then                                          
+            in_files_section = true                                           
+        end                                                                   
+    end                                                                       
+                                                                              
+    for _, file_info in ipairs(files_to_checkout) do                          
+        local blob_path = ".minigit/objects/" .. file_info.hash               
+        local content = fs.read(blob_path)                                    
+        if content then                                                       
+            fs.write(file_info.filename, content)                             
+        end                                                                   
+    end                                                                       
+                                                                              
+    fs.write(".minigit/HEAD", commit_hash)                                    
+    fs.write(".minigit/index", "")                                            
+                                                                              
+    print("Checked out " .. commit_hash)                                      
+end                                                                           
+                                                                              
+function cmd_reset(commit_hash)                                               
+    local commit_path = ".minigit/commits/" .. commit_hash                    
+    if not fs.exists(commit_path) then                                        
+        print("Invalid commit")                                               
+        os.exit(1)                                                            
+    end                                                                       
+                                                                              
+    fs.write(".minigit/HEAD", commit_hash)                                    
+    fs.write(".minigit/index", "")                                            
+                                                                              
+    print("Reset to " .. commit_hash)                                         
+end                                                                           
+                                                                              
+function cmd_rm(filename_to_remove)                                           
+    local index_content = fs.read(".minigit/index") or ""                     
+    local files = {}                                                          
+    local found = false                                                       
+    for file in index_content:gmatch("[^\r\n]+") do                           
+        if file == filename_to_remove then                                    
+            found = true                                                      
+        else                                                                  
+            table.insert(files, file)                                         
+        end                                                                   
+    end                                                                       
+                                                                              
+    if not found then                                                         
+        print("File not in index")                                            
+        os.exit(1)                                                            
+    end                                                                       
+                                                                              
+    if #files > 0 then                                                        
+        fs.write(".minigit/index", table.concat(files, "\n") .. "\n")         
+    else                                                                      
+        fs.write(".minigit/index", "")                                        
+    end                                                                       
+end                                                                           
+                                                                              
