#!/usr/bin/env ruby                                                            
                                                                               
                                                                               
                                                                               
require 'fileutils'                                                            
                                                                               
require 'time'                                                                 
                                                                               
                                                                               
                                                                               
MINIGIT_DIR = '.minigit'.freeze                                                
                                                                               
OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects').freeze                         
                                                                               
COMMITS_DIR = File.join(MINIGIT_DIR, 'commits').freeze                         
                                                                               
INDEX_FILE = File.join(MINIGIT_DIR, 'index').freeze                            
                                                                               
HEAD_FILE = File.join(MINIGIT_DIR, 'HEAD').freeze                              
                                                                               
                                                                               
                                                                               
def minihash(content)                                                          
                                                                               
  h = 1469598103934665603                                                      
                                                                               
  content.each_byte do |b|                                                     
                                                                               
    h ^= b                                                                     
                                                                               
    h = (h * 1099511628211) & 0xFFFFFFFFFFFFFFFF                               
                                                                               
  end                                                                          
                                                                               
  format('%016x', h)                                                           
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
def init_repo                                                                  
                                                                               
  if Dir.exist?(MINIGIT_DIR)                                                   
                                                                               
    puts "Repository already initialized"                                      
                                                                               
    exit 0                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  Dir.mkdir(MINIGIT_DIR)                                                       
                                                                               
  Dir.mkdir(OBJECTS_DIR)                                                       
                                                                               
  Dir.mkdir(COMMITS_DIR)                                                       
                                                                               
  FileUtils.touch(INDEX_FILE)                                                  
                                                                               
  FileUtils.touch(HEAD_FILE)                                                   
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
def add_file(file_path)                                                        
                                                                               
  unless file_path && File.exist?(file_path)                                   
                                                                               
    puts "File not found"                                                      
                                                                               
    exit 1                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  content = File.binread(file_path)                                            
                                                                               
  hash = minihash(content)                                                     
                                                                               
                                                                               
                                                                               
  File.binwrite(File.join(OBJECTS_DIR, hash), content)                         
                                                                               
                                                                               
                                                                               
  staged_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:   
true) : []                                                                     
                                                                               
  unless staged_files.include?(file_path)                                      
                                                                               
    File.open(INDEX_FILE, 'a') { |f| f.puts(file_path) }                       
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
def commit_files(message)                                                      
                                                                               
  staged_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:   
true) : []                                                                     
                                                                               
  if staged_files.empty?                                                       
                                                                               
    puts "Nothing to commit"                                                   
                                                                               
    exit 1                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  parent_hash = File.read(HEAD_FILE).strip                                     
                                                                               
  parent_hash = 'NONE' if parent_hash.empty?                                   
                                                                               
                                                                               
                                                                               
  timestamp = Time.now.to_i                                                    
                                                                               
                                                                               
                                                                               
  file_entries = staged_files.sort.map do |file|                               
                                                                               
    content = File.binread(file)                                               
                                                                               
    blob_hash = minihash(content)                                              
                                                                               
    "#{file} #{blob_hash}"                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  commit_content = [                                                           
                                                                               
    "parent: #{parent_hash}",                                                  
                                                                               
    "timestamp: #{timestamp}",                                                 
                                                                               
    "message: #{message}",                                                     
                                                                               
    "files:",                                                                  
                                                                               
    *file_entries                                                              
                                                                               
  ].join("\n")                                                                 
                                                                               
                                                                               
                                                                               
  commit_hash = minihash(commit_content)                                       
                                                                               
                                                                               
                                                                               
  File.write(File.join(COMMITS_DIR, commit_hash), commit_content)              
                                                                               
  File.write(HEAD_FILE, commit_hash + "\n")                                    
                                                                               
  File.truncate(INDEX_FILE, 0)                                                 
                                                                               
                                                                               
                                                                               
  puts "Committed #{commit_hash}"                                              
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
def show_log                                                                   
                                                                               
  current_commit_hash = File.exist?(HEAD_FILE) ? File.read(HEAD_FILE).strip :  
''                                                                             
                                                                               
  if current_commit_hash.empty?                                                
                                                                               
    puts "No commits"                                                          
                                                                               
    return                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  while current_commit_hash && !current_commit_hash.empty? &&                  
current_commit_hash != 'NONE'                                                  
                                                                               
    commit_path = File.join(COMMITS_DIR, current_commit_hash)                  
                                                                               
    break unless File.exist?(commit_path)                                      
                                                                               
                                                                               
                                                                               
    commit_data = {}                                                           
                                                                               
    File.foreach(commit_path) do |line|                                        
                                                                               
      if line.start_with?('parent: ')                                          
                                                                               
        commit_data[:parent] = line.split(': ', 2)[1].strip                    
                                                                               
      elsif line.start_with?('timestamp: ')                                    
                                                                               
        commit_data[:timestamp] = line.split(': ', 2)[1].strip                 
                                                                               
      elsif line.start_with?('message: ')                                      
                                                                               
        commit_data[:message] = line.split(': ', 2)[1].strip                   
                                                                               
      end                                                                      
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    puts "commit #{current_commit_hash}"                                       
                                                                               
    puts "Date: #{commit_data[:timestamp]}"                                    
                                                                               
    puts "Message: #{commit_data[:message]}"                                   
                                                                               
                                                                               
                                                                               
    current_commit_hash = commit_data[:parent]                                 
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
# Main command dispatcher                                                      
                                                                               
command = ARGV[0]                                                              
                                                                               
case command                                                                   
                                                                               
when 'init'                                                                    
                                                                               
  init_repo                                                                    
                                                                               
when 'add'                                                                     
                                                                               
  add_file(ARGV[1])                                                            
                                                                               
when 'commit'                                                                  
                                                                               
  if ARGV[1] == '-m' && ARGV[2]                                                
                                                                               
    commit_files(ARGV[2])                                                      
                                                                               
  else                                                                         
                                                                               
    exit 1                                                                     
                                                                               
  end                                                                          
                                                                               
when 'log'                                                                     
                                                                               
  show_log                                                                     
                                                                               
else                                                                           
                                                                               
  exit 1                                                                       
                                                                               
end                                                                            
                                                                               

