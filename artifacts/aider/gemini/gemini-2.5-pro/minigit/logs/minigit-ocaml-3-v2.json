+let cmd_checkout commit_hash =                                                
+  let commit_path = Filename.concat commits_dir commit_hash in                
+  if not (Sys.file_exists commit_path) then (                                 
+    prerr_endline "Invalid commit";                                           
+    exit 1                                                                    
+  );                                                                          
                                                                               
+  let lines = read_file_lines commit_path in                                  
+  let rec find_files_section lines =                                          
+    match lines with                                                          
+    | [] -> []                                                                
+    | "files:" :: rest -> rest                                                
+    | _ :: rest -> find_files_section rest                                    
+  in                                                                          
+  let file_lines = find_files_section lines in                                
+                                                                              
+  List.iter (fun line ->                                                      
+    match String.split_on_char ' ' line with                                  
+    | [fname; hash] ->                                                        
+        let blob_path = Filename.concat objects_dir hash in                   
+        let content = read_file_bytes blob_path in                            
+        write_file fname content                                              
+    | _ -> ()                                                                 
+  ) file_lines;                                                               
+                                                                              
+  write_file head_file commit_hash;                                           
+  write_file index_file "";                                                   
+                                                                              
+  Printf.printf "Checked out %s\n" commit_hash                                
+                                                                              
+let cmd_reset commit_hash =                                                   
+  let commit_path = Filename.concat commits_dir commit_hash in                
+  if not (Sys.file_exists commit_path) then (                                 
+    prerr_endline "Invalid commit";                                           
+    exit 1                                                                    
+  );                                                                          
+                                                                              
+  write_file head_file commit_hash;                                           
+                                                                              
+  Printf.printf "Reset to %s\n" commit_hash                                   
+                                                                              
 (* --- Main --- *)                                                            
                                                                               
