Makefile                                                                       

                                                                               
.PHONY: all clean                                                              
                                                                               
                                                                               
                                                                               
all: minigit                                                                   
                                                                               
                                                                               
                                                                               
minigit: minigit.ml                                                            
                                                                               
    ocamlopt -o minigit unix.cmxa minigit.ml                                   
                                                                               
                                                                               
                                                                               
clean:                                                                         
                                                                               
    rm -f minigit *.cmi *.cmx *.o                                              
                                                                               

minigit.ml                                                                     

                                                                               
open Printf                                                                    
                                                                               
                                                                               
                                                                               
(* --- Utility Functions --- *)                                                
                                                                               
                                                                               
                                                                               
let read_file_content path =                                                   
                                                                               
  try                                                                          
                                                                               
    let ic = open_in_bin path in                                               
                                                                               
    let len = in_channel_length ic in                                          
                                                                               
    let content = really_input_string ic len in                                
                                                                               
    close_in ic;                                                               
                                                                               
    content                                                                    
                                                                               
  with Sys_error _ -> ""                                                       
                                                                               
                                                                               
                                                                               
let write_file path content =                                                  
                                                                               
  let oc = open_out_bin path in                                                
                                                                               
  output_string oc content;                                                    
                                                                               
  close_out oc                                                                 
                                                                               
                                                                               
                                                                               
let read_lines path =                                                          
                                                                               
  let content = read_file_content path in                                      
                                                                               
  if content = "" then [] else String.split_on_char '\n' content |> List.filter
((<>) "")                                                                      
                                                                               
                                                                               
                                                                               
let write_lines path lines =                                                   
                                                                               
  write_file path (String.concat "\n" lines ^ if lines <> [] then "\n" else "")
                                                                               
                                                                               
                                                                               
(* --- MiniHash Implementation --- *)                                          
                                                                               
                                                                               
                                                                               
module MiniHash = struct                                                       
                                                                               
  let hash_string s =                                                          
                                                                               
    let h = ref 1469598103934665603L in                                        
                                                                               
    String.iter (fun c ->                                                      
                                                                               
      let byte_val = Int64.of_int (Char.code c) in                             
                                                                               
      h := Int64.logxor !h byte_val;                                           
                                                                               
      h := Int64.mul !h 1099511628211L;                                        
                                                                               
    ) s;                                                                       
                                                                               
    sprintf "%016lx" !h                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
(* --- Command Implementations --- *)                                          
                                                                               
                                                                               
                                                                               
let cmd_init () =                                                              
                                                                               
  if Sys.file_exists ".minigit" then                                           
                                                                               
    print_endline "Repository already initialized"                             
                                                                               
  else                                                                         
                                                                               
    begin                                                                      
                                                                               
      Unix.mkdir ".minigit" 0o755;                                             
                                                                               
      Unix.mkdir ".minigit/objects" 0o755;                                     
                                                                               
      Unix.mkdir ".minigit/commits" 0o755;                                     
                                                                               
      write_file ".minigit/index" "";                                          
                                                                               
      write_file ".minigit/HEAD" "";                                           
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
let cmd_add filename =                                                         
                                                                               
  if not (Sys.file_exists filename) then                                       
                                                                               
    begin                                                                      
                                                                               
      print_endline "File not found";                                          
                                                                               
      exit 1                                                                   
                                                                               
    end;                                                                       
                                                                               
  let content = read_file_content filename in                                  
                                                                               
  let hash = MiniHash.hash_string content in                                   
                                                                               
  let object_path = Filename.concat ".minigit/objects" hash in                 
                                                                               
  write_file object_path content;                                              
                                                                               
                                                                               
                                                                               
  let index_path = ".minigit/index" in                                         
                                                                               
  let staged_files = read_lines index_path in                                  
                                                                               
  if not (List.mem filename staged_files) then                                 
                                                                               
    write_lines index_path (staged_files @ [filename])                         
                                                                               
                                                                               
                                                                               
let cmd_commit message =                                                       
                                                                               
  let index_path = ".minigit/index" in                                         
                                                                               
  let staged_files = read_lines index_path in                                  
                                                                               
  if staged_files = [] then                                                    
                                                                               
    begin                                                                      
                                                                               
      print_endline "Nothing to commit";                                       
                                                                               
      exit 1                                                                   
                                                                               
    end;                                                                       
                                                                               
                                                                               
                                                                               
  let head_content = String.trim (read_file_content ".minigit/HEAD") in        
                                                                               
  let parent_hash = if head_content = "" then "NONE" else head_content in      
                                                                               
                                                                               
                                                                               
  let timestamp = int_of_float (Unix.time ()) in                               
                                                                               
                                                                               
                                                                               
  let sorted_files = List.sort String.compare staged_files in                  
                                                                               
                                                                               
                                                                               
  let file_entries = List.map (fun filename ->                                 
                                                                               
    let content = read_file_content filename in                                
                                                                               
    let hash = MiniHash.hash_string content in                                 
                                                                               
    filename ^ " " ^ hash                                                      
                                                                               
  ) sorted_files in                                                            
                                                                               
                                                                               
                                                                               
  let commit_content =                                                         
                                                                               
    let b = Buffer.create 256 in                                               
                                                                               
    bprintf b "parent: %s\n" parent_hash;                                      
                                                                               
    bprintf b "timestamp: %d\n" timestamp;                                     
                                                                               
    bprintf b "message: %s\n" message;                                         
                                                                               
    bprintf b "files:\n";                                                      
                                                                               
    bprintf b "%s" (String.concat "\n" file_entries);                          
                                                                               
    Buffer.contents b                                                          
                                                                               
  in                                                                           
                                                                               
  let commit_hash = MiniHash.hash_string commit_content in                     
                                                                               
                                                                               
                                                                               
  let commit_path = Filename.concat ".minigit/commits" commit_hash in          
                                                                               
  write_file commit_path commit_content;                                       
                                                                               
  write_file ".minigit/HEAD" (commit_hash ^ "\n");                             
                                                                               
  write_file index_path "";                                                    
                                                                               
                                                                               
                                                                               
  printf "Committed %s\n" commit_hash                                          
                                                                               
                                                                               
                                                                               
let cmd_log () =                                                               
                                                                               
  let head_content = String.trim (read_file_content ".minigit/HEAD") in        
                                                                               
  if head_content = "" then                                                    
                                                                               
    print_endline "No commits"                                                 
                                                                               
  else                                                                         
                                                                               
    let rec print_log_history hash =                                           
                                                                               
      if hash <> "NONE" && hash <> "" then                                     
                                                                               
        let commit_path = Filename.concat ".minigit/commits" hash in           
                                                                               
        if Sys.file_exists commit_path then                                    
                                                                               
          let content = read_file_content commit_path in                       
                                                                               
          let lines = String.split_on_char '\n' content in                     
                                                                               
          let parent = ref "" in                                               
                                                                               
          let timestamp = ref "" in                                            
                                                                               
          let message = ref "" in                                              
                                                                               
          List.iter (fun line ->                                               
                                                                               
            match String.split_on_char ':' line with                           
                                                                               
            | "parent"  :: tl -> parent := String.trim (String.concat ":" tl)  
                                                                               
            | "timestamp" :: tl -> timestamp := String.trim (String.concat ":" 
tl)                                                                            
                                                                               
            | "message" :: tl -> message := String.trim (String.concat ":" tl) 
                                                                               
            | _ -> ()                                                          
                                                                               
          ) lines;                                                             
                                                                               
                                                                               
                                                                               
          printf "commit %s\n" hash;                                           
                                                                               
          printf "Date: %s\n" !timestamp;                                      
                                                                               
          printf "Message: %s\n" !message;                                     
                                                                               
          print_endline "";                                                    
                                                                               
                                                                               
                                                                               
          print_log_history !parent                                            
                                                                               
    in                                                                         
                                                                               
    print_log_history head_content                                             
                                                                               
                                                                               
                                                                               
(* --- Main Entry Point --- *)                                                 
                                                                               
                                                                               
                                                                               
let () =                                                                       
                                                                               
  match Array.to_list Sys.argv with                                            
                                                                               
  | [ _; "init" ] -> cmd_init ()                                               
                                                                               
  | [ _; "add"; file ] -> cmd_add file                                         
                                                                               
  | [ _; "commit"; "-m"; message ] -> cmd_commit message                       
                                                                               
  | [ _; "log" ] -> cmd_log ()                                                 
                                                                               
  | _ ->                                                                       
                                                                               
      prerr_endline "Invalid command";                                         
                                                                               
      exit 1                                                                   
                                                                               

