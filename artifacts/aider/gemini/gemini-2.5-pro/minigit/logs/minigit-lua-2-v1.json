#!/usr/bin/env lua                                                             
                                                                               
-- Bu betik, 64-bit aritmetik için FFI'lı LuaJIT gerektirir.                   
                                                                               
-- Spesifikasyonun hash algoritması, standart Lua'da olmayan 64-bit            
                                                                               
-- işaretsiz tamsayı matematiği gerektirir.                                    
                                                                               
                                                                               
                                                                               
local has_ffi, ffi = pcall(require, "ffi")                                     
                                                                               
if not has_ffi then                                                            
                                                                               
    io.stderr:write("Hata: Bu betik 64-bit aritmetik için LuaJIT ile FFI       
gerektirir.\n")                                                                
                                                                               
    os.exit(1)                                                                 
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
ffi.cdef[[                                                                     
                                                                               
    typedef unsigned long long uint64_t;                                       
                                                                               
    int sprintf(char *str, const char *format, ...);                           
                                                                               
]]                                                                             
                                                                               
                                                                               
                                                                               
-- ========================================                                    
                                                                               
-- Özel Hash Algoritması (MiniHash)                                            
                                                                               
-- ========================================                                    
                                                                               
                                                                               
                                                                               
function mini_hash(data)                                                       
                                                                               
    local h = ffi.cast("uint64_t", 1469598103934665603ULL)                     
                                                                               
    local prime = ffi.cast("uint64_t", 1099511628211ULL)                       
                                                                               
                                                                               
                                                                               
    for i = 1, #data do                                                        
                                                                               
        local byte = string.byte(data, i)                                      
                                                                               
        h = h ~ ffi.cast("uint64_t", byte)                                     
                                                                               
        h = h * prime                                                          
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local buf = ffi.new("char[17]")                                            
                                                                               
    ffi.C.sprintf(buf, "%016llx", h)                                           
                                                                               
    return ffi.string(buf)                                                     
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
-- ========================================                                    
                                                                               
-- Dosya Sistemi Yardımcıları                                                  
                                                                               
-- ========================================                                    
                                                                               
                                                                               
                                                                               
local fs = {}                                                                  
                                                                               
                                                                               
                                                                               
function fs.exists(path)                                                       
                                                                               
    local f = io.open(path, "r")                                               
                                                                               
    if f then                                                                  
                                                                               
        f:close()                                                              
                                                                               
        return true                                                            
                                                                               
    end                                                                        
                                                                               
    return false                                                               
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.is_dir(path)                                                       
                                                                               
    -- os.execute, LuaJIT/5.1'de başarı durumunda (çıkış kodu 0) true döner    
                                                                               
    return os.execute("test -d " .. path .. " >/dev/null 2>&1")                
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.mkdir(path)                                                        
                                                                               
    os.execute("mkdir -p " .. path .. " >/dev/null 2>&1")                      
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.read(path)                                                         
                                                                               
    local f, err = io.open(path, "rb")                                         
                                                                               
    if not f then return nil, err end                                          
                                                                               
    local content = f:read("*a")                                               
                                                                               
    f:close()                                                                  
                                                                               
    return content                                                             
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.write(path, content)                                               
                                                                               
    local f, err = io.open(path, "wb")                                         
                                                                               
    if not f then return nil, err end                                          
                                                                               
    f:write(content)                                                           
                                                                               
    f:close()                                                                  
                                                                               
    return true                                                                
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
-- ========================================                                    
                                                                               
-- Komut Implementasyonları                                                    
                                                                               
-- ========================================                                    
                                                                               
                                                                               
                                                                               
function cmd_init()                                                            
                                                                               
    if fs.is_dir(".minigit") then                                              
                                                                               
        print("Repository already initialized")                                
                                                                               
        return                                                                 
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    fs.mkdir(".minigit/objects")                                               
                                                                               
    fs.mkdir(".minigit/commits")                                               
                                                                               
    fs.write(".minigit/index", "")                                             
                                                                               
    fs.write(".minigit/HEAD", "")                                              
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_add(filename)                                                     
                                                                               
    if not fs.exists(filename) then                                            
                                                                               
        print("File not found")                                                
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local content = fs.read(filename)                                          
                                                                               
    local hash = mini_hash(content)                                            
                                                                               
                                                                               
                                                                               
    fs.write(".minigit/objects/" .. hash, content)                             
                                                                               
                                                                               
                                                                               
    local index_content = fs.read(".minigit/index") or ""                      
                                                                               
    local files = {}                                                           
                                                                               
    for file in index_content:gmatch("[^\r\n]+") do                            
                                                                               
        table.insert(files, file)                                              
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local found = false                                                        
                                                                               
    for _, file in ipairs(files) do                                            
                                                                               
        if file == filename then                                               
                                                                               
            found = true                                                       
                                                                               
            break                                                              
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    if not found then                                                          
                                                                               
        table.insert(files, filename)                                          
                                                                               
        fs.write(".minigit/index", table.concat(files, "\n") .. "\n")          
                                                                               
    end                                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_commit(message)                                                   
                                                                               
    local index_content = fs.read(".minigit/index") or ""                      
                                                                               
    if index_content:match("^%s*$") then                                       
                                                                               
        print("Nothing to commit")                                             
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local parent_hash = fs.read(".minigit/HEAD") or ""                         
                                                                               
    parent_hash = parent_hash:match("^%s*(.-)%s*$") -- boşlukları temizle      
                                                                               
    if parent_hash == "" then                                                  
                                                                               
        parent_hash = "NONE"                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local timestamp = os.time()                                                
                                                                               
                                                                               
                                                                               
    local files_from_index = {}                                                
                                                                               
    for filename in index_content:gmatch("[^\r\n]+") do                        
                                                                               
        table.insert(files_from_index, filename)                               
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local files_to_commit = {}                                                 
                                                                               
    for _, filename in ipairs(files_from_index) do                             
                                                                               
        local content = fs.read(filename)                                      
                                                                               
        if content then                                                        
                                                                               
            local hash = mini_hash(content)                                    
                                                                               
            table.insert(files_to_commit, {filename = filename, hash = hash})  
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    table.sort(files_to_commit, function(a, b) return a.filename < b.filename  
end)                                                                           
                                                                               
                                                                               
                                                                               
    local commit_content_parts = {}                                            
                                                                               
    table.insert(commit_content_parts, "parent: " .. parent_hash)              
                                                                               
    table.insert(commit_content_parts, "timestamp: " .. tostring(timestamp))   
                                                                               
    table.insert(commit_content_parts, "message: " .. message)                 
                                                                               
    table.insert(commit_content_parts, "files:")                               
                                                                               
    for _, file_info in ipairs(files_to_commit) do                             
                                                                               
        table.insert(commit_content_parts, file_info.filename .. " " ..        
file_info.hash)                                                                
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local commit_content = table.concat(commit_content_parts, "\n") .. "\n"    
                                                                               
    local commit_hash = mini_hash(commit_content)                              
                                                                               
                                                                               
                                                                               
    fs.write(".minigit/commits/" .. commit_hash, commit_content)               
                                                                               
    fs.write(".minigit/HEAD", commit_hash)                                     
                                                                               
    fs.write(".minigit/index", "")                                             
                                                                               
                                                                               
                                                                               
    print("Committed " .. commit_hash)                                         
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_log()                                                             
                                                                               
    local head_hash = fs.read(".minigit/HEAD") or ""                           
                                                                               
    head_hash = head_hash:match("^%s*(.-)%s*$") -- trim                        
                                                                               
    if head_hash == "" then                                                    
                                                                               
        print("No commits")                                                    
                                                                               
        return                                                                 
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local current_hash = head_hash                                             
                                                                               
    while current_hash and current_hash ~= "NONE" and current_hash ~= "" do    
                                                                               
        local commit_path = ".minigit/commits/" .. current_hash                
                                                                               
        if not fs.exists(commit_path) then                                     
                                                                               
            -- Bu durum bozuk bir repoyu gösterir, döngüden çık.               
                                                                               
            break                                                              
                                                                               
        end                                                                    
                                                                               
                                                                               
                                                                               
        local commit_content = fs.read(commit_path)                            
                                                                               
        local timestamp, message, parent_hash                                  
                                                                               
                                                                               
                                                                               
        for line in commit_content:gmatch("[^\r\n]+") do                       
                                                                               
            if line:match("^parent: ") then                                    
                                                                               
                parent_hash = line:sub(9)                                      
                                                                               
            elseif line:match("^timestamp: ") then                             
                                                                               
                timestamp = line:sub(12)                                       
                                                                               
            elseif line:match("^message: ") then                               
                                                                               
                message = line:sub(10)                                         
                                                                               
            end                                                                
                                                                               
        end                                                                    
                                                                               
                                                                               
                                                                               
        print("commit " .. current_hash)                                       
                                                                               
        print("Date: " .. timestamp)                                           
                                                                               
        print("Message: " .. message)                                          
                                                                               
                                                                               
                                                                               
        current_hash = parent_hash                                             
                                                                               
    end                                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
-- ========================================                                    
                                                                               
-- Ana Dağıtıcı                                                                
                                                                               
-- ========================================                                    
                                                                               
                                                                               
                                                                               
local command = arg[1]                                                         
                                                                               
                                                                               
                                                                               
if command == "init" then                                                      
                                                                               
    cmd_init()                                                                 
                                                                               
elseif command == "add" and arg[2] then                                        
                                                                               
    cmd_add(arg[2])                                                            
                                                                               
elseif command == "commit" and arg[2] == "-m" and arg[3] then                  
                                                                               
    cmd_commit(arg[3])                                                         
                                                                               
elseif command == "log" then                                                   
                                                                               
    cmd_log()                                                                  
                                                                               
else                                                                           
                                                                               
    -- Spesifikasyonda belirtilmemiş davranış, çıkış yap.                      
                                                                               
    os.exit(1)                                                                 
                                                                               
end                                                                            
                                                                               

