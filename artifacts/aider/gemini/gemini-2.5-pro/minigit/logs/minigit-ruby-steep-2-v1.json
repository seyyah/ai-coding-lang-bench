#!/usr/bin/env ruby                                                            
                                                                               
                                                                               
                                                                               
require 'fileutils'                                                            
                                                                               
require 'time'                                                                 
                                                                               
                                                                               
                                                                               
class MiniGit                                                                  
                                                                               
  MINIGIT_DIR = '.minigit'.freeze                                              
                                                                               
  OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects').freeze                       
                                                                               
  COMMITS_DIR = File.join(MINIGIT_DIR, 'commits').freeze                       
                                                                               
  INDEX_FILE = File.join(MINIGIT_DIR, 'index').freeze                          
                                                                               
  HEAD_FILE = File.join(MINIGIT_DIR, 'HEAD').freeze                            
                                                                               
                                                                               
                                                                               
  def run(args)                                                                
                                                                               
    command = args[0]                                                          
                                                                               
    case command                                                               
                                                                               
    when 'init'                                                                
                                                                               
      init                                                                     
                                                                               
    when 'add'                                                                 
                                                                               
      add(args[1])                                                             
                                                                               
    when 'commit'                                                              
                                                                               
      if args[1] == '-m' && args[2]                                            
                                                                               
        commit(args[2])                                                        
                                                                               
      end                                                                      
                                                                               
    when 'log'                                                                 
                                                                               
      log                                                                      
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def init                                                                     
                                                                               
    if Dir.exist?(MINIGIT_DIR)                                                 
                                                                               
      puts "Repository already initialized"                                    
                                                                               
      return                                                                   
                                                                               
    end                                                                        
                                                                               
    FileUtils.mkdir_p(OBJECTS_DIR)                                             
                                                                               
    FileUtils.mkdir_p(COMMITS_DIR)                                             
                                                                               
    FileUtils.touch(INDEX_FILE)                                                
                                                                               
    FileUtils.touch(HEAD_FILE)                                                 
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def add(file_path)                                                           
                                                                               
    unless File.exist?(file_path)                                              
                                                                               
      puts "File not found"                                                    
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    content = File.binread(file_path)                                          
                                                                               
    hash = minihash(content)                                                   
                                                                               
                                                                               
                                                                               
    File.binwrite(File.join(OBJECTS_DIR, hash), content)                       
                                                                               
                                                                               
                                                                               
    staged_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp: 
true).reject(&:empty?) : []                                                    
                                                                               
    staged_files << file_path unless staged_files.include?(file_path)          
                                                                               
    File.write(INDEX_FILE, staged_files.join("\n") + "\n")                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def commit(message)                                                          
                                                                               
    staged_files = File.readlines(INDEX_FILE, chomp: true).reject(&:empty?)    
                                                                               
    if staged_files.empty?                                                     
                                                                               
      puts "Nothing to commit"                                                 
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    parent = File.read(HEAD_FILE).strip                                        
                                                                               
    parent = 'NONE' if parent.empty?                                           
                                                                               
                                                                               
                                                                               
    timestamp = Time.now.to_i                                                  
                                                                               
                                                                               
                                                                               
    file_entries = staged_files.sort.map do |file_path|                        
                                                                               
      content = File.binread(file_path)                                        
                                                                               
      hash = minihash(content)                                                 
                                                                               
      "#{file_path} #{hash}"                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    commit_content = [                                                         
                                                                               
      "parent: #{parent}",                                                     
                                                                               
      "timestamp: #{timestamp}",                                               
                                                                               
      "message: #{message}",                                                   
                                                                               
      "files:",                                                                
                                                                               
      *file_entries                                                            
                                                                               
    ].join("\n")                                                               
                                                                               
                                                                               
                                                                               
    commit_hash = minihash(commit_content)                                     
                                                                               
                                                                               
                                                                               
    File.write(File.join(COMMITS_DIR, commit_hash), commit_content)            
                                                                               
    File.write(HEAD_FILE, commit_hash)                                         
                                                                               
    File.write(INDEX_FILE, "")                                                 
                                                                               
                                                                               
                                                                               
    puts "Committed #{commit_hash}"                                            
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def log                                                                      
                                                                               
    current_hash = File.read(HEAD_FILE).strip                                  
                                                                               
    if current_hash.empty?                                                     
                                                                               
      puts "No commits"                                                        
                                                                               
      return                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    while current_hash != 'NONE' && !current_hash.empty?                       
                                                                               
      commit_path = File.join(COMMITS_DIR, current_hash)                       
                                                                               
      break unless File.exist?(commit_path)                                    
                                                                               
                                                                               
                                                                               
      commit_content = File.read(commit_path)                                  
                                                                               
                                                                               
                                                                               
      lines = commit_content.lines                                             
                                                                               
      parent = lines[0].split(': ', 2)[1].strip                                
                                                                               
      timestamp = lines[1].split(': ', 2)[1].strip                             
                                                                               
      message = lines[2].split(': ', 2)[1].strip                               
                                                                               
                                                                               
                                                                               
      puts "commit #{current_hash}"                                            
                                                                               
      puts "Date: #{timestamp}"                                                
                                                                               
      puts "Message: #{message}"                                               
                                                                               
                                                                               
                                                                               
      current_hash = parent                                                    
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  private                                                                      
                                                                               
                                                                               
                                                                               
  def minihash(data)                                                           
                                                                               
    h = 1469598103934665603                                                    
                                                                               
    fnv_prime = 1099511628211                                                  
                                                                               
    mask = (1 << 64) - 1                                                       
                                                                               
                                                                               
                                                                               
    data.each_byte do |b|                                                      
                                                                               
      h ^= b                                                                   
                                                                               
      h = (h * fnv_prime) & mask                                               
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    format('%016x', h)                                                         
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
if __FILE__ == $0                                                              
                                                                               
  MiniGit.new.run(ARGV)                                                        
                                                                               
end                                                                            
                                                                               

