class MiniGit                                                                  
                                                                               
  MINIGIT_DIR: String                                                          
                                                                               
  OBJECTS_DIR: String                                                          
                                                                               
  COMMITS_DIR: String                                                          
                                                                               
  INDEX_FILE: String                                                           
                                                                               
  HEAD_FILE: String                                                            
                                                                               
                                                                               
                                                                               
  def run: (Array[String] args) -> void                                        
                                                                               
                                                                               
                                                                               
  def init: () -> void                                                         
                                                                               
                                                                               
                                                                               
  def add: (String file_path) -> void                                          
                                                                               
                                                                               
                                                                               
  def commit: (String message) -> void                                         
                                                                               
                                                                               
                                                                               
  def log: () -> void                                                          
                                                                               
                                                                               
                                                                               
  private                                                                      
                                                                               
                                                                               
                                                                               
  def minihash: (String data) -> String                                        
                                                                               
end                                                                            
                                                                               

