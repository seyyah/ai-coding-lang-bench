#!/usr/bin/env ruby                                                            
                                                                               
                                                                               
                                                                               
require 'fileutils'                                                            
                                                                               
require 'time'                                                                 
                                                                               
                                                                               
                                                                               
MINIGIT_DIR = '.minigit'.freeze                                                
                                                                               
OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects').freeze                         
                                                                               
COMMITS_DIR = File.join(MINIGIT_DIR, 'commits').freeze                         
                                                                               
INDEX_FILE = File.join(MINIGIT_DIR, 'index').freeze                            
                                                                               
HEAD_FILE = File.join(MINIGIT_DIR, 'HEAD').freeze                              
                                                                               
                                                                               
                                                                               
# Implements the MiniHash algorithm as per SPEC-v1.txt                         
                                                                               
def mini_hash(data)                                                            
                                                                               
  h = 1469598103934665603                                                      
                                                                               
  fnv_prime = 1099511628211                                                    
                                                                               
  mod = 2**64                                                                  
                                                                               
                                                                               
                                                                               
  data.each_byte do |b|                                                        
                                                                               
    h ^= b                                                                     
                                                                               
    h = (h * fnv_prime) % mod                                                  
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  format('%016x', h)                                                           
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
# 'init' command implementation                                                
                                                                               
def init_command                                                               
                                                                               
  if Dir.exist?(MINIGIT_DIR)                                                   
                                                                               
    puts "Repository already initialized"                                      
                                                                               
    exit 0                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  Dir.mkdir(MINIGIT_DIR)                                                       
                                                                               
  Dir.mkdir(OBJECTS_DIR)                                                       
                                                                               
  Dir.mkdir(COMMITS_DIR)                                                       
                                                                               
  FileUtils.touch(INDEX_FILE)                                                  
                                                                               
  FileUtils.touch(HEAD_FILE)                                                   
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
# 'add' command implementation                                                 
                                                                               
def add_command(file_path)                                                     
                                                                               
  unless file_path && File.exist?(file_path)                                   
                                                                               
    puts "File not found"                                                      
                                                                               
    exit 1                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  content = File.binread(file_path)                                            
                                                                               
  hash = mini_hash(content)                                                    
                                                                               
                                                                               
                                                                               
  File.write(File.join(OBJECTS_DIR, hash), content)                            
                                                                               
                                                                               
                                                                               
  index_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:    
true) : []                                                                     
                                                                               
  unless index_files.include?(file_path)                                       
                                                                               
    File.open(INDEX_FILE, 'a') do |f|                                          
                                                                               
      f.puts(file_path)                                                        
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
# 'commit' command implementation                                              
                                                                               
def commit_command(message)                                                    
                                                                               
  index_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:    
true).reject(&:empty?) : []                                                    
                                                                               
  if index_files.empty?                                                        
                                                                               
    puts "Nothing to commit"                                                   
                                                                               
    exit 1                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  parent_hash = File.read(HEAD_FILE).strip                                     
                                                                               
  parent_hash = 'NONE' if parent_hash.empty?                                   
                                                                               
                                                                               
                                                                               
  timestamp = Time.now.to_i                                                    
                                                                               
                                                                               
                                                                               
  files_info = []                                                              
                                                                               
  index_files.sort.each do |file_path|                                         
                                                                               
    content = File.binread(file_path)                                          
                                                                               
    blob_hash = mini_hash(content)                                             
                                                                               
    files_info << "#{file_path} #{blob_hash}"                                  
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  commit_content_parts = [                                                     
                                                                               
    "parent: #{parent_hash}",                                                  
                                                                               
    "timestamp: #{timestamp}",                                                 
                                                                               
    "message: #{message}",                                                     
                                                                               
    "files:",                                                                  
                                                                               
    *files_info                                                                
                                                                               
  ]                                                                            
                                                                               
  commit_content = commit_content_parts.join("\n")                             
                                                                               
                                                                               
                                                                               
  commit_hash = mini_hash(commit_content)                                      
                                                                               
                                                                               
                                                                               
  File.write(File.join(COMMITS_DIR, commit_hash), commit_content)              
                                                                               
  File.write(HEAD_FILE, "#{commit_hash}\n")                                    
                                                                               
  File.truncate(INDEX_FILE, 0)                                                 
                                                                               
                                                                               
                                                                               
  puts "Committed #{commit_hash}"                                              
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
# 'log' command implementation                                                 
                                                                               
def log_command                                                                
                                                                               
  head_hash = File.read(HEAD_FILE).strip                                       
                                                                               
  if head_hash.empty?                                                          
                                                                               
    puts "No commits"                                                          
                                                                               
    return                                                                     
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  current_hash = head_hash                                                     
                                                                               
  while !current_hash.empty? && current_hash != 'NONE'                         
                                                                               
    commit_file_path = File.join(COMMITS_DIR, current_hash)                    
                                                                               
    break unless File.exist?(commit_file_path)                                 
                                                                               
                                                                               
                                                                               
    content = File.read(commit_file_path)                                      
                                                                               
    lines = content.lines(chomp: true)                                         
                                                                               
                                                                               
                                                                               
    commit_data = {}                                                           
                                                                               
    lines.each do |line|                                                       
                                                                               
      if line.start_with?('parent: ')                                          
                                                                               
        commit_data[:parent] = line.split(': ', 2).last                        
                                                                               
      elsif line.start_with?('timestamp: ')                                    
                                                                               
        commit_data[:timestamp] = line.split(': ', 2).last                     
                                                                               
      elsif line.start_with?('message: ')                                      
                                                                               
        commit_data[:message] = line.split(': ', 2).last                       
                                                                               
      end                                                                      
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    puts "commit #{current_hash}"                                              
                                                                               
    puts "Date: #{commit_data[:timestamp]}"                                    
                                                                               
    puts "Message: #{commit_data[:message]}"                                   
                                                                               
    puts ''                                                                    
                                                                               
                                                                               
                                                                               
    current_hash = commit_data[:parent]                                        
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
# Main command dispatcher                                                      
                                                                               
def main                                                                       
                                                                               
  command = ARGV[0]                                                            
                                                                               
  case command                                                                 
                                                                               
  when 'init'                                                                  
                                                                               
    init_command                                                               
                                                                               
  when 'add'                                                                   
                                                                               
    add_command(ARGV[1])                                                       
                                                                               
  when 'commit'                                                                
                                                                               
    if ARGV[1] == '-m' && ARGV[2]                                              
                                                                               
      commit_command(ARGV[2])                                                  
                                                                               
    else                                                                       
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
  when 'log'                                                                   
                                                                               
    log_command                                                                
                                                                               
  else                                                                         
                                                                               
    exit 1                                                                     
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
main if __FILE__ == $0                                                         
                                                                               

