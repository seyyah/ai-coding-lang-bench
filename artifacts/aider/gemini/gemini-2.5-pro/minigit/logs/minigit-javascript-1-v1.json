#!/usr/bin/env node                                                            
                                                                               
                                                                               
                                                                               
const fs = require('fs');                                                      
                                                                               
const path = require('path');                                                  
                                                                               
const process = require('process');                                            
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR = '.minigit';                                                
                                                                               
const OBJECTS_DIR = path.join(MINIGIT_DIR, 'objects');                         
                                                                               
const COMMITS_DIR = path.join(MINIGIT_DIR, 'commits');                         
                                                                               
const INDEX_FILE = path.join(MINIGIT_DIR, 'index');                            
                                                                               
const HEAD_FILE = path.join(MINIGIT_DIR, 'HEAD');                              
                                                                               
                                                                               
                                                                               
function miniHash(buffer) {                                                    
                                                                               
    let h = 1469598103934665603n;                                              
                                                                               
    const prime = 1099511628211n;                                              
                                                                               
    const mask = 0xFFFFFFFFFFFFFFFFn;                                          
                                                                               
                                                                               
                                                                               
    for (const byte of buffer) {                                               
                                                                               
        h = h ^ BigInt(byte);                                                  
                                                                               
        h = (h * prime) & mask;                                                
                                                                               
    }                                                                          
                                                                               
    return h.toString(16).padStart(16, '0');                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function init() {                                                              
                                                                               
    if (fs.existsSync(MINIGIT_DIR)) {                                          
                                                                               
        console.log("Repository already initialized");                         
                                                                               
        process.exit(0);                                                       
                                                                               
    }                                                                          
                                                                               
    fs.mkdirSync(MINIGIT_DIR);                                                 
                                                                               
    fs.mkdirSync(OBJECTS_DIR);                                                 
                                                                               
    fs.mkdirSync(COMMITS_DIR);                                                 
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
    fs.writeFileSync(HEAD_FILE, '');                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function add(filename) {                                                       
                                                                               
    if (!fs.existsSync(filename)) {                                            
                                                                               
        console.log("File not found");                                         
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const content = fs.readFileSync(filename);                                 
                                                                               
    const hash = miniHash(content);                                            
                                                                               
                                                                               
                                                                               
    const objectPath = path.join(OBJECTS_DIR, hash);                           
                                                                               
    fs.writeFileSync(objectPath, content);                                     
                                                                               
                                                                               
                                                                               
    let indexContent = fs.readFileSync(INDEX_FILE, 'utf8');                    
                                                                               
    let stagedFiles = indexContent.split('\n').filter(line => line.length > 0);
                                                                               
                                                                               
                                                                               
    if (!stagedFiles.includes(filename)) {                                     
                                                                               
        stagedFiles.push(filename);                                            
                                                                               
        fs.writeFileSync(INDEX_FILE, stagedFiles.join('\n') + '\n');           
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function commit(message) {                                                     
                                                                               
    const indexContent = fs.readFileSync(INDEX_FILE, 'utf8').trim();           
                                                                               
    if (!indexContent) {                                                       
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const parent = fs.readFileSync(HEAD_FILE, 'utf8').trim() || 'NONE';        
                                                                               
    const timestamp = Math.floor(Date.now() / 1000);                           
                                                                               
                                                                               
                                                                               
    const stagedFiles = indexContent.split('\n').filter(Boolean);              
                                                                               
    stagedFiles.sort();                                                        
                                                                               
                                                                               
                                                                               
    const fileEntries = stagedFiles.map(filename => {                          
                                                                               
        const content = fs.readFileSync(filename);                             
                                                                               
        const hash = miniHash(content);                                        
                                                                               
        return `${filename} ${hash}`;                                          
                                                                               
    });                                                                        
                                                                               
                                                                               
                                                                               
    let commitContent = `parent: ${parent}\n`;                                 
                                                                               
    commitContent += `timestamp: ${timestamp}\n`;                              
                                                                               
    commitContent += `message: ${message}\n`;                                  
                                                                               
    commitContent += `files:\n`;                                               
                                                                               
    commitContent += fileEntries.join('\n');                                   
                                                                               
                                                                               
                                                                               
    const commitHash = miniHash(Buffer.from(commitContent, 'utf8'));           
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(path.join(COMMITS_DIR, commitHash), commitContent);       
                                                                               
    fs.writeFileSync(HEAD_FILE, commitHash);                                   
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
                                                                               
                                                                               
    console.log(`Committed ${commitHash}`);                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function log() {                                                               
                                                                               
    let currentHash;                                                           
                                                                               
    try {                                                                      
                                                                               
        currentHash = fs.readFileSync(HEAD_FILE, 'utf8').trim();               
                                                                               
    } catch (e) {                                                              
                                                                               
        currentHash = '';                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if (!currentHash) {                                                        
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while (currentHash && currentHash !== 'NONE') {                            
                                                                               
        const commitPath = path.join(COMMITS_DIR, currentHash);                
                                                                               
        if (!fs.existsSync(commitPath)) {                                      
                                                                               
            process.exit(1);                                                   
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        const commitContent = fs.readFileSync(commitPath, 'utf8');             
                                                                               
        const lines = commitContent.split('\n');                               
                                                                               
                                                                               
                                                                               
        const parentLine = lines.find(l => l.startsWith('parent: '));          
                                                                               
        const timestampLine = lines.find(l => l.startsWith('timestamp: '));    
                                                                               
        const messageLine = lines.find(l => l.startsWith('message: '));        
                                                                               
                                                                               
                                                                               
        const timestamp = timestampLine.substring('timestamp: '.length);       
                                                                               
        const message = messageLine.substring('message: '.length);             
                                                                               
        const parent = parentLine.substring('parent: '.length);                
                                                                               
                                                                               
                                                                               
        console.log(`commit ${currentHash}`);                                  
                                                                               
        console.log(`Date: ${timestamp}`);                                     
                                                                               
        console.log(`Message: ${message}`);                                    
                                                                               
                                                                               
                                                                               
        currentHash = parent;                                                  
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function main() {                                                              
                                                                               
    const args = process.argv.slice(2);                                        
                                                                               
    const command = args[0];                                                   
                                                                               
                                                                               
                                                                               
    switch (command) {                                                         
                                                                               
        case 'init':                                                           
                                                                               
            init();                                                            
                                                                               
            break;                                                             
                                                                               
        case 'add':                                                            
                                                                               
            if (args.length < 2) {                                             
                                                                               
                process.exit(1);                                               
                                                                               
            }                                                                  
                                                                               
            add(args[1]);                                                      
                                                                               
            break;                                                             
                                                                               
        case 'commit':                                                         
                                                                               
            if (args.length < 3 || args[1] !== '-m') {                         
                                                                               
                process.exit(1);                                               
                                                                               
            }                                                                  
                                                                               
            commit(args[2]);                                                   
                                                                               
            break;                                                             
                                                                               
        case 'log':                                                            
                                                                               
            log();                                                             
                                                                               
            break;                                                             
                                                                               
        default:                                                               
                                                                               
            process.exit(1);                                                   
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
main();                                                                        
                                                                               

