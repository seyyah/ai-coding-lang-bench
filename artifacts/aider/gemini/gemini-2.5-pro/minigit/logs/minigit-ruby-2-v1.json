#!/usr/bin/env ruby                                                            
                                                                               
                                                                               
                                                                               
require 'fileutils'                                                            
                                                                               
require 'time'                                                                 
                                                                               
                                                                               
                                                                               
class MiniGit                                                                  
                                                                               
  MINIGIT_DIR = '.minigit'.freeze                                              
                                                                               
  OBJECTS_DIR = File.join(MINIGIT_DIR, 'objects').freeze                       
                                                                               
  COMMITS_DIR = File.join(MINIGIT_DIR, 'commits').freeze                       
                                                                               
  INDEX_FILE = File.join(MINIGIT_DIR, 'index').freeze                          
                                                                               
  HEAD_FILE = File.join(MINIGIT_DIR, 'HEAD').freeze                            
                                                                               
                                                                               
                                                                               
  def run(args)                                                                
                                                                               
    command = args[0]                                                          
                                                                               
    case command                                                               
                                                                               
    when 'init'                                                                
                                                                               
      init                                                                     
                                                                               
    when 'add'                                                                 
                                                                               
      exit 1 unless args[1]                                                    
                                                                               
      add(args[1])                                                             
                                                                               
    when 'commit'                                                              
                                                                               
      exit 1 unless args[1] == '-m' && args[2]                                 
                                                                               
      commit(args[2])                                                          
                                                                               
    when 'log'                                                                 
                                                                               
      log                                                                      
                                                                               
    else                                                                       
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  private                                                                      
                                                                               
                                                                               
                                                                               
  def minihash(data)                                                           
                                                                               
    h = 1469598103934665603                                                    
                                                                               
    fnv_prime = 1099511628211                                                  
                                                                               
    mod = 2**64                                                                
                                                                               
                                                                               
                                                                               
    data.each_byte do |b|                                                      
                                                                               
      h ^= b                                                                   
                                                                               
      h = (h * fnv_prime) % mod                                                
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    format('%016x', h)                                                         
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def init                                                                     
                                                                               
    if Dir.exist?(MINIGIT_DIR)                                                 
                                                                               
      puts 'Repository already initialized'                                    
                                                                               
      exit 0                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    FileUtils.mkdir_p(OBJECTS_DIR)                                             
                                                                               
    FileUtils.mkdir_p(COMMITS_DIR)                                             
                                                                               
    FileUtils.touch(INDEX_FILE)                                                
                                                                               
    FileUtils.touch(HEAD_FILE)                                                 
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def add(filename)                                                            
                                                                               
    unless File.exist?(filename)                                               
                                                                               
      puts 'File not found'                                                    
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    content = File.binread(filename)                                           
                                                                               
    hash = minihash(content)                                                   
                                                                               
                                                                               
                                                                               
    File.binwrite(File.join(OBJECTS_DIR, hash), content)                       
                                                                               
                                                                               
                                                                               
    index_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:  
true) : []                                                                     
                                                                               
    return if index_files.include?(filename)                                   
                                                                               
                                                                               
                                                                               
    File.open(INDEX_FILE, 'a') { |f| f.puts filename }                         
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def commit(message)                                                          
                                                                               
    index_files = File.exist?(INDEX_FILE) ? File.readlines(INDEX_FILE, chomp:  
true).reject(&:empty?) : []                                                    
                                                                               
    if index_files.empty?                                                      
                                                                               
      puts 'Nothing to commit'                                                 
                                                                               
      exit 1                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    parent_hash = File.read(HEAD_FILE).strip                                   
                                                                               
    parent_hash = 'NONE' if parent_hash.empty?                                 
                                                                               
                                                                               
                                                                               
    commit_content_lines = []                                                  
                                                                               
    commit_content_lines << "parent: #{parent_hash}"                           
                                                                               
    commit_content_lines << "timestamp: #{Time.now.to_i}"                      
                                                                               
    commit_content_lines << "message: #{message}"                              
                                                                               
    commit_content_lines << 'files:'                                           
                                                                               
                                                                               
                                                                               
    index_files.sort.each do |filename|                                        
                                                                               
      content = File.binread(filename)                                         
                                                                               
      hash = minihash(content)                                                 
                                                                               
      commit_content_lines << "#{filename} #{hash}"                            
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    commit_data = commit_content_lines.join("\n") + "\n"                       
                                                                               
    commit_hash = minihash(commit_data)                                        
                                                                               
                                                                               
                                                                               
    File.write(File.join(COMMITS_DIR, commit_hash), commit_data)               
                                                                               
    File.write(HEAD_FILE, commit_hash)                                         
                                                                               
    File.write(INDEX_FILE, '')                                                 
                                                                               
                                                                               
                                                                               
    puts "Committed #{commit_hash}"                                            
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
  def log                                                                      
                                                                               
    current_hash = File.read(HEAD_FILE).strip                                  
                                                                               
    if current_hash.empty?                                                     
                                                                               
      puts 'No commits'                                                        
                                                                               
      return                                                                   
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    first = true                                                               
                                                                               
    while current_hash != 'NONE' && !current_hash.empty?                       
                                                                               
      commit_path = File.join(COMMITS_DIR, current_hash)                       
                                                                               
      break unless File.exist?(commit_path)                                    
                                                                               
                                                                               
                                                                               
      puts '' unless first                                                     
                                                                               
      first = false                                                            
                                                                               
                                                                               
                                                                               
      commit_data = File.read(commit_path)                                     
                                                                               
                                                                               
                                                                               
      parent_hash = ''                                                         
                                                                               
      timestamp = ''                                                           
                                                                               
      message = ''                                                             
                                                                               
                                                                               
                                                                               
      commit_data.each_line do |line|                                          
                                                                               
        if line.start_with?('parent:')                                         
                                                                               
          parent_hash = line.split(': ', 2)[1].strip                           
                                                                               
        elsif line.start_with?('timestamp:')                                   
                                                                               
          timestamp = line.split(': ', 2)[1].strip                             
                                                                               
        elsif line.start_with?('message:')                                     
                                                                               
          message = line.split(': ', 2)[1].strip                               
                                                                               
        end                                                                    
                                                                               
      end                                                                      
                                                                               
                                                                               
                                                                               
      puts "commit #{current_hash}"                                            
                                                                               
      puts "Date: #{timestamp}"                                                
                                                                               
      puts "Message: #{message}"                                               
                                                                               
                                                                               
                                                                               
      current_hash = parent_hash                                               
                                                                               
    end                                                                        
                                                                               
  end                                                                          
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
if __FILE__ == $0                                                              
                                                                               
  MiniGit.new.run(ARGV)                                                        
                                                                               
end                                                                            
                                                                               

