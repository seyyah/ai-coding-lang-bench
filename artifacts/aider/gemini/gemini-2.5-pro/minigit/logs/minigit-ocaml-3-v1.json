Makefile                                                                       

                                                                               
all: minigit                                                                   
                                                                               
                                                                               
                                                                               
minigit: minigit.ml                                                            
                                                                               
    ocamlopt -o minigit unix.cmxa minigit.ml                                   
                                                                               
                                                                               
                                                                               
clean:                                                                         
                                                                               
    rm -f minigit *.cmi *.cmx *.o                                              
                                                                               

minigit.ml                                                                     

                                                                               
(* --- Helpers --- *)                                                          
                                                                               
                                                                               
                                                                               
let minigit_dir = ".minigit"                                                   
                                                                               
let objects_dir = Filename.concat minigit_dir "objects"                        
                                                                               
let commits_dir = Filename.concat minigit_dir "commits"                        
                                                                               
let index_file = Filename.concat minigit_dir "index"                           
                                                                               
let head_file = Filename.concat minigit_dir "HEAD"                             
                                                                               
                                                                               
                                                                               
let read_file_bytes filename =                                                 
                                                                               
  try                                                                          
                                                                               
    let ic = open_in_bin filename in                                           
                                                                               
    let len = in_channel_length ic in                                          
                                                                               
    let content = really_input_string ic len in                                
                                                                               
    close_in ic;                                                               
                                                                               
    content                                                                    
                                                                               
  with _ -> ""                                                                 
                                                                               
                                                                               
                                                                               
let read_file_lines filename =                                                 
                                                                               
  if not (Sys.file_exists filename) then []                                    
                                                                               
  else                                                                         
                                                                               
    let ic = open_in filename in                                               
                                                                               
    let rec read_all_lines acc =                                               
                                                                               
      try                                                                      
                                                                               
        let line = input_line ic in                                            
                                                                               
        read_all_lines (line :: acc)                                           
                                                                               
      with End_of_file ->                                                      
                                                                               
        close_in ic;                                                           
                                                                               
        List.rev acc                                                           
                                                                               
    in                                                                         
                                                                               
    read_all_lines []                                                          
                                                                               
                                                                               
                                                                               
let write_file filename content =                                              
                                                                               
  let oc = open_out filename in                                                
                                                                               
  output_string oc content;                                                    
                                                                               
  close_out oc                                                                 
                                                                               
                                                                               
                                                                               
let append_file filename content =                                             
                                                                               
  let oc = open_out_gen [Open_append; Open_creat] 0o644 filename in            
                                                                               
  output_string oc content;                                                    
                                                                               
  close_out oc                                                                 
                                                                               
                                                                               
                                                                               
(* --- MiniHash --- *)                                                         
                                                                               
                                                                               
                                                                               
let minihash_string content =                                                  
                                                                               
  let h = ref 1469598103934665603L in                                          
                                                                               
  let prime = 1099511628211L in                                                
                                                                               
  String.iter (fun c ->                                                        
                                                                               
    let b = Char.code c in                                                     
                                                                               
    h := Int64.logxor !h (Int64.of_int b);                                     
                                                                               
    h := Int64.mul !h prime;                                                   
                                                                               
  ) content;                                                                   
                                                                               
  Printf.sprintf "%016Lx" !h                                                   
                                                                               
                                                                               
                                                                               
(* --- Commands --- *)                                                         
                                                                               
                                                                               
                                                                               
let cmd_init () =                                                              
                                                                               
  if Sys.file_exists minigit_dir then (                                        
                                                                               
    print_endline "Repository already initialized";                            
                                                                               
    exit 0                                                                     
                                                                               
  ) else begin                                                                 
                                                                               
    Unix.mkdir minigit_dir 0o755;                                              
                                                                               
    Unix.mkdir objects_dir 0o755;                                              
                                                                               
    Unix.mkdir commits_dir 0o755;                                              
                                                                               
    write_file index_file "";                                                  
                                                                               
    write_file head_file "";                                                   
                                                                               
  end                                                                          
                                                                               
                                                                               
                                                                               
let cmd_add filename =                                                         
                                                                               
  if not (Sys.file_exists filename) then (                                     
                                                                               
    prerr_endline "File not found";                                            
                                                                               
    exit 1                                                                     
                                                                               
  );                                                                           
                                                                               
  let content = read_file_bytes filename in                                    
                                                                               
  let hash = minihash_string content in                                        
                                                                               
  let blob_path = Filename.concat objects_dir hash in                          
                                                                               
  write_file blob_path content;                                                
                                                                               
                                                                               
                                                                               
  let index_lines = read_file_lines index_file |> List.filter ((<>) "") in     
                                                                               
  if not (List.mem filename index_lines) then                                  
                                                                               
    append_file index_file (filename ^ "\n")                                   
                                                                               
                                                                               
                                                                               
let cmd_commit message =                                                       
                                                                               
  let index_lines = read_file_lines index_file |> List.filter ((<>) "") in     
                                                                               
  if index_lines = [] then (                                                   
                                                                               
    prerr_endline "Nothing to commit";                                         
                                                                               
    exit 1                                                                     
                                                                               
  );                                                                           
                                                                               
                                                                               
                                                                               
  let head_content = read_file_bytes head_file in                              
                                                                               
  let parent_hash =                                                            
                                                                               
    let trimmed = String.trim head_content in                                  
                                                                               
    if trimmed = "" then "NONE" else trimmed                                   
                                                                               
  in                                                                           
                                                                               
  let timestamp = int_of_float (Unix.time ()) in                               
                                                                               
                                                                               
                                                                               
  let sorted_files = List.sort String.compare index_lines in                   
                                                                               
  let file_entries = List.map (fun fname ->                                    
                                                                               
    let content = read_file_bytes fname in                                     
                                                                               
    let hash = minihash_string content in                                      
                                                                               
    Printf.sprintf "%s %s" fname hash                                          
                                                                               
  ) sorted_files in                                                            
                                                                               
                                                                               
                                                                               
  let commit_content =                                                         
                                                                               
    let files_str = String.concat "\n" file_entries in                         
                                                                               
    Printf.sprintf "parent: %s\ntimestamp: %d\nmessage: %s\nfiles:\n%s"        
                                                                               
      parent_hash timestamp message files_str                                  
                                                                               
  in                                                                           
                                                                               
                                                                               
                                                                               
  let commit_hash = minihash_string commit_content in                          
                                                                               
  let commit_path = Filename.concat commits_dir commit_hash in                 
                                                                               
  write_file commit_path commit_content;                                       
                                                                               
                                                                               
                                                                               
  write_file head_file commit_hash;                                            
                                                                               
  write_file index_file "";                                                    
                                                                               
                                                                               
                                                                               
  Printf.printf "Committed %s\n" commit_hash                                   
                                                                               
                                                                               
                                                                               
let get_value_from_commit_line line =                                          
                                                                               
  try                                                                          
                                                                               
    let i = String.index line ':' in                                           
                                                                               
    String.trim (String.sub line (i + 1) (String.length line - i - 1))         
                                                                               
  with Not_found -> ""                                                         
                                                                               
                                                                               
                                                                               
let cmd_log () =                                                               
                                                                               
  let head_content = read_file_bytes head_file in                              
                                                                               
  let initial_hash = String.trim head_content in                               
                                                                               
  if initial_hash = "" then                                                    
                                                                               
    print_endline "No commits"                                                 
                                                                               
  else                                                                         
                                                                               
    let rec print_commits_from hash =                                          
                                                                               
      if hash = "NONE" || hash = "" then ()                                    
                                                                               
      else                                                                     
                                                                               
        let commit_path = Filename.concat commits_dir hash in                  
                                                                               
        if Sys.file_exists commit_path then (                                  
                                                                               
          let lines = read_file_lines commit_path in                           
                                                                               
          match lines with                                                     
                                                                               
          | parent_line :: timestamp_line :: message_line :: _ ->              
                                                                               
              let parent = get_value_from_commit_line parent_line in           
                                                                               
              let timestamp = get_value_from_commit_line timestamp_line in     
                                                                               
              let message = get_value_from_commit_line message_line in         
                                                                               
              Printf.printf "commit %s\nDate: %s\nMessage: %s\n\n" hash        
timestamp message;                                                             
                                                                               
              print_commits_from parent                                        
                                                                               
          | _ -> ()                                                            
                                                                               
        )                                                                      
                                                                               
    in                                                                         
                                                                               
    print_commits_from initial_hash                                            
                                                                               
                                                                               
                                                                               
(* --- Main --- *)                                                             
                                                                               
                                                                               
                                                                               
let () =                                                                       
                                                                               
  match Array.to_list Sys.argv with                                            
                                                                               
  | [_; "init"] -> cmd_init ()                                                 
                                                                               
  | [_; "add"; filename] -> cmd_add filename                                   
                                                                               
  | [_; "commit"; "-m"; message] -> cmd_commit message                         
                                                                               
  | [_; "log"] -> cmd_log ()                                                   
                                                                               
  | _ ->                                                                       
                                                                               
      prerr_endline ("Usage: " ^ Sys.argv.(0) ^ " <init|add|commit|log> ..."); 
                                                                               
      exit 1                                                                   
                                                                               

