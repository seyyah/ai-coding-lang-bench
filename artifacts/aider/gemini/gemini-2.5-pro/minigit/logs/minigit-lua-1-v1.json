minigit                                                                        

                                                                               
#!/usr/bin/env lua                                                             
                                                                               
                                                                               
                                                                               
local io = io                                                                  
                                                                               
local os = os                                                                  
                                                                               
local string = string                                                          
                                                                               
local table = table                                                            
                                                                               
local math = math                                                              
                                                                               
                                                                               
                                                                               
local fs = {}                                                                  
                                                                               
                                                                               
                                                                               
function fs.exists(path)                                                       
                                                                               
    local f = io.open(path, "r")                                               
                                                                               
    if f then f:close() end                                                    
                                                                               
    return f ~= nil                                                            
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.read(path)                                                         
                                                                               
    local f = io.open(path, "r")                                               
                                                                               
    if not f then return nil end                                               
                                                                               
    local content = f:read("*a")                                               
                                                                               
    f:close()                                                                  
                                                                               
    return content                                                             
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.write(path, content)                                               
                                                                               
    local f = io.open(path, "w")                                               
                                                                               
    if not f then return nil end                                               
                                                                               
    f:write(content)                                                           
                                                                               
    f:close()                                                                  
                                                                               
    return true                                                                
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.append(path, content)                                              
                                                                               
    local f = io.open(path, "a")                                               
                                                                               
    if not f then return nil end                                               
                                                                               
    f:write(content)                                                           
                                                                               
    f:close()                                                                  
                                                                               
    return true                                                                
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.mkdir(path)                                                        
                                                                               
    os.execute("mkdir -p " .. path)                                            
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.readlines(path)                                                    
                                                                               
    if not fs.exists(path) then return {} end                                  
                                                                               
    local lines = {}                                                           
                                                                               
    for line in io.lines(path) do                                              
                                                                               
        lines[#lines+1] = line                                                 
                                                                               
    end                                                                        
                                                                               
    return lines                                                               
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function fs.trim(s)                                                            
                                                                               
    return s:match("^%s*(.-)%s*$")                                             
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
-- MiniHash Implementation                                                     
                                                                               
local minihash                                                                 
                                                                               
do                                                                             
                                                                               
    local B16 = 65536                                                          
                                                                               
    -- h[1] is LSB, h[4] is MSB                                                
                                                                               
    -- 0x14650FB0739D0383                                                      
                                                                               
    local FNV_OFFSET_BASIS = {0x0383, 0x739D, 0x0FB0, 0x1465}                  
                                                                               
    -- 0x00000100000001B3                                                      
                                                                               
    local FNV_PRIME        = {0x01B3, 0x0000, 0x0100, 0x0000}                  
                                                                               
                                                                               
                                                                               
    local function mul_u64(a, b)                                               
                                                                               
        local res_parts = {0,0,0,0,0,0,0,0}                                    
                                                                               
        for i = 1, 4 do                                                        
                                                                               
            for j = 1, 4 do                                                    
                                                                               
                local k = i + j - 1                                            
                                                                               
                res_parts[k] = res_parts[k] + a[i] * b[j]                      
                                                                               
            end                                                                
                                                                               
        end                                                                    
                                                                               
                                                                               
                                                                               
        local carry = 0                                                        
                                                                               
        for i = 1, 8 do                                                        
                                                                               
            local val = res_parts[i] + carry                                   
                                                                               
            res_parts[i] = val % B16                                           
                                                                               
            carry = math.floor(val / B16)                                      
                                                                               
        end                                                                    
                                                                               
        return {res_parts[1], res_parts[2], res_parts[3], res_parts[4]}        
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local function xor_u64_byte(h, byte)                                       
                                                                               
        h[1] = h[1] ~ byte                                                     
                                                                               
        return h                                                               
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local function u64_to_hex(h)                                               
                                                                               
        return string.format("%04x%04x%04x%04x", h[4], h[3], h[2], h[1])       
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    minihash = function(data)                                                  
                                                                               
        local h = {FNV_OFFSET_BASIS[1], FNV_OFFSET_BASIS[2],                   
FNV_OFFSET_BASIS[3], FNV_OFFSET_BASIS[4]}                                      
                                                                               
        for i = 1, #data do                                                    
                                                                               
            local byte = string.byte(data, i)                                  
                                                                               
            h = xor_u64_byte(h, byte)                                          
                                                                               
            h = mul_u64(h, FNV_PRIME)                                          
                                                                               
        end                                                                    
                                                                               
        return u64_to_hex(h)                                                   
                                                                               
    end                                                                        
                                                                               
end -- MiniHash scope                                                          
                                                                               
                                                                               
                                                                               
-- Commands                                                                    
                                                                               
function cmd_init()                                                            
                                                                               
    if fs.exists(".minigit") then                                              
                                                                               
        print("Repository already initialized")                                
                                                                               
        return                                                                 
                                                                               
    end                                                                        
                                                                               
    fs.mkdir(".minigit/objects")                                               
                                                                               
    fs.mkdir(".minigit/commits")                                               
                                                                               
    fs.write(".minigit/HEAD", "")                                              
                                                                               
    fs.write(".minigit/index", "")                                             
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_add(file_path)                                                    
                                                                               
    if not fs.exists(file_path) then                                           
                                                                               
        print("File not found")                                                
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
    local content = fs.read(file_path)                                         
                                                                               
    local hash = minihash(content)                                             
                                                                               
    fs.write(".minigit/objects/" .. hash, content)                             
                                                                               
                                                                               
                                                                               
    local index_files = fs.readlines(".minigit/index")                         
                                                                               
    local found = false                                                        
                                                                               
    for _, filename in ipairs(index_files) do                                  
                                                                               
        if filename == file_path then                                          
                                                                               
            found = true                                                       
                                                                               
            break                                                              
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    if not found then                                                          
                                                                               
        fs.append(".minigit/index", file_path .. "\n")                         
                                                                               
    end                                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_commit(message)                                                   
                                                                               
    local index_files = fs.readlines(".minigit/index")                         
                                                                               
    if #index_files == 0 then                                                  
                                                                               
        print("Nothing to commit")                                             
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local parent = fs.read(".minigit/HEAD")                                    
                                                                               
    if parent == nil or fs.trim(parent) == "" then                             
                                                                               
        parent = "NONE"                                                        
                                                                               
    else                                                                       
                                                                               
        parent = fs.trim(parent)                                               
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local timestamp = os.time()                                                
                                                                               
                                                                               
                                                                               
    table.sort(index_files)                                                    
                                                                               
                                                                               
                                                                               
    local files_list = {}                                                      
                                                                               
    for _, filename in ipairs(index_files) do                                  
                                                                               
        local content = fs.read(filename)                                      
                                                                               
        if content then                                                        
                                                                               
            local hash = minihash(content)                                     
                                                                               
            files_list[#files_list+1] = filename .. " " .. hash                
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
    local files_part = table.concat(files_list, "\n")                          
                                                                               
                                                                               
                                                                               
    local commit_content = string.format("parent: %s\ntimestamp: %s\nmessage:  
%s\nfiles:\n%s",                                                               
                                                                               
        parent, timestamp, message, files_part)                                
                                                                               
                                                                               
                                                                               
    local commit_hash = minihash(commit_content)                               
                                                                               
                                                                               
                                                                               
    fs.write(".minigit/commits/" .. commit_hash, commit_content)               
                                                                               
    fs.write(".minigit/HEAD", commit_hash .. "\n")                             
                                                                               
    fs.write(".minigit/index", "")                                             
                                                                               
                                                                               
                                                                               
    print("Committed " .. commit_hash)                                         
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
function cmd_log()                                                             
                                                                               
    local head = fs.read(".minigit/HEAD")                                      
                                                                               
    if head == nil or fs.trim(head) == "" then                                 
                                                                               
        print("No commits")                                                    
                                                                               
        return                                                                 
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local current_hash = fs.trim(head)                                         
                                                                               
                                                                               
                                                                               
    while current_hash ~= "NONE" and current_hash ~= "" do                     
                                                                               
        local commit_path = ".minigit/commits/" .. current_hash                
                                                                               
        if not fs.exists(commit_path) then                                     
                                                                               
            break                                                              
                                                                               
        end                                                                    
                                                                               
        local content = fs.read(commit_path)                                   
                                                                               
                                                                               
                                                                               
        local parent = content:match("parent: (%S+)")                          
                                                                               
        local timestamp = content:match("timestamp: (%d+)")                    
                                                                               
        local message = content:match("message: ([^\n]+)")                     
                                                                               
                                                                               
                                                                               
        print("commit " .. current_hash)                                       
                                                                               
        print("Date: " .. timestamp)                                           
                                                                               
        print("Message: " .. message)                                          
                                                                               
                                                                               
                                                                               
        current_hash = parent                                                  
                                                                               
    end                                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
-- Main argument parsing                                                       
                                                                               
if #arg < 1 then                                                               
                                                                               
    return                                                                     
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
local command = arg[1]                                                         
                                                                               
                                                                               
                                                                               
if command == "init" then                                                      
                                                                               
    cmd_init()                                                                 
                                                                               
elseif command == "add" then                                                   
                                                                               
    if not arg[2] then print("Usage: minigit add <file>"); os.exit(1) end      
                                                                               
    cmd_add(arg[2])                                                            
                                                                               
elseif command == "commit" then                                                
                                                                               
    if arg[2] ~= "-m" or not arg[3] then                                       
                                                                               
        print("Usage: minigit commit -m \"<message>\"")                        
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
    cmd_commit(arg[3])                                                         
                                                                               
elseif command == "log" then                                                   
                                                                               
    cmd_log()                                                                  
                                                                               
else                                                                           
                                                                               
    print("Unknown command: " .. command)                                      
                                                                               
    os.exit(1)                                                                 
                                                                               
end                                                                            
                                                                               

