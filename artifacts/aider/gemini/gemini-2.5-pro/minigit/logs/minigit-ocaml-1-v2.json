+let cmd_checkout commit_hash =                                                
+  let commit_path = Filename.concat ".minigit/commits" commit_hash in         
+  if not (Sys.file_exists commit_path) then                                   
+    begin                                                                     
+      print_endline "Invalid commit";                                         
+      exit 1                                                                  
+    end;                                                                      
                                                                               
+  let lines = read_lines commit_path in                                       
+  let rec find_files_section = function                                       
+    | [] -> []                                                                
+    | "files:" :: rest -> rest                                                
+    | _ :: rest -> find_files_section rest                                    
+  in                                                                          
+  let file_lines = find_files_section lines in                                
+  let parsed_files = List.map (fun line ->                                    
+    match String.split_on_char ' ' line with                                  
+    | [filename; hash] -> (filename, hash)                                    
+    | _ -> failwith ("Malformed file entry in commit " ^ commit_hash)         
+  ) file_lines in                                                             
+                                                                              
+    let object_path = Filename.concat ".minigit/objects" blob_hash in         
+    let content = read_file_content object_path in                            
+    write_file filename content                                               
+  ) parsed_files;                                                             
+                                                                              
+  write_file ".minigit/HEAD" (commit_hash ^ "\n");                            
+  write_file ".minigit/index" "";                                             
+                                                                              
+  printf "Checked out %s\n" commit_hash                                       
+                                                                              
+let cmd_reset commit_hash =                                                   
+  let commit_path = Filename.concat ".minigit/commits" commit_hash in         
+  if not (Sys.file_exists commit_path) then                                   
+    begin                                                                     
+      print_endline "Invalid commit";                                         
+      exit 1                                                                  
+    end;                                                                      
+                                                                              
+  write_file ".minigit/HEAD" (commit_hash ^ "\n");                            
+  write_file ".minigit/index" "";                                             
+                                                                              
+  printf "Reset to %s\n" commit_hash                                          
