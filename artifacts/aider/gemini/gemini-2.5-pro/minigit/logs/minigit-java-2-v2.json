+    private static void diff(String commit1Hash, String commit2Hash) throws   
IOException {                                                                  
+        Map<String, String> files1 = getCommitFiles(commit1Hash);             
+        Map<String, String> files2 = getCommitFiles(commit2Hash);             
+                                                                              
+        if (files1 == null || files2 == null) {                               
+            System.out.println("Invalid commit");                             
+            System.exit(1);                                                   
+            return;                                                           
+        }                                                                     
+                                                                              
+        Set<String> allFiles = new HashSet<>(files1.keySet());                
+        allFiles.addAll(files2.keySet());                                     
+                                                                              
+        List<String> sortedFiles = new ArrayList<>(allFiles);                 
+        Collections.sort(sortedFiles);                                        
+                                                                              
+        for (String file : sortedFiles) {                                     
+            String hash1 = files1.get(file);                                  
+            String hash2 = files2.get(file);                                  
+                                                                              
+            if (hash1 == null && hash2 != null) {                             
+                System.out.println("Added: " + file);                         
+            } else if (hash1 != null && hash2 == null) {                      
+                System.out.println("Removed: " + file);                       
+            } else if (hash1 != null && !hash1.equals(hash2)) {               
+                System.out.println("Modified: " + file);                      
+            }                                                                 
+        }                                                                     
+    }                                                                         
