+    private static Map<String, String> getCommitFiles(String commitHash)      
throws IOException {                                                           
+        Path commitPath = COMMITS_DIR.resolve(commitHash);                    
+        if (!Files.exists(commitPath)) {                                      
+            return null;                                                      
+        }                                                                     
+                                                                              
+        Map<String, String> files = new HashMap<>();                          
+        List<String> lines = Files.readAllLines(commitPath);                  
+        boolean filesSection = false;                                         
+        for (String line : lines) {                                           
+            if (line.equals("files:")) {                                      
+                filesSection = true;                                          
+                continue;                                                     
+            }                                                                 
+            if (filesSection) {                                               
+                String[] parts = line.split(" ", 2);                          
+                if (parts.length == 2) {                                      
+                    files.put(parts[0], parts[1]);                            
+                }                                                             
+            }                                                                 
+        }                                                                     
+        return files;                                                         
+    }                                                                         
