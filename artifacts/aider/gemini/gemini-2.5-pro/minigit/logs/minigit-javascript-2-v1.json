Elbette, SPEC-v1.txt dosyasında belirtilen minigit aracını Javascript (Node.js)
kullanarak uygulayacağım. Bu uygulama, test-v1.sh betiğindeki tüm testleri     
geçecek şekilde tasarlanmıştır.                                                

İsteğiniz doğrultusunda, çalıştırılabilir bir minigit dosyası oluşturacağım. Bu
dosya, komutları işlemek için gerekli tüm JavaScript kodunu içerecek ve bir    
shebang satırıyla (#!/usr/bin/env node) başlayacaktır. Bu, dosyanın ./minigit  
olarak doğrudan çalıştırılabilmesini sağlar.                                   

İşte minigit dosyasının içeriği:                                               

minigit                                                                        

                                                                               
#!/usr/bin/env node                                                            
                                                                               
                                                                               
                                                                               
const fs = require('fs');                                                      
                                                                               
const path = require('path');                                                  
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR = '.minigit';                                                
                                                                               
const OBJECTS_DIR = path.join(MINIGIT_DIR, 'objects');                         
                                                                               
const COMMITS_DIR = path.join(MINIGIT_DIR, 'commits');                         
                                                                               
const INDEX_FILE = path.join(MINIGIT_DIR, 'index');                            
                                                                               
const HEAD_FILE = path.join(MINIGIT_DIR, 'HEAD');                              
                                                                               
                                                                               
                                                                               
function miniHash(data) {                                                      
                                                                               
    let h = 1469598103934665603n;                                              
                                                                               
    const MASK = (1n << 64n) - 1n;                                             
                                                                               
    const MULT = 1099511628211n;                                               
                                                                               
                                                                               
                                                                               
    for (const byte of data) {                                                 
                                                                               
        h ^= BigInt(byte);                                                     
                                                                               
        h = (h * MULT) & MASK;                                                 
                                                                               
    }                                                                          
                                                                               
    return h.toString(16).padStart(16, '0');                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function init() {                                                              
                                                                               
    if (fs.existsSync(MINIGIT_DIR)) {                                          
                                                                               
        console.log("Repository already initialized");                         
                                                                               
        process.exit(0);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    fs.mkdirSync(MINIGIT_DIR);                                                 
                                                                               
    fs.mkdirSync(OBJECTS_DIR);                                                 
                                                                               
    fs.mkdirSync(COMMITS_DIR);                                                 
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
    fs.writeFileSync(HEAD_FILE, '');                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function add(file) {                                                           
                                                                               
    if (!fs.existsSync(file)) {                                                
                                                                               
        console.log("File not found");                                         
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const content = fs.readFileSync(file);                                     
                                                                               
    const hash = miniHash(content);                                            
                                                                               
                                                                               
                                                                               
    const blobPath = path.join(OBJECTS_DIR, hash);                             
                                                                               
    fs.writeFileSync(blobPath, content);                                       
                                                                               
                                                                               
                                                                               
    let indexContent = fs.readFileSync(INDEX_FILE, 'utf8');                    
                                                                               
    const indexFiles = indexContent.split('\n').filter(Boolean);               
                                                                               
                                                                               
                                                                               
    if (!indexFiles.includes(file)) {                                          
                                                                               
        indexContent += file + '\n';                                           
                                                                               
        fs.writeFileSync(INDEX_FILE, indexContent);                            
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function commit(message) {                                                     
                                                                               
    const indexContent = fs.readFileSync(INDEX_FILE, 'utf8').trim();           
                                                                               
    if (!indexContent) {                                                       
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const parent = fs.readFileSync(HEAD_FILE, 'utf8').trim() || 'NONE';        
                                                                               
    const timestamp = Math.floor(Date.now() / 1000);                           
                                                                               
                                                                               
                                                                               
    const stagedFiles = indexContent.split('\n').filter(Boolean).sort();       
                                                                               
                                                                               
                                                                               
    const fileEntries = stagedFiles.map(file => {                              
                                                                               
        const content = fs.readFileSync(file);                                 
                                                                               
        const hash = miniHash(content);                                        
                                                                               
        return `${file} ${hash}`;                                              
                                                                               
    });                                                                        
                                                                               
                                                                               
                                                                               
    const commitData = [                                                       
                                                                               
        `parent: ${parent}`,                                                   
                                                                               
        `timestamp: ${timestamp}`,                                             
                                                                               
        `message: ${message}`,                                                 
                                                                               
        'files:',                                                              
                                                                               
        ...fileEntries                                                         
                                                                               
    ].join('\n');                                                              
                                                                               
                                                                               
                                                                               
    const commitHash = miniHash(Buffer.from(commitData, 'utf8'));              
                                                                               
                                                                               
                                                                               
    const commitPath = path.join(COMMITS_DIR, commitHash);                     
                                                                               
    fs.writeFileSync(commitPath, commitData);                                  
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(HEAD_FILE, commitHash);                                   
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
                                                                               
                                                                               
    console.log(`Committed ${commitHash}`);                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function log() {                                                               
                                                                               
    let currentHash = fs.readFileSync(HEAD_FILE, 'utf8').trim();               
                                                                               
                                                                               
                                                                               
    if (!currentHash) {                                                        
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while (currentHash && currentHash !== 'NONE') {                            
                                                                               
        const commitPath = path.join(COMMITS_DIR, currentHash);                
                                                                               
        if (!fs.existsSync(commitPath)) {                                      
                                                                               
            break;                                                             
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        const commitContent = fs.readFileSync(commitPath, 'utf8');             
                                                                               
        const lines = commitContent.split('\n');                               
                                                                               
                                                                               
                                                                               
        const parent = lines[0].substring('parent: '.length);                  
                                                                               
        const timestamp = lines[1].substring('timestamp: '.length);            
                                                                               
        const message = lines[2].substring('message: '.length);                
                                                                               
                                                                               
                                                                               
        console.log(`commit ${currentHash}`);                                  
                                                                               
        console.log(`Date: ${timestamp}`);                                     
                                                                               
        console.log(`Message: ${message}`);                                    
                                                                               
                                                                               
                                                                               
        currentHash = parent;                                                  
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function main() {                                                              
                                                                               
    const args = process.argv.slice(2);                                        
                                                                               
    const command = args[0];                                                   
                                                                               
                                                                               
                                                                               
    switch(command) {                                                          
                                                                               
        case 'init':                                                           
                                                                               
            init();                                                            
                                                                               
            break;                                                             
                                                                               
        case 'add':                                                            
                                                                               
            add(args[1]);                                                      
                                                                               
            break;                                                             
                                                                               
        case 'commit':                                                         
                                                                               
            // args[1] is '-m'                                                 
                                                                               
            commit(args[2]);                                                   
                                                                               
            break;                                                             
                                                                               
        case 'log':                                                            
                                                                               
            log();                                                             
                                                                               
            break;                                                             
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
main();                                                                        
                                                                               

