src/main.rs                                                                    

                                                                               
use std::collections::BTreeSet;                                                
                                                                               
use std::env;                                                                  
                                                                               
use std::fs;                                                                   
                                                                               
use std::path::Path;                                                           
                                                                               
use std::process;                                                              
                                                                               
use std::time::{SystemTime, UNIX_EPOCH};                                       
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR: &str = ".minigit";                                          
                                                                               
const OBJECTS_DIR: &str = ".minigit/objects";                                  
                                                                               
const COMMITS_DIR: &str = ".minigit/commits";                                  
                                                                               
const INDEX_FILE: &str = ".minigit/index";                                     
                                                                               
const HEAD_FILE: &str = ".minigit/HEAD";                                       
                                                                               
                                                                               
                                                                               
// MiniHash algorithm as per spec                                              
                                                                               
fn minihash(data: &[u8]) -> String {                                           
                                                                               
    let mut h: u64 = 1469598103934665603;                                      
                                                                               
    let prime: u64 = 1099511628211;                                            
                                                                               
                                                                               
                                                                               
    for &byte in data {                                                        
                                                                               
        h ^= byte as u64;                                                      
                                                                               
        h = h.wrapping_mul(prime);                                             
                                                                               
    }                                                                          
                                                                               
    format!("{:016x}", h)                                                      
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn main() {                                                                    
                                                                               
    let args: Vec<String> = env::args().collect();                             
                                                                               
    if args.len() < 2 {                                                        
                                                                               
        process::exit(1);                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let command = &args[1];                                                    
                                                                               
    match command.as_str() {                                                   
                                                                               
        "init" => {                                                            
                                                                               
            if args.len() != 2 { process::exit(1); }                           
                                                                               
            cmd_init();                                                        
                                                                               
        }                                                                      
                                                                               
        "add" => {                                                             
                                                                               
            if args.len() != 3 { process::exit(1); }                           
                                                                               
            cmd_add(&args[2]);                                                 
                                                                               
        }                                                                      
                                                                               
        "commit" => {                                                          
                                                                               
            if args.len() != 4 || args[2] != "-m" { process::exit(1); }        
                                                                               
            cmd_commit(&args[3]);                                              
                                                                               
        }                                                                      
                                                                               
        "log" => {                                                             
                                                                               
            if args.len() != 2 { process::exit(1); }                           
                                                                               
            cmd_log();                                                         
                                                                               
        }                                                                      
                                                                               
        _ => {                                                                 
                                                                               
            process::exit(1);                                                  
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn cmd_init() {                                                                
                                                                               
    if Path::new(MINIGIT_DIR).exists() {                                       
                                                                               
        println!("Repository already initialized");                            
                                                                               
        return; // Exit 0 is default                                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    fs::create_dir(MINIGIT_DIR).expect("Failed to create .minigit directory"); 
                                                                               
    fs::create_dir(OBJECTS_DIR).expect("Failed to create objects directory");  
                                                                               
    fs::create_dir(COMMITS_DIR).expect("Failed to create commits directory");  
                                                                               
    fs::File::create(INDEX_FILE).expect("Failed to create index file");        
                                                                               
    fs::File::create(HEAD_FILE).expect("Failed to create HEAD file");          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn cmd_add(filename: &str) {                                                   
                                                                               
    let filepath = Path::new(filename);                                        
                                                                               
    if !filepath.is_file() {                                                   
                                                                               
        println!("File not found");                                            
                                                                               
        process::exit(1);                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let content = fs::read(filepath).expect("Failed to read file content");    
                                                                               
    let hash = minihash(&content);                                             
                                                                               
                                                                               
                                                                               
    let object_path = Path::new(OBJECTS_DIR).join(&hash);                      
                                                                               
    fs::write(object_path, content).expect("Failed to write blob object");     
                                                                               
                                                                               
                                                                               
    let index_content = fs::read_to_string(INDEX_FILE).expect("Failed to read  
index file");                                                                  
                                                                               
    let mut indexed_files: BTreeSet<String> =                                  
                                                                               
        index_content.lines().map(String::from).collect();                     
                                                                               
                                                                               
                                                                               
    if indexed_files.insert(filename.to_string()) {                            
                                                                               
        let mut new_index_content = String::new();                             
                                                                               
        for file in indexed_files {                                            
                                                                               
            new_index_content.push_str(&file);                                 
                                                                               
            new_index_content.push('\n');                                      
                                                                               
        }                                                                      
                                                                               
        fs::write(INDEX_FILE, new_index_content).expect("Failed to write to    
index file");                                                                  
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn cmd_commit(message: &str) {                                                 
                                                                               
    let index_content = fs::read_to_string(INDEX_FILE).expect("Failed to read  
index file");                                                                  
                                                                               
    let staged_files: Vec<String> = index_content.lines().filter(|s|           
!s.is_empty()).map(String::from).collect();                                    
                                                                               
                                                                               
                                                                               
    if staged_files.is_empty() {                                               
                                                                               
        println!("Nothing to commit");                                         
                                                                               
        process::exit(1);                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let parent = fs::read_to_string(HEAD_FILE)                                 
                                                                               
        .expect("Failed to read HEAD")                                         
                                                                               
        .trim()                                                                
                                                                               
        .to_string();                                                          
                                                                               
    let parent_hash = if parent.is_empty() {                                   
                                                                               
        "NONE".to_string()                                                     
                                                                               
    } else {                                                                   
                                                                               
        parent                                                                 
                                                                               
    };                                                                         
                                                                               
                                                                               
                                                                               
    let timestamp = SystemTime::now()                                          
                                                                               
        .duration_since(UNIX_EPOCH)                                            
                                                                               
        .expect("Time went backwards")                                         
                                                                               
        .as_secs();                                                            
                                                                               
                                                                               
                                                                               
    let mut file_entries: Vec<(String, String)> = Vec::new();                  
                                                                               
    for filename in &staged_files {                                            
                                                                               
        let content = fs::read(filename).unwrap_or_else(|_| panic!("Failed to  
read staged file: {}", filename));                                             
                                                                               
        let hash = minihash(&content);                                         
                                                                               
        file_entries.push((filename.clone(), hash));                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    file_entries.sort_by(|a, b| a.0.cmp(&b.0));                                
                                                                               
                                                                               
                                                                               
    let mut commit_body = String::new();                                       
                                                                               
    commit_body.push_str(&format!("parent: {}\n", parent_hash));               
                                                                               
    commit_body.push_str(&format!("timestamp: {}\n", timestamp));              
                                                                               
    commit_body.push_str(&format!("message: {}\n", message));                  
                                                                               
    commit_body.push_str("files:\n");                                          
                                                                               
    for (filename, hash) in file_entries {                                     
                                                                               
        commit_body.push_str(&format!("{} {}\n", filename, hash));             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let commit_content = commit_body.trim_end();                               
                                                                               
                                                                               
                                                                               
    let commit_hash = minihash(commit_content.as_bytes());                     
                                                                               
                                                                               
                                                                               
    let commit_path = Path::new(COMMITS_DIR).join(&commit_hash);               
                                                                               
    fs::write(commit_path, commit_content).expect("Failed to write commit      
object");                                                                      
                                                                               
                                                                               
                                                                               
    fs::write(HEAD_FILE, &commit_hash).expect("Failed to update HEAD");        
                                                                               
    fs::write(INDEX_FILE, "").expect("Failed to clear index");                 
                                                                               
                                                                               
                                                                               
    println!("Committed {}", commit_hash);                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
fn cmd_log() {                                                                 
                                                                               
    let mut current_hash = fs::read_to_string(HEAD_FILE)                       
                                                                               
        .expect("Failed to read HEAD")                                         
                                                                               
        .trim()                                                                
                                                                               
        .to_string();                                                          
                                                                               
                                                                               
                                                                               
    if current_hash.is_empty() {                                               
                                                                               
        println!("No commits");                                                
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while !current_hash.is_empty() && current_hash != "NONE" {                 
                                                                               
        let commit_path = Path::new(COMMITS_DIR).join(&current_hash);          
                                                                               
        if !commit_path.exists() {                                             
                                                                               
            eprintln!("Error: commit object {} not found.", current_hash);     
                                                                               
            process::exit(1);                                                  
                                                                               
        }                                                                      
                                                                               
        let commit_content = fs::read_to_string(commit_path)                   
                                                                               
            .unwrap_or_else(|_| panic!("Failed to read commit object: {}",     
current_hash));                                                                
                                                                               
                                                                               
                                                                               
        let mut timestamp = "";                                                
                                                                               
        let mut message = "";                                                  
                                                                               
        let mut parent = "";                                                   
                                                                               
                                                                               
                                                                               
        for line in commit_content.lines() {                                   
                                                                               
            if let Some(val) = line.strip_prefix("timestamp: ") {              
                                                                               
                timestamp = val;                                               
                                                                               
            } else if let Some(val) = line.strip_prefix("message: ") {         
                                                                               
                message = val;                                                 
                                                                               
            } else if let Some(val) = line.strip_prefix("parent: ") {          
                                                                               
                parent = val;                                                  
                                                                               
            }                                                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        println!("commit {}", current_hash);                                   
                                                                               
        println!("Date: {}", timestamp);                                       
                                                                               
        println!("Message: {}", message);                                      
                                                                               
                                                                               
                                                                               
        current_hash = parent.to_string();                                     
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               

