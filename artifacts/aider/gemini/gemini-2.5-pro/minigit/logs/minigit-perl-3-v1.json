#!/usr/bin/env perl                                                            
                                                                               
                                                                               
                                                                               
use strict;                                                                    
                                                                               
use warnings;                                                                  
                                                                               
use File::Path qw(make_path);                                                  
                                                                               
                                                                               
                                                                               
# --- Constants ---                                                            
                                                                               
my $MINIGIT_DIR = ".minigit";                                                  
                                                                               
my $OBJECTS_DIR = "$MINIGIT_DIR/objects";                                      
                                                                               
my $COMMITS_DIR = "$MINIGIT_DIR/commits";                                      
                                                                               
my $INDEX_FILE = "$MINIGIT_DIR/index";                                         
                                                                               
my $HEAD_FILE = "$MINIGIT_DIR/HEAD";                                           
                                                                               
                                                                               
                                                                               
# --- Helper Subroutines ---                                                   
                                                                               
                                                                               
                                                                               
sub minihash {                                                                 
                                                                               
    my ($data) = @_;                                                           
                                                                               
    {                                                                          
                                                                               
        use bigint;                                                            
                                                                               
        my $h = 1469598103934665603;                                           
                                                                               
        my $prime = 1099511628211;                                             
                                                                               
        my $mask = hex("FFFFFFFFFFFFFFFF");                                    
                                                                               
                                                                               
                                                                               
        for my $byte (unpack("C*", $data)) {                                   
                                                                               
            $h ^= $byte;                                                       
                                                                               
            $h = ($h * $prime);                                                
                                                                               
            $h &= $mask;                                                       
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        return sprintf("%016x", $h);                                           
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
sub read_file_content {                                                        
                                                                               
    my ($filename) = @_;                                                       
                                                                               
    open my $fh, '<:raw', $filename or return undef;                           
                                                                               
    my $content = do { local $/; <$fh> };                                      
                                                                               
    close $fh;                                                                 
                                                                               
    return $content;                                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
sub write_file_content {                                                       
                                                                               
    my ($filename, $content) = @_;                                             
                                                                               
    open my $fh, '>:raw', $filename or die "Cannot write to $filename: $!";    
                                                                               
    print $fh $content;                                                        
                                                                               
    close $fh;                                                                 
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
# --- Command Implementations ---                                              
                                                                               
                                                                               
                                                                               
sub do_init {                                                                  
                                                                               
    if (-d $MINIGIT_DIR) {                                                     
                                                                               
        print "Repository already initialized\n";                              
                                                                               
        exit 0;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    make_path($OBJECTS_DIR, $COMMITS_DIR) or die "Failed to create repository  
directories: $!";                                                              
                                                                               
    write_file_content($INDEX_FILE, "");                                       
                                                                               
    write_file_content($HEAD_FILE, "");                                        
                                                                               
    exit 0;                                                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
sub do_add {                                                                   
                                                                               
    my ($filename) = @_;                                                       
                                                                               
                                                                               
                                                                               
    unless (-f $filename) {                                                    
                                                                               
        print "File not found\n";                                              
                                                                               
        exit 1;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    my $content = read_file_content($filename);                                
                                                                               
    die "Could not read file $filename" unless defined $content;               
                                                                               
                                                                               
                                                                               
    my $hash = minihash($content);                                             
                                                                               
                                                                               
                                                                               
    write_file_content("$OBJECTS_DIR/$hash", $content);                        
                                                                               
                                                                               
                                                                               
    my $index_content = read_file_content($INDEX_FILE);                        
                                                                               
    my @staged_files = grep { length $_ } split /\n/, $index_content;          
                                                                               
                                                                               
                                                                               
    my $is_staged = 0;                                                         
                                                                               
    foreach my $staged_file (@staged_files) {                                  
                                                                               
        if ($staged_file eq $filename) {                                       
                                                                               
            $is_staged = 1;                                                    
                                                                               
            last;                                                              
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    unless ($is_staged) {                                                      
                                                                               
        open my $fh, '>>', $INDEX_FILE or die "Cannot open index file for      
appending: $!";                                                                
                                                                               
        print $fh "$filename\n";                                               
                                                                               
        close $fh;                                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    exit 0;                                                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
sub do_commit {                                                                
                                                                               
    my ($message) = @_;                                                        
                                                                               
                                                                               
                                                                               
    my $index_content = read_file_content($INDEX_FILE);                        
                                                                               
    my @staged_files = sort(grep { length $_ } split /\n/, $index_content);    
                                                                               
                                                                               
                                                                               
    if (@staged_files == 0) {                                                  
                                                                               
        print "Nothing to commit\n";                                           
                                                                               
        exit 1;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    my $parent_hash = read_file_content($HEAD_FILE);                           
                                                                               
    if (defined $parent_hash) {                                                
                                                                               
        $parent_hash =~ s/\s+$//;                                              
                                                                               
    }                                                                          
                                                                               
    $parent_hash = ($parent_hash && length $parent_hash) ? $parent_hash :      
"NONE";                                                                        
                                                                               
                                                                               
                                                                               
    my $timestamp = time();                                                    
                                                                               
                                                                               
                                                                               
    my $commit_files_section = "";                                             
                                                                               
    for my $file (@staged_files) {                                             
                                                                               
        my $content = read_file_content($file);                                
                                                                               
        die "Could not read file $file to commit" unless defined $content;     
                                                                               
        my $hash = minihash($content);                                         
                                                                               
        $commit_files_section .= "$file $hash\n";                              
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    my $commit_content = "parent: $parent_hash\n";                             
                                                                               
    $commit_content .= "timestamp: $timestamp\n";                              
                                                                               
    $commit_content .= "message: $message\n";                                  
                                                                               
    $commit_content .= "files:\n";                                             
                                                                               
    $commit_content .= $commit_files_section;                                  
                                                                               
                                                                               
                                                                               
    my $commit_hash = minihash($commit_content);                               
                                                                               
                                                                               
                                                                               
    write_file_content("$COMMITS_DIR/$commit_hash", $commit_content);          
                                                                               
    write_file_content($HEAD_FILE, "$commit_hash\n");                          
                                                                               
    write_file_content($INDEX_FILE, "");                                       
                                                                               
                                                                               
                                                                               
    print "Committed $commit_hash\n";                                          
                                                                               
    exit 0;                                                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
sub do_log {                                                                   
                                                                               
    my $current_hash = read_file_content($HEAD_FILE);                          
                                                                               
                                                                               
                                                                               
    if (!defined $current_hash || $current_hash =~ /^\s*$/) {                  
                                                                               
        print "No commits\n";                                                  
                                                                               
        exit 0;                                                                
                                                                               
    }                                                                          
                                                                               
    $current_hash =~ s/\s+$//;                                                 
                                                                               
                                                                               
                                                                               
    while ($current_hash ne "NONE" && length $current_hash > 0) {              
                                                                               
        my $commit_file = "$COMMITS_DIR/$current_hash";                        
                                                                               
        unless (-f $commit_file) {                                             
                                                                               
            die "Corrupt repository: commit object $current_hash not found.";  
                                                                               
        }                                                                      
                                                                               
        my $commit_content = read_file_content($commit_file);                  
                                                                               
                                                                               
                                                                               
        my ($parent) = $commit_content =~ /^parent: (.+)/m;                    
                                                                               
        my ($timestamp) = $commit_content =~ /^timestamp: (.+)/m;              
                                                                               
        my ($message) = $commit_content =~ /^message: (.+)/m;                  
                                                                               
                                                                               
                                                                               
        print "commit $current_hash\n";                                        
                                                                               
        print "Date: $timestamp\n";                                            
                                                                               
        print "Message: $message\n";                                           
                                                                               
                                                                               
                                                                               
        $current_hash = $parent;                                               
                                                                               
                                                                               
                                                                               
        if ($current_hash ne "NONE" && length $current_hash > 0) {             
                                                                               
            print "\n";                                                        
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    exit 0;                                                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
# --- Main execution ---                                                       
                                                                               
                                                                               
                                                                               
sub main {                                                                     
                                                                               
    my @args = @ARGV;                                                          
                                                                               
    if (@args == 0) {                                                          
                                                                               
        # No command given, exit. Spec doesn't define behaviour.               
                                                                               
        exit 1;                                                                
                                                                               
    }                                                                          
                                                                               
    my $command = shift @args;                                                 
                                                                               
                                                                               
                                                                               
    if ($command eq 'init') {                                                  
                                                                               
        do_init();                                                             
                                                                               
    }                                                                          
                                                                               
    elsif ($command eq 'add') {                                                
                                                                               
        if (@args == 0) {                                                      
                                                                               
            # Spec doesn't define behaviour.                                   
                                                                               
            exit 1;                                                            
                                                                               
        }                                                                      
                                                                               
        my $file = $args[0];                                                   
                                                                               
        do_add($file);                                                         
                                                                               
    }                                                                          
                                                                               
    elsif ($command eq 'commit') {                                             
                                                                               
        if (@args < 2 || $args[0] ne '-m') {                                   
                                                                               
            # Spec doesn't define behaviour.                                   
                                                                               
            exit 1;                                                            
                                                                               
        }                                                                      
                                                                               
        my $message = $args[1];                                                
                                                                               
        do_commit($message);                                                   
                                                                               
    }                                                                          
                                                                               
    elsif ($command eq 'log') {                                                
                                                                               
        do_log();                                                              
                                                                               
    }                                                                          
                                                                               
    else {                                                                     
                                                                               
        # Spec does not define behaviour for unknown commands.                 
                                                                               
        exit 1;                                                                
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
main();                                                                        
                                                                               

