import java.io.IOException;                                                    
                                                                               
import java.nio.charset.StandardCharsets;                                      
                                                                               
import java.nio.file.Files;                                                    
                                                                               
import java.nio.file.Path;                                                     
                                                                               
import java.nio.file.Paths;                                                    
                                                                               
import java.util.ArrayList;                                                    
                                                                               
import java.util.Collections;                                                  
                                                                               
import java.util.List;                                                         
                                                                               
                                                                               
                                                                               
public class MiniGit {                                                         
                                                                               
                                                                               
                                                                               
    private static final Path MINIGIT_DIR = Paths.get(".minigit");             
                                                                               
    private static final Path OBJECTS_DIR = MINIGIT_DIR.resolve("objects");    
                                                                               
    private static final Path COMMITS_DIR = MINIGIT_DIR.resolve("commits");    
                                                                               
    private static final Path INDEX_FILE = MINIGIT_DIR.resolve("index");       
                                                                               
    private static final Path HEAD_FILE = MINIGIT_DIR.resolve("HEAD");         
                                                                               
                                                                               
                                                                               
    public static void main(String[] args) {                                   
                                                                               
        if (args.length == 0) {                                                
                                                                               
            return;                                                            
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        String command = args[0];                                              
                                                                               
                                                                               
                                                                               
        try {                                                                  
                                                                               
            switch (command) {                                                 
                                                                               
                case "init":                                                   
                                                                               
                    init();                                                    
                                                                               
                    break;                                                     
                                                                               
                case "add":                                                    
                                                                               
                    if (args.length < 2) {                                     
                                                                               
                        System.exit(1);                                        
                                                                               
                    }                                                          
                                                                               
                    add(args[1]);                                              
                                                                               
                    break;                                                     
                                                                               
                case "commit":                                                 
                                                                               
                    if (args.length < 3 || !"-m".equals(args[1])) {            
                                                                               
                        System.exit(1);                                        
                                                                               
                    }                                                          
                                                                               
                    commit(args[2]);                                           
                                                                               
                    break;                                                     
                                                                               
                case "log":                                                    
                                                                               
                    log();                                                     
                                                                               
                    break;                                                     
                                                                               
                default:                                                       
                                                                               
                    System.exit(1);                                            
                                                                               
            }                                                                  
                                                                               
        } catch (IOException e) {                                              
                                                                               
            System.exit(1);                                                    
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    private static String miniHash(byte[] data) {                              
                                                                               
        long h = 1469598103934665603L;                                         
                                                                               
        for (byte b : data) {                                                  
                                                                               
            h ^= (long)b & 0xff;                                               
                                                                               
            h *= 1099511628211L;                                               
                                                                               
        }                                                                      
                                                                               
        return String.format("%016x", h);                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    private static void init() throws IOException {                            
                                                                               
        if (Files.exists(MINIGIT_DIR)) {                                       
                                                                               
            System.out.println("Repository already initialized");              
                                                                               
            System.exit(0);                                                    
                                                                               
        }                                                                      
                                                                               
        Files.createDirectories(MINIGIT_DIR);                                  
                                                                               
        Files.createDirectories(OBJECTS_DIR);                                  
                                                                               
        Files.createDirectories(COMMITS_DIR);                                  
                                                                               
        Files.createFile(INDEX_FILE);                                          
                                                                               
        Files.createFile(HEAD_FILE);                                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    private static void add(String filename) throws IOException {              
                                                                               
        Path filePath = Paths.get(filename);                                   
                                                                               
        if (!Files.exists(filePath)) {                                         
                                                                               
            System.out.println("File not found");                              
                                                                               
            System.exit(1);                                                    
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        byte[] content = Files.readAllBytes(filePath);                         
                                                                               
        String hash = miniHash(content);                                       
                                                                               
        Path objectPath = OBJECTS_DIR.resolve(hash);                           
                                                                               
                                                                               
                                                                               
        if (!Files.exists(objectPath)) {                                       
                                                                               
            Files.write(objectPath, content);                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        List<String> indexEntries;                                             
                                                                               
        if (Files.exists(INDEX_FILE) && Files.size(INDEX_FILE) > 0) {          
                                                                               
            indexEntries = new ArrayList<>(Files.readAllLines(INDEX_FILE,      
StandardCharsets.UTF_8));                                                      
                                                                               
        } else {                                                               
                                                                               
            indexEntries = new ArrayList<>();                                  
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        if (!indexEntries.contains(filename)) {                                
                                                                               
            indexEntries.add(filename);                                        
                                                                               
            Files.write(INDEX_FILE, indexEntries, StandardCharsets.UTF_8);     
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    private static void commit(String message) throws IOException {            
                                                                               
        if (!Files.exists(INDEX_FILE) || Files.size(INDEX_FILE) == 0) {        
                                                                               
            System.out.println("Nothing to commit");                           
                                                                               
            System.exit(1);                                                    
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        String parentHash = Files.readString(HEAD_FILE,                        
StandardCharsets.UTF_8).trim();                                                
                                                                               
        if (parentHash.isEmpty()) {                                            
                                                                               
            parentHash = "NONE";                                               
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        long timestamp = System.currentTimeMillis() / 1000L;                   
                                                                               
                                                                               
                                                                               
        List<String> indexFiles = Files.readAllLines(INDEX_FILE,               
StandardCharsets.UTF_8);                                                       
                                                                               
        Collections.sort(indexFiles);                                          
                                                                               
                                                                               
                                                                               
        StringBuilder commitContent = new StringBuilder();                     
                                                                               
        commitContent.append("parent: ").append(parentHash).append("\n");      
                                                                               
        commitContent.append("timestamp: ").append(timestamp).append("\n");    
                                                                               
        commitContent.append("message: ").append(message).append("\n");        
                                                                               
        commitContent.append("files:\n");                                      
                                                                               
                                                                               
                                                                               
        for (String filename : indexFiles) {                                   
                                                                               
            if (filename.isEmpty()) continue;                                  
                                                                               
            byte[] fileContent = Files.readAllBytes(Paths.get(filename));      
                                                                               
            String blobHash = miniHash(fileContent);                           
                                                                               
            commitContent.append(filename).append("                            
").append(blobHash).append("\n");                                              
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        String commitContentStr = commitContent.toString();                    
                                                                               
        String commitHash =                                                    
miniHash(commitContentStr.getBytes(StandardCharsets.UTF_8));                   
                                                                               
                                                                               
                                                                               
        Path commitPath = COMMITS_DIR.resolve(commitHash);                     
                                                                               
        Files.writeString(commitPath, commitContentStr,                        
StandardCharsets.UTF_8);                                                       
                                                                               
                                                                               
                                                                               
        Files.writeString(HEAD_FILE, commitHash, StandardCharsets.UTF_8);      
                                                                               
        Files.writeString(INDEX_FILE, "", StandardCharsets.UTF_8); // Clear    
index                                                                          
                                                                               
                                                                               
                                                                               
        System.out.println("Committed " + commitHash);                         
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    private static void log() throws IOException {                             
                                                                               
        String currentCommitHash = Files.readString(HEAD_FILE,                 
StandardCharsets.UTF_8).trim();                                                
                                                                               
                                                                               
                                                                               
        if (currentCommitHash.isEmpty()) {                                     
                                                                               
            System.out.println("No commits");                                  
                                                                               
            return;                                                            
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        while (currentCommitHash != null && !currentCommitHash.isEmpty() &&    
!currentCommitHash.equalsIgnoreCase("NONE")) {                                 
                                                                               
            Path commitPath = COMMITS_DIR.resolve(currentCommitHash);          
                                                                               
            if (!Files.exists(commitPath)) {                                   
                                                                               
                break;                                                         
                                                                               
            }                                                                  
                                                                               
                                                                               
                                                                               
            List<String> lines = Files.readAllLines(commitPath,                
StandardCharsets.UTF_8);                                                       
                                                                               
            String parentHash = "NONE";                                        
                                                                               
            String timestamp = "";                                             
                                                                               
            String message = "";                                               
                                                                               
                                                                               
                                                                               
            for (String line : lines) {                                        
                                                                               
                if (line.startsWith("parent: ")) {                             
                                                                               
                    parentHash = line.substring(8);                            
                                                                               
                } else if (line.startsWith("timestamp: ")) {                   
                                                                               
                    timestamp = line.substring(11);                            
                                                                               
                } else if (line.startsWith("message: ")) {                     
                                                                               
                    message = line.substring(9);                               
                                                                               
                }                                                              
                                                                               
            }                                                                  
                                                                               
                                                                               
                                                                               
            System.out.println("commit " + currentCommitHash);                 
                                                                               
            System.out.println("Date: " + timestamp);                          
                                                                               
            System.out.println("Message: " + message);                         
                                                                               
                                                                               
                                                                               
            currentCommitHash = parentHash;                                    
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               

