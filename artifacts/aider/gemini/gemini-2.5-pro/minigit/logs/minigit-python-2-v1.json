#!/usr/bin/env python3                                                         
                                                                               
                                                                               
                                                                               
import sys                                                                     
                                                                               
import os                                                                      
                                                                               
import time                                                                    
                                                                               
                                                                               
                                                                               
MINIGIT_DIR = ".minigit"                                                       
                                                                               
OBJECTS_DIR = os.path.join(MINIGIT_DIR, "objects")                             
                                                                               
COMMITS_DIR = os.path.join(MINIGIT_DIR, "commits")                             
                                                                               
INDEX_FILE = os.path.join(MINIGIT_DIR, "index")                                
                                                                               
HEAD_FILE = os.path.join(MINIGIT_DIR, "HEAD")                                  
                                                                               
                                                                               
                                                                               
def minihash(data: bytes) -> str:                                              
                                                                               
    """Computes the MiniHash of the given data."""                             
                                                                               
    h = 1469598103934665603                                                    
                                                                               
    for b in data:                                                             
                                                                               
        h ^= b                                                                 
                                                                               
        h = (h * 1099511628211) % (2**64)                                      
                                                                               
    return format(h, '016x')                                                   
                                                                               
                                                                               
                                                                               
def cmd_init():                                                                
                                                                               
    """Initializes a new MiniGit repository."""                                
                                                                               
    if os.path.exists(MINIGIT_DIR):                                            
                                                                               
        print("Repository already initialized")                                
                                                                               
        return                                                                 
                                                                               
                                                                               
                                                                               
    os.makedirs(OBJECTS_DIR)                                                   
                                                                               
    os.makedirs(COMMITS_DIR)                                                   
                                                                               
                                                                               
                                                                               
    with open(INDEX_FILE, 'w'):                                                
                                                                               
        pass                                                                   
                                                                               
    with open(HEAD_FILE, 'w'):                                                 
                                                                               
        pass                                                                   
                                                                               
                                                                               
                                                                               
def cmd_add(filename):                                                         
                                                                               
    """Adds a file to the staging area (index)."""                             
                                                                               
    if not os.path.exists(filename):                                           
                                                                               
        print("File not found")                                                
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
    with open(filename, 'rb') as f:                                            
                                                                               
        content = f.read()                                                     
                                                                               
                                                                               
                                                                               
    hash_val = minihash(content)                                               
                                                                               
    object_path = os.path.join(OBJECTS_DIR, hash_val)                          
                                                                               
    with open(object_path, 'wb') as f:                                         
                                                                               
        f.write(content)                                                       
                                                                               
                                                                               
                                                                               
    with open(INDEX_FILE, 'r') as f:                                           
                                                                               
        staged_files = [line.strip() for line in f.readlines()]                
                                                                               
                                                                               
                                                                               
    if filename not in staged_files:                                           
                                                                               
        with open(INDEX_FILE, 'a') as f:                                       
                                                                               
            f.write(filename + '\n')                                           
                                                                               
                                                                               
                                                                               
def cmd_commit(message):                                                       
                                                                               
    """Creates a new commit from the staged files."""                          
                                                                               
    with open(INDEX_FILE, 'r') as f:                                           
                                                                               
        staged_files = [line.strip() for line in f.readlines() if line.strip()]
                                                                               
                                                                               
                                                                               
    if not staged_files:                                                       
                                                                               
        print("Nothing to commit")                                             
                                                                               
        sys.exit(1)                                                            
                                                                               
                                                                               
                                                                               
    staged_files.sort()                                                        
                                                                               
                                                                               
                                                                               
    try:                                                                       
                                                                               
        with open(HEAD_FILE, 'r') as f:                                        
                                                                               
            parent_hash = f.read().strip()                                     
                                                                               
        if not parent_hash:                                                    
                                                                               
            parent_hash = "NONE"                                               
                                                                               
    except FileNotFoundError:                                                  
                                                                               
        parent_hash = "NONE"                                                   
                                                                               
                                                                               
                                                                               
    commit_content_lines = []                                                  
                                                                               
    commit_content_lines.append(f"parent: {parent_hash}")                      
                                                                               
    commit_content_lines.append(f"timestamp: {int(time.time())}")              
                                                                               
    commit_content_lines.append(f"message: {message}")                         
                                                                               
    commit_content_lines.append("files:")                                      
                                                                               
                                                                               
                                                                               
    for filename in staged_files:                                              
                                                                               
        with open(filename, 'rb') as f:                                        
                                                                               
            content = f.read()                                                 
                                                                               
        blob_hash = minihash(content)                                          
                                                                               
        commit_content_lines.append(f"{filename} {blob_hash}")                 
                                                                               
                                                                               
                                                                               
    commit_content = "\n".join(commit_content_lines) + "\n"                    
                                                                               
                                                                               
                                                                               
    commit_hash = minihash(commit_content.encode('utf-8'))                     
                                                                               
                                                                               
                                                                               
    commit_path = os.path.join(COMMITS_DIR, commit_hash)                       
                                                                               
    with open(commit_path, 'w', encoding='utf-8') as f:                        
                                                                               
        f.write(commit_content)                                                
                                                                               
                                                                               
                                                                               
    with open(HEAD_FILE, 'w', encoding='utf-8') as f:                          
                                                                               
        f.write(commit_hash)                                                   
                                                                               
                                                                               
                                                                               
    # Clear index                                                              
                                                                               
    with open(INDEX_FILE, 'w') as f:                                           
                                                                               
        pass                                                                   
                                                                               
                                                                               
                                                                               
    print(f"Committed {commit_hash}")                                          
                                                                               
                                                                               
                                                                               
def cmd_log():                                                                 
                                                                               
    """Displays the commit history."""                                         
                                                                               
    try:                                                                       
                                                                               
        with open(HEAD_FILE, 'r') as f:                                        
                                                                               
            current_hash = f.read().strip()                                    
                                                                               
    except FileNotFoundError:                                                  
                                                                               
        print("No commits")                                                    
                                                                               
        return                                                                 
                                                                               
                                                                               
                                                                               
    if not current_hash:                                                       
                                                                               
        print("No commits")                                                    
                                                                               
        return                                                                 
                                                                               
                                                                               
                                                                               
    output_lines = []                                                          
                                                                               
    while current_hash and current_hash != "NONE":                             
                                                                               
        commit_path = os.path.join(COMMITS_DIR, current_hash)                  
                                                                               
        if not os.path.exists(commit_path):                                    
                                                                               
            break                                                              
                                                                               
                                                                               
                                                                               
        with open(commit_path, 'r', encoding='utf-8') as f:                    
                                                                               
            lines = f.readlines()                                              
                                                                               
                                                                               
                                                                               
        parent = lines[0].strip().split(' ', 1)[1]                             
                                                                               
        timestamp = lines[1].strip().split(' ', 1)[1]                          
                                                                               
        message = lines[2].strip().split(' ', 1)[1]                            
                                                                               
                                                                               
                                                                               
        output_lines.append(f"commit {current_hash}")                          
                                                                               
        output_lines.append(f"Date: {timestamp}")                              
                                                                               
        output_lines.append(f"Message: {message}")                             
                                                                               
                                                                               
                                                                               
        current_hash = parent                                                  
                                                                               
                                                                               
                                                                               
    if output_lines:                                                           
                                                                               
        print("\n".join(output_lines))                                         
                                                                               
                                                                               
                                                                               
def main():                                                                    
                                                                               
    """Main function to parse arguments and execute commands."""               
                                                                               
    if len(sys.argv) < 2:                                                      
                                                                               
        # No usage message specified in SPEC                                   
                                                                               
        return                                                                 
                                                                               
                                                                               
                                                                               
    command = sys.argv[1]                                                      
                                                                               
                                                                               
                                                                               
    if command == 'init':                                                      
                                                                               
        cmd_init()                                                             
                                                                               
    elif command == 'add':                                                     
                                                                               
        if len(sys.argv) < 3:                                                  
                                                                               
            # No error message specified in SPEC                               
                                                                               
            return                                                             
                                                                               
        cmd_add(sys.argv[2])                                                   
                                                                               
    elif command == 'commit':                                                  
                                                                               
        if len(sys.argv) < 4 or sys.argv[2] != '-m':                           
                                                                               
            # No error message specified in SPEC                               
                                                                               
            return                                                             
                                                                               
        cmd_commit(sys.argv[3])                                                
                                                                               
    elif command == 'log':                                                     
                                                                               
        cmd_log()                                                              
                                                                               
    else:                                                                      
                                                                               
        # No behavior for unknown commands specified in SPEC                   
                                                                               
        pass                                                                   
                                                                               
                                                                               
                                                                               
if __name__ == '__main__':                                                     
                                                                               
    main()                                                                     
                                                                               

