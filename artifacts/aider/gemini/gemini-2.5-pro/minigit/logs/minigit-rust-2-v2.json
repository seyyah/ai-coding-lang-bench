+fn cmd_diff(commit1_hash: &str, commit2_hash: &str) {                         
+    let files1 =                                                              
+        get_commit_files(commit1_hash).unwrap_or_else(||                      
exit_with_message("Invalid commit", 1));                                       
+    let files2 =                                                              
+        get_commit_files(commit2_hash).unwrap_or_else(||                      
exit_with_message("Invalid commit", 1));                                       
+                                                                              
+    let mut all_files: HashSet<String> = files1.keys().cloned().collect();    
+    all_files.extend(files2.keys().cloned());                                 
+                                                                              
+    let mut sorted_files: Vec<String> = all_files.into_iter().collect();      
+    sorted_files.sort();                                                      
+                                                                              
+    for filename in sorted_files {                                            
+        let hash1 = files1.get(&filename);                                    
+        let hash2 = files2.get(&filename);                                    
+                                                                              
+        match (hash1, hash2) {                                                
+            (Some(h1), Some(h2)) if h1 != h2 => println!("Modified: {}",      
filename),                                                                     
+            (None, Some(_)) => println!("Added: {}", filename),               
+            (Some(_), None) => println!("Removed: {}", filename),             
+            _ => {}                                                           
+        }                                                                     
+    }                                                                         
+}                                                                             
+                                                                              
+fn cmd_checkout(commit_hash: &str) {                                          
+    if !Path::new(COMMITS_DIR).join(commit_hash).exists() {                   
+        exit_with_message("Invalid commit", 1);                               
+    }                                                                         
+                                                                              
+    let files_in_commit = get_commit_files(commit_hash).unwrap();             
+                                                                              
+    for (filename, blob_hash) in files_in_commit {                            
+        let blob_path = Path::new(OBJECTS_DIR).join(blob_hash);               
+        let content = fs::read(blob_path).expect("Failed to read blob         
object");                                                                      
+        fs::write(filename, content).expect("Failed to write to working       
directory file");                                                              
+    }                                                                         
+                                                                              
+    write_head(commit_hash).expect("Failed to update HEAD");                  
+    clear_index().expect("Failed to clear index");                            
+                                                                              
+    println!("Checked out {}", commit_hash);                                  
+}                                                                             
+                                                                              
+fn cmd_reset(commit_hash: &str) {                                             
+    if !Path::new(COMMITS_DIR).join(commit_hash).exists() {                   
+        exit_with_message("Invalid commit", 1);                               
+    }                                                                         
+                                                                              
+    write_head(commit_hash).expect("Failed to update HEAD");                  
+    clear_index().expect("Failed to clear index");                            
+                                                                              
+    println!("Reset to {}", commit_hash);                                     
+}                                                                             
+                                                                              
+fn cmd_rm(file_path_str: &str) {                                              
+    let mut index_entries = read_index().unwrap_or_default();                 
+                                                                              
+    if let Some(pos) = index_entries.iter().position(|x| *x == file_path_str) 
{                                                                              
+        index_entries.remove(pos);                                            
+        let mut content = index_entries.join("\n");                           
+        if !index_entries.is_empty() {                                        
+            content.push('\n');                                               
+        }                                                                     
+        fs::write(INDEX_FILE, content).expect("Failed to write to index");    
+    } else {                                                                  
+        exit_with_message("File not in index", 1);                            
+    }                                                                         
+}                                                                             
+                                                                              
+fn cmd_show(commit_hash: &str) {                                              
+    if !Path::new(COMMITS_DIR).join(commit_hash).exists() {                   
+        exit_with_message("Invalid commit", 1);                               
+    }                                                                         
+                                                                              
+    let content = fs::read_to_string(Path::new(COMMITS_DIR).join(commit_hash))
+        .expect("Failed to read commit file");                                
+    let mut timestamp = "";                                                   
+    let mut message = "";                                                     
+    let mut files_section_started = false;                                    
+    let mut files = Vec::new();                                               
+                                                                              
+    for line in content.lines() {                                             
+        if let Some(t) = line.strip_prefix("timestamp: ") {                   
+            timestamp = t;                                                    
+        } else if let Some(m) = line.strip_prefix("message: ") {              
+            message = m;                                                      
+        } else if line == "files:" {                                          
+            files_section_started = true;                                     
+        } else if files_section_started {                                     
+            files.push(line.to_string());                                     
+        }                                                                     
+    }                                                                         
+                                                                              
+    println!("commit {}", commit_hash);                                       
+    println!("Date: {}", timestamp);                                          
+    println!("Message: {}", message);                                         
+    println!("Files:");                                                       
+    files.sort();                                                             
+    for file_line in files {                                                  
+        println!("  {}", file_line);                                          
+    }                                                                         
+}                                                                             
