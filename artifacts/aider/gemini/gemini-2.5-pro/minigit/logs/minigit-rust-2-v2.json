+        "add" => {                                                            
+            if args.len() < 3 {                                               
+                exit_with_message("Usage: minigit add <file>", 1);            
+            }                                                                 
+            cmd_add(&args[2]);                                                
+        }                                                                     
+        "commit" => {                                                         
+            if !(args.len() == 4 && args[2] == "-m") {                        
+                exit_with_message("Usage: minigit commit -m \"<message>\"",   
1);                                                                            
+            }                                                                 
+            cmd_commit(&args[3]);                                             
+        }                                                                     
+        "log" => cmd_log(),                                                   
+        "status" => cmd_status(),                                             
+        "diff" => {                                                           
+            if args.len() < 4 {                                               
+                exit_with_message("Usage: minigit diff <commit1> <commit2>",  
1);                                                                            
+                exit_with_message("Usage: minigit diff <commit1> <commit2>",  
1);                                                                            
+            }                                                                 
+            cmd_diff(&args[2], &args[3]);                                     
+        }                                                                     
+        "checkout" => {                                                       
+            if args.len() < 3 {                                               
+                exit_with_message("Usage: minigit checkout <commit_hash>", 1);
+            }                                                                 
+            cmd_checkout(&args[2]);                                           
+        }                                                                     
+        "reset" => {                                                          
+            if args.len() < 3 {                                               
+                exit_with_message("Usage: minigit reset <commit_hash>", 1);   
+            }                                                                 
+            cmd_reset(&args[2]);                                              
+        }                                                                     
+        "rm" => {                                                             
+            if args.len() < 3 {                                               
+                exit_with_message("Usage: minigit rm <file>", 1);             
