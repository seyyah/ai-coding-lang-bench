#!/usr/bin/env node                                                            
                                                                               
                                                                               
                                                                               
const fs = require('fs');                                                      
                                                                               
const path = require('path');                                                  
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR = '.minigit';                                                
                                                                               
const OBJECTS_DIR = path.join(MINIGIT_DIR, 'objects');                         
                                                                               
const COMMITS_DIR = path.join(MINIGIT_DIR, 'commits');                         
                                                                               
const INDEX_FILE = path.join(MINIGIT_DIR, 'index');                            
                                                                               
const HEAD_FILE = path.join(MINIGIT_DIR, 'HEAD');                              
                                                                               
                                                                               
                                                                               
function miniHash(data) {                                                      
                                                                               
    let h = 1469598103934665603n;                                              
                                                                               
    const prime = 1099511628211n;                                              
                                                                               
    const mask = 0xFFFFFFFFFFFFFFFFn;                                          
                                                                               
                                                                               
                                                                               
    const buffer = Buffer.isBuffer(data) ? data : Buffer.from(data, 'utf8');   
                                                                               
                                                                               
                                                                               
    for (const byte of buffer) {                                               
                                                                               
        h = h ^ BigInt(byte);                                                  
                                                                               
        h = (h * prime) & mask;                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    return h.toString(16).padStart(16, '0');                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function init() {                                                              
                                                                               
    if (fs.existsSync(MINIGIT_DIR)) {                                          
                                                                               
        console.log("Repository already initialized");                         
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    fs.mkdirSync(MINIGIT_DIR);                                                 
                                                                               
    fs.mkdirSync(OBJECTS_DIR);                                                 
                                                                               
    fs.mkdirSync(COMMITS_DIR);                                                 
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
    fs.writeFileSync(HEAD_FILE, '');                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function add(filePath) {                                                       
                                                                               
    if (!fs.existsSync(filePath)) {                                            
                                                                               
        console.log("File not found");                                         
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const content = fs.readFileSync(filePath);                                 
                                                                               
    const hash = miniHash(content);                                            
                                                                               
    const blobPath = path.join(OBJECTS_DIR, hash);                             
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(blobPath, content);                                       
                                                                               
                                                                               
                                                                               
    let indexContent = '';                                                     
                                                                               
    if (fs.existsSync(INDEX_FILE)) {                                           
                                                                               
        indexContent = fs.readFileSync(INDEX_FILE, 'utf8');                    
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const indexFiles = indexContent.split('\n').filter(f => f.length > 0);     
                                                                               
                                                                               
                                                                               
    if (!indexFiles.includes(filePath)) {                                      
                                                                               
        fs.appendFileSync(INDEX_FILE, filePath + '\n');                        
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function commit(message) {                                                     
                                                                               
    if (!fs.existsSync(INDEX_FILE)) {                                          
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
    const indexContent = fs.readFileSync(INDEX_FILE, 'utf8').trim();           
                                                                               
    if (indexContent.length === 0) {                                           
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const stagedFiles = indexContent.split('\n').filter(Boolean);              
                                                                               
    stagedFiles.sort();                                                        
                                                                               
                                                                               
                                                                               
    const fileEntries = stagedFiles.map(file => {                              
                                                                               
        if (!fs.existsSync(file)) {                                            
                                                                               
            // This case is not covered by tests but could happen.             
                                                                               
            // Silently ignore for now.                                        
                                                                               
            return null;                                                       
                                                                               
        }                                                                      
                                                                               
        const content = fs.readFileSync(file);                                 
                                                                               
        const hash = miniHash(content);                                        
                                                                               
        return `${file} ${hash}`;                                              
                                                                               
    }).filter(Boolean);                                                        
                                                                               
                                                                               
                                                                               
    if (fileEntries.length === 0) {                                            
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let parent = fs.readFileSync(HEAD_FILE, 'utf8').trim();                    
                                                                               
    if (parent.length === 0) {                                                 
                                                                               
        parent = 'NONE';                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const timestamp = Math.floor(Date.now() / 1000);                           
                                                                               
                                                                               
                                                                               
    const commitContent = `parent: ${parent}\n` +                              
                                                                               
                          `timestamp: ${timestamp}\n` +                        
                                                                               
                          `message: ${message}\n` +                            
                                                                               
                          `files:\n` +                                         
                                                                               
                          fileEntries.join('\n');                              
                                                                               
                                                                               
                                                                               
    const commitHash = miniHash(commitContent);                                
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(path.join(COMMITS_DIR, commitHash), commitContent);       
                                                                               
    fs.writeFileSync(HEAD_FILE, commitHash);                                   
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
                                                                               
                                                                               
    console.log(`Committed ${commitHash}`);                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
function log() {                                                               
                                                                               
    if (!fs.existsSync(HEAD_FILE)) {                                           
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
    let currentHash = fs.readFileSync(HEAD_FILE, 'utf8').trim();               
                                                                               
    if (currentHash.length === 0) {                                            
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    let isFirst = true;                                                        
                                                                               
    while (currentHash && currentHash !== 'NONE') {                            
                                                                               
        const commitPath = path.join(COMMITS_DIR, currentHash);                
                                                                               
        if (!fs.existsSync(commitPath)) {                                      
                                                                               
            break;                                                             
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        if (!isFirst) {                                                        
                                                                               
            console.log('');                                                   
                                                                               
        }                                                                      
                                                                               
        isFirst = false;                                                       
                                                                               
                                                                               
                                                                               
        const commitContent = fs.readFileSync(commitPath, 'utf8');             
                                                                               
                                                                               
                                                                               
        const lines = commitContent.split('\n');                               
                                                                               
        const parent = lines[0].substring('parent: '.length);                  
                                                                               
        const timestamp = lines[1].substring('timestamp: '.length);            
                                                                               
        const message = lines[2].substring('message: '.length);                
                                                                               
                                                                               
                                                                               
        console.log(`commit ${currentHash}`);                                  
                                                                               
        console.log(`Date: ${timestamp}`);                                     
                                                                               
        console.log(`Message: ${message}`);                                    
                                                                               
                                                                               
                                                                               
        currentHash = parent;                                                  
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
function main() {                                                              
                                                                               
    const args = process.argv.slice(2);                                        
                                                                               
    const command = args[0];                                                   
                                                                               
                                                                               
                                                                               
    try {                                                                      
                                                                               
        switch (command) {                                                     
                                                                               
            case 'init':                                                       
                                                                               
                init();                                                        
                                                                               
                break;                                                         
                                                                               
            case 'add':                                                        
                                                                               
                if (args.length < 2) {                                         
                                                                               
                    process.exit(1);                                           
                                                                               
                }                                                              
                                                                               
                add(args[1]);                                                  
                                                                               
                break;                                                         
                                                                               
            case 'commit':                                                     
                                                                               
                if (args.length < 3 || args[1] !== '-m') {                     
                                                                               
                    process.exit(1);                                           
                                                                               
                }                                                              
                                                                               
                commit(args[2]);                                               
                                                                               
                break;                                                         
                                                                               
            case 'log':                                                        
                                                                               
                log();                                                         
                                                                               
                break;                                                         
                                                                               
            default:                                                           
                                                                               
                process.exit(1);                                               
                                                                               
        }                                                                      
                                                                               
    } catch (e) {                                                              
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
main();                                                                        
                                                                               

