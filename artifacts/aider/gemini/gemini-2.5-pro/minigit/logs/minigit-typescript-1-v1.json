build.sh                                                                       

                                                                               
#!/usr/bin/env bash                                                            
                                                                               
set -e                                                                         
                                                                               
                                                                               
                                                                               
# Install dependencies quietly                                                 
                                                                               
if [ -f package.json ]; then                                                   
                                                                               
    if command -v npm &> /dev/null; then                                       
                                                                               
        npm install --silent > /dev/null 2>&1                                  
                                                                               
    else                                                                       
                                                                               
        echo "npm not found. Please install Node.js and npm."                  
                                                                               
        exit 1                                                                 
                                                                               
    fi                                                                         
                                                                               
fi                                                                             
                                                                               
                                                                               
                                                                               
# Compile TypeScript                                                           
                                                                               
if [ -f tsconfig.json ] && [ -f minigit.ts ]; then                             
                                                                               
    if [ -f ./node_modules/.bin/tsc ]; then                                    
                                                                               
        ./node_modules/.bin/tsc                                                
                                                                               
    else                                                                       
                                                                               
        echo "TypeScript compiler (tsc) not found. Run 'npm install' first."   
                                                                               
        exit 1                                                                 
                                                                               
    fi                                                                         
                                                                               
else                                                                           
                                                                               
    echo "Missing tsconfig.json or minigit.ts"                                 
                                                                               
    exit 1                                                                     
                                                                               
fi                                                                             
                                                                               
                                                                               
                                                                               
# Create the executable file                                                   
                                                                               
if [ -f dist/minigit.js ]; then                                                
                                                                               
    echo '#!/usr/bin/env node' > minigit                                       
                                                                               
    cat dist/minigit.js >> minigit                                             
                                                                               
    chmod +x minigit                                                           
                                                                               
else                                                                           
                                                                               
    echo "Build failed: dist/minigit.js not found."                            
                                                                               
    exit 1                                                                     
                                                                               
fi                                                                             
                                                                               

minigit.ts                                                                     

                                                                               
import * as fs from 'fs';                                                      
                                                                               
import * as path from 'path';                                                  
                                                                               
                                                                               
                                                                               
const MINIGIT_DIR = '.minigit';                                                
                                                                               
const OBJECTS_DIR = path.join(MINIGIT_DIR, 'objects');                         
                                                                               
const COMMITS_DIR = path.join(MINIGIT_DIR, 'commits');                         
                                                                               
const INDEX_FILE = path.join(MINIGIT_DIR, 'index');                            
                                                                               
const HEAD_FILE = path.join(MINIGIT_DIR, 'HEAD');                              
                                                                               
                                                                               
                                                                               
function miniHash(data: Buffer): string {                                      
                                                                               
    let h = 1469598103934665603n;                                              
                                                                               
    const MASK = 0xFFFFFFFFFFFFFFFFn;                                          
                                                                               
    const PRIME = 1099511628211n;                                              
                                                                               
                                                                               
                                                                               
    for (const byte of data) {                                                 
                                                                               
        h = h ^ BigInt(byte);                                                  
                                                                               
        h = (h * PRIME) & MASK;                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    return h.toString(16).padStart(16, '0');                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function init() {                                                              
                                                                               
    if (fs.existsSync(MINIGIT_DIR)) {                                          
                                                                               
        console.log("Repository already initialized");                         
                                                                               
        process.exit(0);                                                       
                                                                               
    }                                                                          
                                                                               
    fs.mkdirSync(MINIGIT_DIR);                                                 
                                                                               
    fs.mkdirSync(OBJECTS_DIR);                                                 
                                                                               
    fs.mkdirSync(COMMITS_DIR);                                                 
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
    fs.writeFileSync(HEAD_FILE, '');                                           
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function add(file: string) {                                                   
                                                                               
    if (!fs.existsSync(file)) {                                                
                                                                               
        console.log("File not found");                                         
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const content = fs.readFileSync(file);                                     
                                                                               
    const hash = miniHash(content);                                            
                                                                               
                                                                               
                                                                               
    const blobPath = path.join(OBJECTS_DIR, hash);                             
                                                                               
    if (!fs.existsSync(blobPath)) {                                            
                                                                               
        fs.writeFileSync(blobPath, content);                                   
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const indexContentRaw = fs.readFileSync(INDEX_FILE, 'utf-8');              
                                                                               
    const indexContent = indexContentRaw.split('\n').filter(line => line.length
> 0);                                                                          
                                                                               
                                                                               
                                                                               
    if (!indexContent.includes(file)) {                                        
                                                                               
        indexContent.push(file);                                               
                                                                               
        fs.writeFileSync(INDEX_FILE, indexContent.join('\n') + '\n');          
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function commit(message: string) {                                             
                                                                               
    const indexContent = fs.readFileSync(INDEX_FILE, 'utf-8').trim();          
                                                                               
    if (!indexContent) {                                                       
                                                                               
        console.log("Nothing to commit");                                      
                                                                               
        process.exit(1);                                                       
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    const stagedFiles = indexContent.split('\n').filter(Boolean);              
                                                                               
    stagedFiles.sort();                                                        
                                                                               
                                                                               
                                                                               
    const parentHash = fs.readFileSync(HEAD_FILE, 'utf-8').trim() || 'NONE';   
                                                                               
    const timestamp = Math.floor(Date.now() / 1000);                           
                                                                               
                                                                               
                                                                               
    const filesList = stagedFiles.map(file => {                                
                                                                               
        const content = fs.readFileSync(file);                                 
                                                                               
        const hash = miniHash(content);                                        
                                                                               
        return `${file} ${hash}`;                                              
                                                                               
    }).join('\n');                                                             
                                                                               
                                                                               
                                                                               
    const commitContentStr = `parent: ${parentHash}\n` +                       
                                                                               
                             `timestamp: ${timestamp}\n` +                     
                                                                               
                             `message: ${message}\n` +                         
                                                                               
                             `files:\n` +                                      
                                                                               
                             `${filesList}`;                                   
                                                                               
                                                                               
                                                                               
    const commitContent = Buffer.from(commitContentStr, 'utf-8');              
                                                                               
    const commitHash = miniHash(commitContent);                                
                                                                               
                                                                               
                                                                               
    fs.writeFileSync(path.join(COMMITS_DIR, commitHash), commitContent);       
                                                                               
    fs.writeFileSync(HEAD_FILE, commitHash);                                   
                                                                               
    fs.writeFileSync(INDEX_FILE, '');                                          
                                                                               
                                                                               
                                                                               
    console.log(`Committed ${commitHash}`);                                    
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function log() {                                                               
                                                                               
    let currentHash = fs.readFileSync(HEAD_FILE, 'utf-8').trim();              
                                                                               
                                                                               
                                                                               
    if (!currentHash) {                                                        
                                                                               
        console.log("No commits");                                             
                                                                               
        return;                                                                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    while (currentHash && currentHash !== 'NONE') {                            
                                                                               
        const commitPath = path.join(COMMITS_DIR, currentHash);                
                                                                               
        if (!fs.existsSync(commitPath)) {                                      
                                                                               
             break;                                                            
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        const commitContent = fs.readFileSync(commitPath, 'utf-8');            
                                                                               
        const lines = commitContent.split('\n');                               
                                                                               
                                                                               
                                                                               
        const parentLine = lines.find(l => l.startsWith('parent: '));          
                                                                               
        const timestampLine = lines.find(l => l.startsWith('timestamp: '));    
                                                                               
        const messageLine = lines.find(l => l.startsWith('message: '));        
                                                                               
                                                                               
                                                                               
        const parent = parentLine ? parentLine.substring('parent: '.length) :  
'NONE';                                                                        
                                                                               
        const timestamp = timestampLine ? timestampLine.substring('timestamp:  
'.length) : '';                                                                
                                                                               
        const message = messageLine ? messageLine.substring('message: '.length)
: '';                                                                          
                                                                               
                                                                               
                                                                               
        console.log(`commit ${currentHash}`);                                  
                                                                               
        console.log(`Date: ${timestamp}`);                                     
                                                                               
        console.log(`Message: ${message}`);                                    
                                                                               
                                                                               
                                                                               
        currentHash = parent;                                                  
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
function main() {                                                              
                                                                               
    const args = process.argv.slice(2);                                        
                                                                               
    const command = args[0];                                                   
                                                                               
                                                                               
                                                                               
    switch (command) {                                                         
                                                                               
        case 'init':                                                           
                                                                               
            init();                                                            
                                                                               
            break;                                                             
                                                                               
        case 'add':                                                            
                                                                               
            if (args.length < 2) {                                             
                                                                               
                console.error("Usage: minigit add <file>");                    
                                                                               
                process.exit(1);                                               
                                                                               
            }                                                                  
                                                                               
            add(args[1]);                                                      
                                                                               
            break;                                                             
                                                                               
        case 'commit':                                                         
                                                                               
            if (args.length < 3 || args[1] !== '-m') {                         
                                                                               
                console.error('Usage: minigit commit -m "<message>"');         
                                                                               
                process.exit(1);                                               
                                                                               
            }                                                                  
                                                                               
            commit(args[2]);                                                   
                                                                               
            break;                                                             
                                                                               
        case 'log':                                                            
                                                                               
            log();                                                             
                                                                               
            break;                                                             
                                                                               
        default:                                                               
                                                                               
            console.error(`Unknown command: ${command || 'no command'}`);      
                                                                               
            process.exit(1);                                                   
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
main();                                                                        
                                                                               

