#!/usr/bin/env lua                                                             
                                                                               
                                                                               
                                                                               
-- Dosya sistemi yardımcı fonksiyonları                                        
                                                                               
local lfs = {}                                                                 
                                                                               
                                                                               
                                                                               
function lfs.exists(path)                                                      
                                                                               
    local f = io.open(path, "r")                                               
                                                                               
    if f then                                                                  
                                                                               
        f:close()                                                              
                                                                               
        return true                                                            
                                                                               
    end                                                                        
                                                                               
    return false                                                               
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function lfs.mkdir_p(path)                                                     
                                                                               
    os.execute("mkdir -p " .. path)                                            
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function lfs.write_file(path, content)                                         
                                                                               
    local f = assert(io.open(path, "wb"))                                      
                                                                               
    f:write(content)                                                           
                                                                               
    f:close()                                                                  
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function lfs.read_file(path)                                                   
                                                                               
    local f = io.open(path, "rb")                                              
                                                                               
    if not f then return nil end                                               
                                                                               
    local content = f:read("*a")                                               
                                                                               
    f:close()                                                                  
                                                                               
    return content                                                             
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function lfs.read_lines(path)                                                  
                                                                               
    local lines = {}                                                           
                                                                               
    local content = lfs.read_file(path)                                        
                                                                               
    if not content or content == "" then return lines end                      
                                                                               
    for line in string.gmatch(content, "[^\r\n]+") do                          
                                                                               
        table.insert(lines, line)                                              
                                                                               
    end                                                                        
                                                                               
    return lines                                                               
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
-- MiniHash implementasyonu                                                    
                                                                               
local MASK32 = 0xFFFFFFFF                                                      
                                                                               
                                                                               
                                                                               
local function mul64(a, b)                                                     
                                                                               
    local a_lo = a & MASK32                                                    
                                                                               
    local a_hi = a >> 32                                                       
                                                                               
    local b_lo = b & MASK32                                                    
                                                                               
    local b_hi = b >> 32                                                       
                                                                               
                                                                               
                                                                               
    local lo_prod = a_lo * b_lo                                                
                                                                               
    local mid_prod1 = a_lo * b_hi                                              
                                                                               
    local mid_prod2 = a_hi * b_lo                                              
                                                                               
                                                                               
                                                                               
    local carry = lo_prod >> 32                                                
                                                                               
                                                                               
                                                                               
    local mid_sum = (mid_prod1 & MASK32) + (mid_prod2 & MASK32) + carry        
                                                                               
                                                                               
                                                                               
    local res_lo = lo_prod & MASK32                                            
                                                                               
    local res_hi = mid_sum & MASK32                                            
                                                                               
                                                                               
                                                                               
    return (res_hi << 32) | res_lo                                             
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
local function minihash(data)                                                  
                                                                               
    local h = 1469598103934665603                                              
                                                                               
    local P = 1099511628211                                                    
                                                                               
    for i = 1, #data do                                                        
                                                                               
        local byte = string.byte(data, i)                                      
                                                                               
        h = h ~ byte                                                           
                                                                               
        h = mul64(h, P)                                                        
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local hi = (h >> 32) & MASK32                                              
                                                                               
    local lo = h & MASK32                                                      
                                                                               
    return string.format("%08x%08x", hi, lo)                                   
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
-- Sabitler                                                                    
                                                                               
local MINIGIT_DIR = ".minigit"                                                 
                                                                               
local OBJECTS_DIR = MINIGIT_DIR .. "/objects"                                  
                                                                               
local COMMITS_DIR = MINIGIT_DIR .. "/commits"                                  
                                                                               
local INDEX_FILE = MINIGIT_DIR .. "/index"                                     
                                                                               
local HEAD_FILE = MINIGIT_DIR .. "/HEAD"                                       
                                                                               
                                                                               
                                                                               
-- Komut implementasyonları                                                    
                                                                               
function cmd_init()                                                            
                                                                               
    if lfs.exists(INDEX_FILE) then                                             
                                                                               
        print("Repository already initialized")                                
                                                                               
        return                                                                 
                                                                               
    end                                                                        
                                                                               
    lfs.mkdir_p(OBJECTS_DIR)                                                   
                                                                               
    lfs.mkdir_p(COMMITS_DIR)                                                   
                                                                               
    lfs.write_file(INDEX_FILE, "")                                             
                                                                               
    lfs.write_file(HEAD_FILE, "")                                              
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_add(filename)                                                     
                                                                               
    if not filename then                                                       
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
    if not lfs.exists(filename) then                                           
                                                                               
        print("File not found")                                                
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local content = lfs.read_file(filename)                                    
                                                                               
    local hash = minihash(content)                                             
                                                                               
                                                                               
                                                                               
    lfs.write_file(OBJECTS_DIR .. "/" .. hash, content)                        
                                                                               
                                                                               
                                                                               
    local index_entries = lfs.read_lines(INDEX_FILE)                           
                                                                               
    local found = false                                                        
                                                                               
    for _, entry in ipairs(index_entries) do                                   
                                                                               
        if entry == filename then                                              
                                                                               
            found = true                                                       
                                                                               
            break                                                              
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    if not found then                                                          
                                                                               
        table.insert(index_entries, filename)                                  
                                                                               
        lfs.write_file(INDEX_FILE, table.concat(index_entries, "\n") .. "\n")  
                                                                               
    end                                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
function cmd_commit(message)                                                   
                                                                               
    local index_entries = lfs.read_lines(INDEX_FILE)                           
                                                                               
    if #index_entries == 0 then                                                
                                                                               
        print("Nothing to commit")                                             
                                                                               
        os.exit(1)                                                             
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local parent = lfs.read_file(HEAD_FILE)                                    
                                                                               
    if parent == "" or parent == nil then                                      
                                                                               
        parent = "NONE"                                                        
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local timestamp = os.time()                                                
                                                                               
                                                                               
                                                                               
    local files_info = {}                                                      
                                                                               
    for _, filename in ipairs(index_entries) do                                
                                                                               
        local content = lfs.read_file(filename)                                
                                                                               
        if content then                                                        
                                                                               
            local hash = minihash(content)                                     
                                                                               
            table.insert(files_info, {name=filename, hash=hash})               
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    table.sort(files_info, function(a, b) return a.name < b.name end)          
                                                                               
                                                                               
                                                                               
    local commit_content_parts = {}                                            
                                                                               
    table.insert(commit_content_parts, "parent: " .. parent)                   
                                                                               
    table.insert(commit_content_parts, "timestamp: " .. tostring(timestamp))   
                                                                               
    table.insert(commit_content_parts, "message: " .. message)                 
                                                                               
    table.insert(commit_content_parts, "files:")                               
                                                                               
    for _, info in ipairs(files_info) do                                       
                                                                               
        table.insert(commit_content_parts, info.name .. " " .. info.hash)      
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local commit_content = table.concat(commit_content_parts, "\n") .. "\n"    
                                                                               
                                                                               
                                                                               
    local commit_hash = minihash(commit_content)                               
                                                                               
                                                                               
                                                                               
    lfs.write_file(COMMITS_DIR .. "/" .. commit_hash, commit_content)          
                                                                               
    lfs.write_file(HEAD_FILE, commit_hash)                                     
                                                                               
    lfs.write_file(INDEX_FILE, "") -- clear index                              
                                                                               
                                                                               
                                                                               
    print("Committed " .. commit_hash)                                         
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
function cmd_log()                                                             
                                                                               
    local head = lfs.read_file(HEAD_FILE)                                      
                                                                               
    if head == "" or head == nil or head == "NONE" then                        
                                                                               
        print("No commits")                                                    
                                                                               
        return                                                                 
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
    local current_hash = head                                                  
                                                                               
    while current_hash ~= "NONE" and current_hash ~= "" and current_hash ~= nil
do                                                                             
                                                                               
        local commit_path = COMMITS_DIR .. "/" .. current_hash                 
                                                                               
        if not lfs.exists(commit_path) then                                    
                                                                               
            break                                                              
                                                                               
        end                                                                    
                                                                               
        local content = lfs.read_file(commit_path)                             
                                                                               
                                                                               
                                                                               
        local parent = string.match(content, "parent: ([^\n\r]+)")             
                                                                               
        local timestamp = string.match(content, "timestamp: ([^\n\r]+)")       
                                                                               
        local message = string.match(content, "message: ([^\n\r]+)")           
                                                                               
                                                                               
                                                                               
        print("commit " .. current_hash)                                       
                                                                               
        print("Date: " .. timestamp)                                           
                                                                               
        print("Message: " .. message)                                          
                                                                               
                                                                               
                                                                               
        current_hash = parent                                                  
                                                                               
        if current_hash and current_hash ~= "NONE" then                        
                                                                               
            print("")                                                          
                                                                               
        end                                                                    
                                                                               
    end                                                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
                                                                               
                                                                               
-- Ana yönlendirme                                                             
                                                                               
local args = arg or {}                                                         
                                                                               
                                                                               
                                                                               
if #args == 0 then                                                             
                                                                               
    os.exit(1)                                                                 
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
local command = args[1]                                                        
                                                                               
                                                                               
                                                                               
if command == "init" then                                                      
                                                                               
    cmd_init()                                                                 
                                                                               
elseif command == "add" and args[2] then                                       
                                                                               
    cmd_add(args[2])                                                           
                                                                               
elseif command == "commit" and args[2] == "-m" and args[3] then                
                                                                               
    cmd_commit(args[3])                                                        
                                                                               
elseif command == "log" then                                                   
                                                                               
    cmd_log()                                                                  
                                                                               
else                                                                           
                                                                               
    os.exit(1)                                                                 
                                                                               
end                                                                            
                                                                               

