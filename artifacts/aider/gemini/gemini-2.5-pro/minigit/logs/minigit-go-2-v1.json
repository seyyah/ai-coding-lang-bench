minigit.go                                                                     

                                                                               
package main                                                                   
                                                                               
                                                                               
                                                                               
import (                                                                       
                                                                               
    "bufio"                                                                    
                                                                               
    "fmt"                                                                      
                                                                               
    "io/ioutil"                                                                
                                                                               
    "log"                                                                      
                                                                               
    "os"                                                                       
                                                                               
    "path/filepath"                                                            
                                                                               
    "sort"                                                                     
                                                                               
    "strconv"                                                                  
                                                                               
    "strings"                                                                  
                                                                               
    "time"                                                                     
                                                                               
)                                                                              
                                                                               
                                                                               
                                                                               
// miniHash implements the custom MiniHash algorithm.                          
                                                                               
func miniHash(data []byte) string {                                            
                                                                               
    var h uint64 = 1469598103934665603                                         
                                                                               
    const prime uint64 = 1099511628211                                         
                                                                               
                                                                               
                                                                               
    for _, b := range data {                                                   
                                                                               
        h ^= uint64(b)                                                         
                                                                               
        h *= prime                                                             
                                                                               
    }                                                                          
                                                                               
    return fmt.Sprintf("%016x", h)                                             
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// handleInit implements the 'init' command.                                   
                                                                               
func handleInit() {                                                            
                                                                               
    if _, err := os.Stat(".minigit"); err == nil {                             
                                                                               
        fmt.Println("Repository already initialized")                          
                                                                               
        return                                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    dirs := []string{".minigit", ".minigit/objects", ".minigit/commits"}       
                                                                               
    for _, dir := range dirs {                                                 
                                                                               
        if err := os.Mkdir(dir, 0755); err != nil {                            
                                                                               
            log.Fatalf("Failed to create directory %s: %v", dir, err)          
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    files := []string{".minigit/index", ".minigit/HEAD"}                       
                                                                               
    for _, file := range files {                                               
                                                                               
        if f, err := os.Create(file); err != nil {                             
                                                                               
            log.Fatalf("Failed to create file %s: %v", file, err)              
                                                                               
        } else {                                                               
                                                                               
            f.Close()                                                          
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// handleAdd implements the 'add' command.                                     
                                                                               
func handleAdd(filename string) {                                              
                                                                               
    content, err := ioutil.ReadFile(filename)                                  
                                                                               
    if err != nil {                                                            
                                                                               
        if os.IsNotExist(err) {                                                
                                                                               
            fmt.Println("File not found")                                      
                                                                               
            os.Exit(1)                                                         
                                                                               
        }                                                                      
                                                                               
        log.Fatalf("Failed to read file %s: %v", filename, err)                
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    hash := miniHash(content)                                                  
                                                                               
    objectPath := filepath.Join(".minigit", "objects", hash)                   
                                                                               
    if err := ioutil.WriteFile(objectPath, content, 0644); err != nil {        
                                                                               
        log.Fatalf("Failed to write object file: %v", err)                     
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    indexPath := filepath.Join(".minigit", "index")                            
                                                                               
    indexContent, err := ioutil.ReadFile(indexPath)                            
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read index: %v", err)                            
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    stagedFiles := make(map[string]bool)                                       
                                                                               
    scanner := bufio.NewScanner(strings.NewReader(string(indexContent)))       
                                                                               
    for scanner.Scan() {                                                       
                                                                               
        line := scanner.Text()                                                 
                                                                               
        if line != "" {                                                        
                                                                               
            stagedFiles[line] = true                                           
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if !stagedFiles[filename] {                                                
                                                                               
        f, err := os.OpenFile(indexPath, os.O_APPEND|os.O_CREATE|os.O_WRONLY,  
0644)                                                                          
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to open index for writing: %v", err)            
                                                                               
        }                                                                      
                                                                               
        defer f.Close()                                                        
                                                                               
        if _, err := fmt.Fprintln(f, filename); err != nil {                   
                                                                               
            log.Fatalf("Failed to write to index: %v", err)                    
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// handleCommit implements the 'commit' command.                               
                                                                               
func handleCommit(message string) {                                            
                                                                               
    indexPath := filepath.Join(".minigit", "index")                            
                                                                               
    indexContent, err := ioutil.ReadFile(indexPath)                            
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read index: %v", err)                            
                                                                               
    }                                                                          
                                                                               
    if strings.TrimSpace(string(indexContent)) == "" {                         
                                                                               
        fmt.Println("Nothing to commit")                                       
                                                                               
        os.Exit(1)                                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    headPath := filepath.Join(".minigit", "HEAD")                              
                                                                               
    parentHashBytes, err := ioutil.ReadFile(headPath)                          
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read HEAD: %v", err)                             
                                                                               
    }                                                                          
                                                                               
    parentHash := strings.TrimSpace(string(parentHashBytes))                   
                                                                               
    if parentHash == "" {                                                      
                                                                               
        parentHash = "NONE"                                                    
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    timestamp := time.Now().Unix()                                             
                                                                               
                                                                               
                                                                               
    var filenames []string                                                     
                                                                               
    scanner := bufio.NewScanner(strings.NewReader(string(indexContent)))       
                                                                               
    for scanner.Scan() {                                                       
                                                                               
        line := scanner.Text()                                                 
                                                                               
        if line != "" {                                                        
                                                                               
            filenames = append(filenames, line)                                
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
    sort.Strings(filenames)                                                    
                                                                               
                                                                               
                                                                               
    var fileEntries []string                                                   
                                                                               
    for _, filename := range filenames {                                       
                                                                               
        content, err := ioutil.ReadFile(filename)                              
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to read file %s for commit: %v", filename, err) 
                                                                               
        }                                                                      
                                                                               
        hash := miniHash(content)                                              
                                                                               
        fileEntries = append(fileEntries, fmt.Sprintf("%s %s", filename, hash))
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    var commitBuilder strings.Builder                                          
                                                                               
    fmt.Fprintf(&commitBuilder, "parent: %s\n", parentHash)                    
                                                                               
    fmt.Fprintf(&commitBuilder, "timestamp: %d\n", timestamp)                  
                                                                               
    fmt.Fprintf(&commitBuilder, "message: %s\n", message)                      
                                                                               
    fmt.Fprintf(&commitBuilder, "files:\n")                                    
                                                                               
    fmt.Fprintf(&commitBuilder, "%s", strings.Join(fileEntries, "\n"))         
                                                                               
    if len(fileEntries) > 0 {                                                  
                                                                               
        fmt.Fprintln(&commitBuilder)                                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    commitContent := commitBuilder.String()                                    
                                                                               
    commitHash := miniHash([]byte(commitContent))                              
                                                                               
                                                                               
                                                                               
    commitPath := filepath.Join(".minigit", "commits", commitHash)             
                                                                               
    if err := ioutil.WriteFile(commitPath, []byte(commitContent), 0644); err !=
nil {                                                                          
                                                                               
        log.Fatalf("Failed to write commit object: %v", err)                   
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if err := ioutil.WriteFile(headPath, []byte(commitHash), 0644); err != nil 
{                                                                              
                                                                               
        log.Fatalf("Failed to update HEAD: %v", err)                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    if err := os.Truncate(indexPath, 0); err != nil {                          
                                                                               
        log.Fatalf("Failed to clear index: %v", err)                           
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    fmt.Printf("Committed %s\n", commitHash)                                   
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// parseCommit extracts metadata from commit file content.                     
                                                                               
func parseCommit(content string) (parent, message string, timestamp int64) {   
                                                                               
    scanner := bufio.NewScanner(strings.NewReader(content))                    
                                                                               
    for scanner.Scan() {                                                       
                                                                               
        line := scanner.Text()                                                 
                                                                               
        if strings.HasPrefix(line, "parent: ") {                               
                                                                               
            parent = strings.TrimPrefix(line, "parent: ")                      
                                                                               
        } else if strings.HasPrefix(line, "timestamp: ") {                     
                                                                               
            tsStr := strings.TrimPrefix(line, "timestamp: ")                   
                                                                               
            var err error                                                      
                                                                               
            timestamp, err = strconv.ParseInt(tsStr, 10, 64)                   
                                                                               
            if err != nil {                                                    
                                                                               
                log.Fatalf("Failed to parse timestamp in commit: %v", err)     
                                                                               
            }                                                                  
                                                                               
        } else if strings.HasPrefix(line, "message: ") {                       
                                                                               
            message = strings.TrimPrefix(line, "message: ")                    
                                                                               
        } else if line == "files:" {                                           
                                                                               
            break                                                              
                                                                               
        }                                                                      
                                                                               
    }                                                                          
                                                                               
    return                                                                     
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
// handleLog implements the 'log' command.                                     
                                                                               
func handleLog() {                                                             
                                                                               
    headPath := filepath.Join(".minigit", "HEAD")                              
                                                                               
    currentHashBytes, err := ioutil.ReadFile(headPath)                         
                                                                               
    if err != nil {                                                            
                                                                               
        log.Fatalf("Failed to read HEAD: %v", err)                             
                                                                               
    }                                                                          
                                                                               
    currentHash := strings.TrimSpace(string(currentHashBytes))                 
                                                                               
                                                                               
                                                                               
    if currentHash == "" {                                                     
                                                                               
        fmt.Println("No commits")                                              
                                                                               
        return                                                                 
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    for currentHash != "NONE" && currentHash != "" {                           
                                                                               
        commitPath := filepath.Join(".minigit", "commits", currentHash)        
                                                                               
        commitContentBytes, err := ioutil.ReadFile(commitPath)                 
                                                                               
        if err != nil {                                                        
                                                                               
            log.Fatalf("Failed to read commit object %s: %v", currentHash, err)
                                                                               
        }                                                                      
                                                                               
                                                                               
                                                                               
        parentHash, message, timestamp :=                                      
parseCommit(string(commitContentBytes))                                        
                                                                               
                                                                               
                                                                               
        fmt.Printf("commit %s\n", currentHash)                                 
                                                                               
        fmt.Printf("Date: %d\n", timestamp)                                    
                                                                               
        fmt.Printf("Message: %s\n", message)                                   
                                                                               
                                                                               
                                                                               
        currentHash = parentHash                                               
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               
                                                                               
                                                                               
func main() {                                                                  
                                                                               
    log.SetFlags(0)                                                            
                                                                               
    if len(os.Args) < 2 {                                                      
                                                                               
        fmt.Fprintln(os.Stderr, "Usage: minigit <command> [<args>]")           
                                                                               
        os.Exit(1)                                                             
                                                                               
    }                                                                          
                                                                               
                                                                               
                                                                               
    command := os.Args[1]                                                      
                                                                               
    switch command {                                                           
                                                                               
    case "init":                                                               
                                                                               
        handleInit()                                                           
                                                                               
    case "add":                                                                
                                                                               
        if len(os.Args) < 3 {                                                  
                                                                               
            fmt.Fprintln(os.Stderr, "Usage: minigit add <file>")               
                                                                               
            os.Exit(1)                                                         
                                                                               
        }                                                                      
                                                                               
        handleAdd(os.Args[2])                                                  
                                                                               
    case "commit":                                                             
                                                                               
        if len(os.Args) < 4 || os.Args[2] != "-m" {                            
                                                                               
            fmt.Fprintln(os.Stderr, "Usage: minigit commit -m \"<message>\"")  
                                                                               
            os.Exit(1)                                                         
                                                                               
        }                                                                      
                                                                               
        handleCommit(os.Args[3])                                               
                                                                               
    case "log":                                                                
                                                                               
        handleLog()                                                            
                                                                               
    default:                                                                   
                                                                               
        fmt.Fprintf(os.Stderr, "Unknown command: %s\n", command)               
                                                                               
        os.Exit(1)                                                             
                                                                               
    }                                                                          
                                                                               
}                                                                              
                                                                               

