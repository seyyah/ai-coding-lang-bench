+                                                                              
+sub cmd_status {                                                              
+    open my $idx_fh, '<', INDEX_FILE or die "Cannot read index: $!";          
+    my @files = <$idx_fh>;                                                    
+    close $idx_fh;                                                            
+    chomp @files;                                                             
+                                                                              
+    print "Staged files:\n";                                                  
+    if (scalar @files > 0) {                                                  
+        foreach my $file (sort @files) {                                      
+            print "$file\n";                                                  
+        }                                                                     
+    } else {                                                                  
+        print "(none)\n";                                                     
+    }                                                                         
+    exit 0;                                                                   
+}                                                                             
+                                                                              
+sub read_commit_files {                                                       
+    my ($commit_hash) = @_;                                                   
+    my $commit_path = COMMITS_DIR . "/$commit_hash";                          
+    unless (-f $commit_path) {                                                
+        print "Invalid commit\n";                                             
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    open my $commit_fh, '<', $commit_path or die "Cannot read commit          
$commit_hash: $!";                                                             
+    my $content = do { local $/; <$commit_fh> };                              
+    close $commit_fh;                                                         
+                                                                              
+    my ($files_section) = $content =~ /files:\n(.*)/s;                        
+    my %files;                                                                
+    if (defined $files_section) {                                             
+        for my $line (split /\n/, $files_section) {                           
+            next if $line =~ /^\s*$/;                                         
+            my ($filename, $blob_hash) = split ' ', $line, 2;                 
+            $files{$filename} = $blob_hash;                                   
+        }                                                                     
+    }                                                                         
+    return \%files;                                                           
+}                                                                             
+                                                                              
+sub cmd_diff {                                                                
+    my ($commit1_hash, $commit2_hash) = @_;                                   
+                                                                              
+    unless (defined $commit1_hash && defined $commit2_hash) {                 
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    my $files1 = read_commit_files($commit1_hash);                            
+    my $files2 = read_commit_files($commit2_hash);                            
+                                                                              
+    my %all_files;                                                            
+    @all_files{keys %$files1} = ();                                           
+    @all_files{keys %$files2} = ();                                           
+                                                                              
+    for my $file (sort keys %all_files) {                                     
+        my $hash1 = $files1->{$file};                                         
+        my $hash2 = $files2->{$file};                                         
+                                                                              
+        if (defined $hash1 && !defined $hash2) {                              
+            print "Removed: $file\n";                                         
+        } elsif (!defined $hash1 && defined $hash2) {                         
+            print "Added: $file\n";                                           
+        } elsif (defined $hash1 && defined $hash2 && $hash1 ne $hash2) {      
+            print "Modified: $file\n";                                        
+        }                                                                     
+    }                                                                         
+    exit 0;                                                                   
+}                                                                             
+                                                                              
+sub cmd_checkout {                                                            
+    my ($commit_hash) = @_;                                                   
+                                                                              
+    unless (defined $commit_hash) {                                           
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    my $files_map = read_commit_files($commit_hash);                          
+                                                                              
+    for my $filename (keys %$files_map) {                                     
+        my $blob_hash = $files_map->{$filename};                              
+                                                                              
+        my $blob_path = OBJECTS_DIR . "/$blob_hash";                          
+        open my $blob_fh, '<:raw', $blob_path or die "Cannot read blob        
$blob_hash: $!";                                                               
+        my $blob_content = do { local $/; <$blob_fh> };                       
+        close $blob_fh;                                                       
+                                                                              
+        open my $file_fh, '>:raw', $filename or die "Cannot write to file     
$filename: $!";                                                                
+        print $file_fh $blob_content;                                         
+        close $file_fh;                                                       
+    }                                                                         
+                                                                              
+    open my $head_fh, '>', HEAD_FILE or die "Cannot write to HEAD: $!";       
+    print $head_fh "$commit_hash\n";                                          
+    close $head_fh;                                                           
+                                                                              
+    open my $idx_fh, '>', INDEX_FILE or die "Cannot clear index: $!";         
+    close $idx_fh;                                                            
+                                                                              
+    print "Checked out $commit_hash\n";                                       
+    exit 0;                                                                   
+}                                                                             
+                                                                              
+sub cmd_reset {                                                               
+    my ($commit_hash) = @_;                                                   
+                                                                              
+    unless (defined $commit_hash) {                                           
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    my $commit_path = COMMITS_DIR . "/$commit_hash";                          
+    unless (-f $commit_path) {                                                
+        print "Invalid commit\n";                                             
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    open my $head_fh, '>', HEAD_FILE or die "Cannot write to HEAD: $!";       
+    print $head_fh "$commit_hash\n";                                          
+    close $head_fh;                                                           
+                                                                              
+    open my $idx_fh, '>', INDEX_FILE or die "Cannot clear index: $!";         
+    close $idx_fh;                                                            
+                                                                              
+    print "Reset to $commit_hash\n";                                          
+    exit 0;                                                                   
+}                                                                             
+                                                                              
+sub cmd_rm {                                                                  
+    my ($file_to_remove) = @_;                                                
+                                                                              
+    unless (defined $file_to_remove) {                                        
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    open my $idx_fh, '<', INDEX_FILE or die "Cannot read index: $!";          
+    my @lines = <$idx_fh>;                                                    
+    close $idx_fh;                                                            
+    chomp @lines;                                                             
+                                                                              
+    my $found = 0;                                                            
+    my @new_lines;                                                            
+    for my $line (@lines) {                                                   
+        if ($line eq $file_to_remove) {                                       
+            $found = 1;                                                       
+        } else {                                                              
+            push @new_lines, $line;                                           
+        }                                                                     
+    }                                                                         
+                                                                              
+    unless ($found) {                                                         
+        print "File not in index\n";                                          
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    open my $new_idx_fh, '>', INDEX_FILE or die "Cannot write to index: $!";  
+    foreach my $line (@new_lines) {                                           
+        print $new_idx_fh "$line\n";                                          
+    }                                                                         
+    close $new_idx_fh;                                                        
+                                                                              
+    exit 0;                                                                   
+}                                                                             
+                                                                              
+sub cmd_show {                                                                
+    my ($commit_hash) = @_;                                                   
+                                                                              
+    unless (defined $commit_hash) {                                           
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    my $commit_path = COMMITS_DIR . "/$commit_hash";                          
+    unless (-f $commit_path) {                                                
+        print "Invalid commit\n";                                             
+        exit 1;                                                               
+    }                                                                         
+                                                                              
+    open my $commit_fh, '<', $commit_path or die "Cannot read commit          
$commit_hash: $!";                                                             
+    my $content = do { local $/; <$commit_fh> };                              
+    close $commit_fh;                                                         
+                                                                              
+    my ($timestamp) = $content =~ /^timestamp: (.*)$/m;                       
+    my ($message) = $content =~ /^message: (.*)$/m;                           
+    my ($files_section) = $content =~ /files:\n(.*)/s;                        
+                                                                              
+    print "commit $commit_hash\n";                                            
+    print "Date: $timestamp\n";                                               
+    print "Message: $message\n";                                              
+                                                                              
+    if (defined $files_section) {                                             
+        print "Files:\n";                                                     
+                                                                              
+        my @file_lines;                                                       
+        for my $line (split /\n/, $files_section) {                           
+            next if $line =~ /^\s*$/;                                         
+            push @file_lines, $line;                                          
+        }                                                                     
+                                                                              
+        for my $line (sort @file_lines) {                                     
+            print "  $line\n";                                                
+        }                                                                     
+    }                                                                         
+                                                                              
+    exit 0;                                                                   
+}                                                                             
                                                                               

