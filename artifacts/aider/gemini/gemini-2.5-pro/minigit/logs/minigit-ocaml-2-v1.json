Makefile                                                                       

                                                                               
.PHONY: all clean                                                              
                                                                               
                                                                               
                                                                               
all: minigit                                                                   
                                                                               
                                                                               
                                                                               
minigit: minigit.ml                                                            
                                                                               
    ocamlopt -o minigit unix.cmxa minigit.ml                                   
                                                                               
                                                                               
                                                                               
clean:                                                                         
                                                                               
    rm -f minigit *.cmi *.cmx *.o                                              
                                                                               

minigit.ml                                                                     

                                                                               
let starts_with prefix s =                                                     
                                                                               
  String.length s >= String.length prefix &&                                   
                                                                               
  String.sub s 0 (String.length prefix) = prefix                               
                                                                               
                                                                               
                                                                               
module Utils = struct                                                          
                                                                               
  let minigit_dir = ".minigit"                                                 
                                                                               
  let objects_dir = minigit_dir ^ "/objects"                                   
                                                                               
  let commits_dir = minigit_dir ^ "/commits"                                   
                                                                               
  let index_file = minigit_dir ^ "/index"                                      
                                                                               
  let head_file = minigit_dir ^ "/HEAD"                                        
                                                                               
                                                                               
                                                                               
  let write_file filename content =                                            
                                                                               
    let oc = open_out filename in                                              
                                                                               
    output_string oc content;                                                  
                                                                               
    close_out oc                                                               
                                                                               
                                                                               
                                                                               
  let read_file_bytes filename =                                               
                                                                               
    try                                                                        
                                                                               
      let ic = open_in_bin filename in                                         
                                                                               
      let len = in_channel_length ic in                                        
                                                                               
      let bytes = Bytes.create len in                                          
                                                                               
      really_input ic bytes 0 len;                                             
                                                                               
      close_in ic;                                                             
                                                                               
      Some bytes                                                               
                                                                               
    with _ -> None                                                             
                                                                               
                                                                               
                                                                               
  let read_file_lines filename =                                               
                                                                               
    if not (Sys.file_exists filename) then []                                  
                                                                               
    else                                                                       
                                                                               
      let ic = open_in filename in                                             
                                                                               
      let rec read_all_lines acc =                                             
                                                                               
        try                                                                    
                                                                               
          let line = input_line ic in                                          
                                                                               
          read_all_lines (line :: acc)                                         
                                                                               
        with End_of_file ->                                                    
                                                                               
          close_in ic;                                                         
                                                                               
          List.rev acc                                                         
                                                                               
      in                                                                       
                                                                               
      read_all_lines []                                                        
                                                                               
                                                                               
                                                                               
  let mini_hash_bytes (bytes : Bytes.t) : string =                             
                                                                               
    let h = ref 1469598103934665603L in                                        
                                                                               
    let prime = 1099511628211L in                                              
                                                                               
    Bytes.iter (fun byte ->                                                    
                                                                               
      let b = Int64.of_int (Char.code byte) in                                 
                                                                               
      h := Int64.logxor !h b;                                                  
                                                                               
      h := Int64.mul !h prime;                                                 
                                                                               
    ) bytes;                                                                   
                                                                               
    Printf.sprintf "%016lx" !h                                                 
                                                                               
                                                                               
                                                                               
  let mini_hash_string (s : string) : string =                                 
                                                                               
    mini_hash_bytes (Bytes.of_string s)                                        
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
module Commands = struct                                                       
                                                                               
  let init () =                                                                
                                                                               
    if Sys.file_exists Utils.minigit_dir then                                  
                                                                               
      print_endline "Repository already initialized"                           
                                                                               
    else begin                                                                 
                                                                               
      Unix.mkdir Utils.minigit_dir 0o755;                                      
                                                                               
      Unix.mkdir Utils.objects_dir 0o755;                                      
                                                                               
      Unix.mkdir Utils.commits_dir 0o755;                                      
                                                                               
      Utils.write_file Utils.index_file "";                                    
                                                                               
      Utils.write_file Utils.head_file "";                                     
                                                                               
    end                                                                        
                                                                               
                                                                               
                                                                               
  let add filename =                                                           
                                                                               
    if not (Sys.file_exists filename) then begin                               
                                                                               
      print_endline "File not found";                                          
                                                                               
      exit 1                                                                   
                                                                               
    end;                                                                       
                                                                               
    match Utils.read_file_bytes filename with                                  
                                                                               
    | None ->                                                                  
                                                                               
        print_endline "File not found";                                        
                                                                               
        exit 1                                                                 
                                                                               
    | Some bytes ->                                                            
                                                                               
        let hash = Utils.mini_hash_bytes bytes in                              
                                                                               
        let object_path = Filename.concat Utils.objects_dir hash in            
                                                                               
        if not (Sys.file_exists object_path) then begin                        
                                                                               
          let oc = open_out_bin object_path in                                 
                                                                               
          output_bytes oc bytes;                                               
                                                                               
          close_out oc                                                         
                                                                               
        end;                                                                   
                                                                               
                                                                               
                                                                               
        let staged_files = Utils.read_file_lines Utils.index_file in           
                                                                               
        if not (List.mem filename staged_files) then                           
                                                                               
          let oc = open_out_gen [Open_append; Open_creat] 0o644                
Utils.index_file in                                                            
                                                                               
          Printf.fprintf oc "%s\n" filename;                                   
                                                                               
          close_out oc                                                         
                                                                               
                                                                               
                                                                               
  let commit message =                                                         
                                                                               
    let staged_files = Utils.read_file_lines Utils.index_file in               
                                                                               
    if staged_files = [] then begin                                            
                                                                               
      print_endline "Nothing to commit";                                       
                                                                               
      exit 1                                                                   
                                                                               
    end;                                                                       
                                                                               
                                                                               
                                                                               
    let sorted_files = List.sort String.compare staged_files in                
                                                                               
                                                                               
                                                                               
    let files_with_hashes = List.map (fun filename ->                          
                                                                               
      match Utils.read_file_bytes filename with                                
                                                                               
      | Some bytes -> (filename, Utils.mini_hash_bytes bytes)                  
                                                                               
      | None -> failwith ("Staged file " ^ filename ^ " disappeared")          
                                                                               
    ) sorted_files in                                                          
                                                                               
                                                                               
                                                                               
    let parent_hash =                                                          
                                                                               
      let head_content = Utils.read_file_lines Utils.head_file in              
                                                                               
      match head_content with                                                  
                                                                               
      | [h] when h <> "" -> h                                                  
                                                                               
      | _ -> "NONE"                                                            
                                                                               
    in                                                                         
                                                                               
                                                                               
                                                                               
    let timestamp = int_of_float (Unix.time ()) in                             
                                                                               
                                                                               
                                                                               
    let b = Buffer.create 1024 in                                              
                                                                               
    Printf.bprintf b "parent: %s\n" parent_hash;                               
                                                                               
    Printf.bprintf b "timestamp: %d\n" timestamp;                              
                                                                               
    Printf.bprintf b "message: %s\n" message;                                  
                                                                               
    Buffer.add_string b "files:\n";                                            
                                                                               
    List.iter (fun (file, hash) ->                                             
                                                                               
      Printf.bprintf b "%s %s\n" file hash                                     
                                                                               
    ) files_with_hashes;                                                       
                                                                               
                                                                               
                                                                               
    let commit_content = Buffer.contents b in                                  
                                                                               
    let commit_hash = Utils.mini_hash_string commit_content in                 
                                                                               
                                                                               
                                                                               
    let commit_path = Filename.concat Utils.commits_dir commit_hash in         
                                                                               
    Utils.write_file commit_path commit_content;                               
                                                                               
                                                                               
                                                                               
    Utils.write_file Utils.head_file commit_hash;                              
                                                                               
                                                                               
                                                                               
    Utils.write_file Utils.index_file "";                                      
                                                                               
                                                                               
                                                                               
    Printf.printf "Committed %s\n" commit_hash                                 
                                                                               
                                                                               
                                                                               
  let rec log_entry commit_hash =                                              
                                                                               
    if commit_hash = "NONE" || commit_hash = "" then ()                        
                                                                               
    else                                                                       
                                                                               
      let commit_path = Filename.concat Utils.commits_dir commit_hash in       
                                                                               
      if not (Sys.file_exists commit_path) then                                
                                                                               
        failwith ("Commit object missing: " ^ commit_hash)                     
                                                                               
      else                                                                     
                                                                               
        let lines = Utils.read_file_lines commit_path in                       
                                                                               
        let get_value prefix line = String.sub line (String.length prefix)     
(String.length line - String.length prefix) in                                 
                                                                               
                                                                               
                                                                               
        let parent_line = List.find (starts_with "parent: ") lines in          
                                                                               
        let parent_hash = get_value "parent: " parent_line in                  
                                                                               
                                                                               
                                                                               
        let timestamp_line = List.find (starts_with "timestamp: ") lines in    
                                                                               
        let timestamp = get_value "timestamp: " timestamp_line in              
                                                                               
                                                                               
                                                                               
        let message_line = List.find (starts_with "message: ") lines in        
                                                                               
        let message = get_value "message: " message_line in                    
                                                                               
                                                                               
                                                                               
        Printf.printf "commit %s\n" commit_hash;                               
                                                                               
        Printf.printf "Date: %s\n" timestamp;                                  
                                                                               
        Printf.printf "Message: %s\n" message;                                 
                                                                               
                                                                               
                                                                               
        log_entry parent_hash                                                  
                                                                               
                                                                               
                                                                               
  let log () =                                                                 
                                                                               
    let head_content = Utils.read_file_lines Utils.head_file in                
                                                                               
    match head_content with                                                    
                                                                               
    | [] | [""] -> print_endline "No commits"                                  
                                                                               
    | [current_hash] -> log_entry current_hash                                 
                                                                               
    | _ -> failwith "Malformed HEAD file"                                      
                                                                               
end                                                                            
                                                                               
                                                                               
                                                                               
let () =                                                                       
                                                                               
  match Array.to_list Sys.argv with                                            
                                                                               
  | [_; "init"] -> Commands.init ()                                            
                                                                               
  | [_; "add"; file] -> Commands.add file                                      
                                                                               
  | [_; "commit"; "-m"; message] -> Commands.commit message                    
                                                                               
  | [_; "log"] -> Commands.log ()                                              
                                                                               
  | _ ->                                                                       
                                                                               
      prerr_endline "Error: Invalid command or arguments.";                    
                                                                               
      exit 1                                                                   
                                                                               

