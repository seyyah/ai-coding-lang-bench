+func handleCheckout(commitHash string) {                                      
+   commitPath := filepath.Join(commitsDir, commitHash)                        
+   if _, err := os.Stat(commitPath); os.IsNotExist(err) {                     
+       fmt.Println("Invalid commit")                                          
+       os.Exit(1)                                                             
+   }                                                                          
+                                                                              
+   commitContent, err := os.ReadFile(commitPath)                              
+   if err != nil {                                                            
+       log.Fatalf("Failed to read commit %s: %v", commitHash, err)            
+   }                                                                          
+                                                                              
+   lines := strings.Split(string(commitContent), "\n")                        
+   filesSection := false                                                      
+   for _, line := range lines {                                               
+       if line == "files:" {                                                  
+           filesSection = true                                                
+           continue                                                           
+       }                                                                      
+       if filesSection {                                                      
+           parts := strings.SplitN(line, " ", 2)                              
+           if len(parts) == 2 {                                               
+               filename := parts[0]                                           
+               blobHash := parts[1]                                           
+               blobPath := filepath.Join(objectsDir, blobHash)                
+               blobContent, err := os.ReadFile(blobPath)                      
+               if err != nil {                                                
+                   log.Fatalf("Failed to read blob %s for file %s: %v",       
blobHash, filename, err)                                                       
+               }                                                              
+               if err := os.WriteFile(filename, blobContent, 0644); err != nil
{                                                                              
+                   log.Fatalf("Failed to write file %s: %v", filename, err)   
+               }                                                              
+           }                                                                  
+       }                                                                      
+   }                                                                          
+                                                                              
+   if err := os.WriteFile(headFile, []byte(commitHash), 0644); err != nil {   
+       log.Fatalf("Failed to update HEAD: %v", err)                           
+   }                                                                          
+                                                                              
+   if err := os.Truncate(indexFile, 0); err != nil {                          
+       log.Fatalf("Failed to clear index: %v", err)                           
+   }                                                                          
+                                                                              
+   fmt.Printf("Checked out %s\n", commitHash)                                 
+}                                                                             
+                                                                              
+func handleReset(commitHash string) {                                         
+   commitPath := filepath.Join(commitsDir, commitHash)                        
+   if _, err := os.Stat(commitPath); os.IsNotExist(err) {                     
+       fmt.Println("Invalid commit")                                          
+       os.Exit(1)                                                             
+   }                                                                          
+                                                                              
+   if err := os.WriteFile(headFile, []byte(commitHash), 0644); err != nil {   
+       log.Fatalf("Failed to update HEAD: %v", err)                           
+   }                                                                          
+                                                                              
+   if err := os.Truncate(indexFile, 0); err != nil {                          
+       log.Fatalf("Failed to clear index: %v", err)                           
+   }                                                                          
+                                                                              
+   fmt.Printf("Reset to %s\n", commitHash)                                    
+}                                                                             
